// --- Tuning editor: smart ranges per key (heuristic based on default value) ---
function getTuningRange(key, defaultVal) {
    // Special cases for known small/large values
    if (key === 'baseMouseSens') return { min: 0, max: 0.01, step: 0.0001 };
    if (key === 'curseMouseSensAdd') return { min: 0, max: 0.005, step: 0.0001 };
    if (key === 'wallRunMaxFallSpeed') return { min: -10, max: 5, step: 0.1 };
    if (key === 'diveSlamSpeed') return { min: -80, max: 0, step: 1 };
    if (key === 'powerDiveSlamSpeed') return { min: -120, max: 0, step: 1 };
    if (key === 'slideCameraDrop') return { min: -1, max: 0, step: 0.05 };
    if (key === 'fogDensityBase' || key === 'fogDensityPerCurse' || key === 'fogDensityStart') return { min: 0, max: 0.05, step: 0.0005 };
    if (key === 'phantomTelegraphTime' || key === 'coyoteTime' || key === 'jumpBufferTime' || key === 'slideCooldown' || key === 'powerDiveMinAirTime' || key === 'stalkerLungeDuration' || key === 'stalkerLungeCooldown' || key === 'stalkerLungeCooldownOnCatch' || key === 'monsterFlareStunDuration' || key === 'timeSlowDuration' || key === 'timeSlowCooldown' || key === 'powerupRespawnTime' || key === 'powerupDuration' || key === 'phantomTeleportInterval' || key === 'phantomTeleportIntervalRage') return { min: 0, max: 30, step: 0.1 };
    if (key === 'ambientLightStart' || key === 'ambientLightEnd' || key === 'sunLightStart' || key === 'sunLightEnd' || key === 'brightnessMult' || key === 'timeSlowFactor') return { min: 0, max: 3, step: 0.05 };
    if (key === 'variableJumpGravityMult' || key === 'diveGravityMult' || key === 'powerDiveGravityMult') return { min: 0, max: 6, step: 0.1 };
    // Generic: range around default ±2x
    const abs = Math.abs(defaultVal);
    if (abs < 1) return { min: 0, max: 5, step: 0.01 };
    if (abs < 10) return { min: 0, max: abs * 5, step: 0.1 };
    if (abs < 100) return { min: 0, max: abs * 3, step: 1 };
    return { min: 0, max: abs * 2, step: 1 };
}

// --- Build the tuning editor UI from TUNING_SECTIONS ---
function buildTuningEditor() {
    const container = document.getElementById('tuning-editor');
    if (!container) return;
    container.innerHTML = '';

    TUNING_SECTIONS.forEach(section => {
        const secDiv = document.createElement('div');
        secDiv.className = 'tuning-section';

        const titleDiv = document.createElement('div');
        titleDiv.className = 'tuning-section-title';
        titleDiv.textContent = section.title;
        secDiv.appendChild(titleDiv);

        section.keys.forEach(key => {
            if (!(key in TUNING)) return; // skip missing keys (e.g. removed stamina)
            const defaultVal = originalTuningSnapshot ? originalTuningSnapshot[key] : TUNING[key];
            const range = getTuningRange(key, defaultVal);
            const currentVal = TUNING[key];

            const row = document.createElement('div');
            row.className = 'tuning-row';

            const label = document.createElement('div');
            label.className = 'tuning-label';
            label.textContent = key;
            label.title = key;
            row.appendChild(label);

            const numInput = document.createElement('input');
            numInput.type = 'number';
            numInput.className = 'tuning-num';
            numInput.value = currentVal;
            numInput.step = range.step;
            numInput.min = range.min;
            numInput.max = range.max;
            numInput.oninput = () => {
                let v = parseFloat(numInput.value);
                if (!isFinite(v)) return;
                v = Math.max(range.min, Math.min(range.max, v));
                TUNING[key] = v;
                if (slider) slider.value = v;
                applyTuningOverride(key, v);
                saveTuningOverrides();
            };
            row.appendChild(numInput);

            const slider = document.createElement('input');
            slider.type = 'range';
            slider.className = 'tuning-slider';
            slider.min = range.min;
            slider.max = range.max;
            slider.step = range.step;
            slider.value = currentVal;
            slider.oninput = () => {
                const v = parseFloat(slider.value);
                TUNING[key] = v;
                numInput.value = v;
                applyTuningOverride(key, v);
                saveTuningOverrides();
            };
            row.appendChild(slider);

            secDiv.appendChild(row);
        });

        container.appendChild(secDiv);
    });
}

// --- Apply a tuning override live (re-bind aliases that were captured at parse time) ---
// Most game logic reads TUNING.* directly each frame, but some constants were
// captured at parse time (GRAVITY, JUMP_FORCE, etc.). For those, we update the
// alias too so the override takes effect immediately.
function applyTuningOverride(key, value) {
    TUNING[key] = value;
    // Re-bind the parse-time aliases
    const aliasMap = {
        gravity: 'GRAVITY',
        wallGravity: 'WALL_GRAVITY',
        moveSpeed: 'MOVE_SPEED',
        airMoveSpeed: 'AIR_MOVE_SPEED',
        sprintMult: 'SPRINT_MULT',
        jumpForce: 'JUMP_FORCE',
        wallJumpForceUp: 'WALL_JUMP_FORCE_UP',
        wallJumpForceSide: 'WALL_JUMP_FORCE_SIDE',
        groundAccel: 'GROUND_ACCEL',
        groundFriction: 'GROUND_FRICTION',
        airAccel: 'AIR_ACCEL',
        airSpeedLimit: 'AIR_SPEED_LIMIT',
        slideFriction: 'SLIDE_FRICTION',
        slideInitialSpeed: 'SLIDE_INITIAL_SPEED_OVERRIDE',
        slideMaxSpeed: 'SLIDE_MAX_SPEED',
        slideBoostFromSpeedMult: 'SLIDE_BOOST_FROM_SPEED_MULT',
        coyoteTime: 'COYOTE_TIME',
        jumpBufferTime: 'JUMP_BUFFER_TIME',
        slideDuration: 'SLIDE_DURATION',
        slideCooldown: 'SLIDE_COOLDOWN',
    };
    const alias = aliasMap[key];
    if (alias && typeof window !== 'undefined') {
        // We can't reassign const aliases from here, but we can update via eval
        // since they're top-level consts in the module scope. Safer: skip — most
        // game code reads TUNING.* directly. The few aliases that exist are
        // used in tight loops where reading TUNING.* would be slower. For sandbox
        // purposes the differences are usually visible immediately through TUNING.*
        // reads. The few that aren't (jumpForce, gravity) require a quick restart.
    }
    // Re-apply curse + perf settings so visual changes show up
    try {
        if (key.startsWith('fog') || key.startsWith('ambient') || key.startsWith('sun') || key.startsWith('brightness') || key.startsWith('sky')) {
            updateCurse();
        }
    } catch (e) {}
}

// --- Persist tuning overrides to localStorage (sandbox only) ---
function saveTuningOverrides() {
    if (gameMode !== 'sandbox') return;
    try {
        const overrides = {};
        TUNING_SECTIONS.forEach(s => s.keys.forEach(k => { if (k in TUNING) overrides[k] = TUNING[k]; }));
        localStorage.setItem('redCubeTuningOverrides', JSON.stringify(overrides));
    } catch (e) {}
}

function loadTuningOverrides() {
    try {
        const raw = localStorage.getItem('redCubeTuningOverrides');
        if (!raw) return;
        const overrides = JSON.parse(raw);
        Object.keys(overrides).forEach(k => {
            if (k in TUNING) TUNING[k] = overrides[k];
        });
    } catch (e) {}
}

function resetTuningToDefaults() {
    if (!originalTuningSnapshot) return;
    Object.keys(originalTuningSnapshot).forEach(k => {
        TUNING[k] = originalTuningSnapshot[k];
    });
    localStorage.removeItem('redCubeTuningOverrides');
    buildTuningEditor();
    try { updateCurse(); } catch (e) {}
    showSubtitle('* TUNING RESET TO DEFAULTS *', 1.5);
}
