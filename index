// ===================== PHANTOM MONSTER =====================
// A teleporting ghost. Slow base movement, but teleports to a random position
// near the player every few seconds. Telegraphs with a faint ghost before
// arrival. Phases through obstacles (no AABB collision). Higher rage = faster
// teleports + larger catch radius.
function createPhantom() {
    const group = new THREE.Group();
    const S = TUNING.phantomScaleMin + Math.random() * TUNING.phantomScaleRange;

    // Body: floating cloak / wraith — a tall thin cone tapering up, with
    // a glowing eye and tattered "skirt" of cones hanging below.
    const cloakMat = new THREE.MeshPhongMaterial({
        color: 0x1a0a2a, emissive: 0x440066, emissiveIntensity: 0.3,
        transparent: true, opacity: 0.85, shininess: 60
    });
    const cloak = new THREE.Mesh(
        new THREE.ConeGeometry(S * 0.8, S * 3.2, 8, 1, true),
        cloakMat
    );
    cloak.position.y = S * 1.6;
    group.add(cloak);

    // Inner glow core
    const coreMat = new THREE.MeshBasicMaterial({
        color: 0xaa55ff, transparent: true, opacity: 0.6
    });
    const core = new THREE.Mesh(new THREE.SphereGeometry(S * 0.4, 12, 12), coreMat);
    core.position.y = S * 1.8;
    group.add(core);

    // Single glowing eye
    const eyeMat = new THREE.MeshBasicMaterial({ color: 0xff00ff });
    const eyeHaloMat = new THREE.MeshBasicMaterial({ color: 0xff00ff, transparent: true, opacity: 0.5 });
    const eye = new THREE.Mesh(new THREE.SphereGeometry(S * 0.18, 10, 10), eyeMat);
    eye.position.set(0, S * 2.0, S * 0.6);
    group.add(eye);
    const eyeHalo = new THREE.Mesh(new THREE.SphereGeometry(S * 0.32, 12, 12), eyeHaloMat);
    eyeHalo.position.copy(eye.position);
    group.add(eyeHalo);

    // Tattered skirt cones hanging below
    for (let i = 0; i < 6; i++) {
        const ang = (i / 6) * Math.PI * 2;
        const tatter = new THREE.Mesh(
            new THREE.ConeGeometry(S * 0.25, S * 1.0, 4),
            cloakMat
        );
        tatter.position.set(Math.cos(ang) * S * 0.4, S * 0.4, Math.sin(ang) * S * 0.4);
        tatter.rotation.x = Math.PI;
        tatter.userData = { ang, phase: Math.random() * Math.PI * 2 };
        group.add(tatter);
    }

    // Aura
    const auraMat = new THREE.MeshBasicMaterial({
        color: 0x6600aa, transparent: true, opacity: 0.18,
        side: THREE.BackSide, depthWrite: false
    });
    const aura = new THREE.Mesh(new THREE.SphereGeometry(S * 2.2, 12, 12), auraMat);
    aura.position.y = S * 1.8;
    group.add(aura);

    // Spawn position
    const angle = Math.random() * Math.PI * 2;
    const dist = TUNING.monsterSpawnDistMin + Math.random() * TUNING.monsterSpawnDistRange;
    group.position.set(Math.cos(angle) * dist, 0, Math.sin(angle) * dist);

    group.userData = {
        kind: 'phantom',
        scale: S,
        aiState: 'wander',
        rage: 0,
        teleportTimer: 1 + Math.random() * 2,
        telegraphMesh: null,
        telegraphTimer: 0,
        refs: { aura, eye, eyeHalo, core, cloakMat, coreMat, eyeMat, eyeHaloMat, auraMat },
        bobPhase: Math.random() * Math.PI * 2
    };

    group.visible = false;
    scene.add(group);
    monsters.push(group);
    createMonsterBeacon();
    return group;
}

// ===================== TIME SLOW ABILITY =====================
function useTimeSlow() {
    if (timeSlowCooldownTimer > 0 || timeSlowActive) return;
    if (!timeSlowEnabled) return;
    if (!gameStarted || gameEnded || isJumpscareActive) return;
    timeSlowActive = true;
    timeSlowTimer = TUNING.timeSlowDuration;
    timeSlowCooldownTimer = TUNING.timeSlowCooldown;
    runStats.timeSlowUses++;
    runStats.abilitiesUsed++;
    if (v2UI.timeslowOverlay) v2UI.timeslowOverlay.classList.add('active');
    unlockAchievement('time_slow');
    // Brief purple flash
    triggerImpactFrame({ color: '#aa55ff', duration: 200, hitstop: 0, flat: true });
    showSubtitle('* TIME SLOW ACTIVATED *', 1.5);
}

function updateTimeSlow(dt) {
    if (!timeSlowActive && timeSlowCooldownTimer <= 0) return;
    if (timeSlowActive) {
        timeSlowTimer -= dt;
        if (timeSlowTimer <= 0) {
            timeSlowActive = false;
            timeSlowTimer = 0;
            if (v2UI.timeslowOverlay) v2UI.timeslowOverlay.classList.remove('active');
        }
    }
    if (timeSlowCooldownTimer > 0) {
        timeSlowCooldownTimer = Math.max(0, timeSlowCooldownTimer - dt);
    }
    // Update UI
    if (v2UI.timeslow) v2UI.timeslow.style.display = 'block';
    if (v2UI.timeslowLabel) {
        if (timeSlowActive) v2UI.timeslowLabel.textContent = `SLOW — ${timeSlowTimer.toFixed(1)}s`;
        else if (timeSlowCooldownTimer > 0) v2UI.timeslowLabel.textContent = `SLOW — ${timeSlowCooldownTimer.toFixed(1)}s`;
        else v2UI.timeslowLabel.textContent = 'SLOW [E] — READY';
    }
    if (v2UI.timeslowBarFill) {
        if (timeSlowActive) {
            v2UI.timeslowBarFill.style.width = (timeSlowTimer / TUNING.timeSlowDuration * 100) + '%';
            v2UI.timeslowBarFill.style.background = '#aa55ff';
        } else if (timeSlowCooldownTimer > 0) {
            v2UI.timeslowBarFill.style.width = ((1 - timeSlowCooldownTimer / TUNING.timeSlowCooldown) * 100) + '%';
            v2UI.timeslowBarFill.style.background = '#553388';
        } else {
            v2UI.timeslowBarFill.style.width = '100%';
            v2UI.timeslowBarFill.style.background = '#aa55ff';
        }
    }
}

function getTimeScale() {
    return timeSlowActive ? TUNING.timeSlowFactor : 1.0;
}

// ===================== POWER-UPS =====================
function spawnPowerups() {
    // Clear any existing powerups
    powerups.forEach(p => { if (p.mesh) scene.remove(p.mesh); });
    powerups = [];
    if (!powerupsEnabled) return;
    if (gameMode === 'zen' && !powerupsEnabled) return;

    const count = TUNING.powerupSpawnCount;
    const mapHalf = MAP_SIZE * 0.45;
    for (let i = 0; i < count; i++) {
        const type = POWERUP_TYPES[i % POWERUP_TYPES.length];
        const color = POWERUP_COLORS[type];
        // Build a glowing icosahedron with an outer wire shell
        const geo = new THREE.IcosahedronGeometry(1.2, 0);
        const mat = new THREE.MeshPhongMaterial({
            color, emissive: color, emissiveIntensity: 0.8,
            transparent: true, opacity: 0.85, shininess: 100
        });
        const mesh = new THREE.Mesh(geo, mat);
        const shellMat = new THREE.MeshBasicMaterial({
            color, wireframe: true, transparent: true, opacity: 0.5
        });
        const shell = new THREE.Mesh(new THREE.IcosahedronGeometry(1.6, 0), shellMat);
        mesh.add(shell);

        // Find a clear spot — pick random position, away from spawn platform
        let px, pz, attempts = 0;
        do {
            px = (Math.random() - 0.5) * 2 * mapHalf;
            pz = (Math.random() - 0.5) * 2 * mapHalf;
            attempts++;
        } while (Math.hypot(px, pz) < 25 && attempts < 20);

        mesh.position.set(px, 3.5 + Math.random() * 4, pz);
        mesh.userData = { type, shell, spinPhase: Math.random() * Math.PI * 2 };
        scene.add(mesh);
        powerups.push({ mesh, type, respawnTimer: 0, active: true });
    }
}

function updatePowerups(dt) {
    if (!powerupsEnabled) return;
    for (const p of powerups) {
        if (!p.active) {
            p.respawnTimer -= dt;
            if (p.respawnTimer <= 0) {
                p.active = true;
                p.mesh.visible = true;
                // Move to new random spot
                const mapHalf = MAP_SIZE * 0.45;
                let px, pz, attempts = 0;
                do {
                    px = (Math.random() - 0.5) * 2 * mapHalf;
                    pz = (Math.random() - 0.5) * 2 * mapHalf;
                    attempts++;
                } while (Math.hypot(px, pz) < 25 && attempts < 20);
                p.mesh.position.set(px, 3.5 + Math.random() * 4, pz);
                p.mesh.userData.type = POWERUP_TYPES[Math.floor(Math.random() * POWERUP_TYPES.length)];
                const col = POWERUP_COLORS[p.mesh.userData.type];
                p.mesh.material.color.setHex(col);
                p.mesh.material.emissive.setHex(col);
                p.mesh.userData.shell.material.color.setHex(col);
            }
            continue;
        }
        // Spin + bob
        p.mesh.rotation.y += dt * 1.5;
        p.mesh.rotation.x += dt * 0.6;
        p.mesh.userData.spinPhase += dt * 2;
        p.mesh.position.y = p.mesh.position.y + Math.sin(p.mesh.userData.spinPhase) * dt * 0.3;
        if (p.mesh.userData.shell) p.mesh.userData.shell.rotation.y -= dt * 2;

        // Pickup check
        const dx = p.mesh.position.x - player.position.x;
        const dz = p.mesh.position.z - player.position.z;
        const dy = p.mesh.position.y - player.position.y;
        if (dx * dx + dz * dz + dy * dy < TUNING.powerupPickupRadius * TUNING.powerupPickupRadius) {
            pickupPowerup(p);
        }
    }
}

function pickupPowerup(p) {
    p.active = false;
    p.mesh.visible = false;
    p.respawnTimer = TUNING.powerupRespawnTime;
    activePowerup = { type: p.mesh.userData.type, timer: TUNING.powerupDuration };
    runStats.powerupsCollected++;
    showPickupToast(POWERUP_NAMES[activePowerup.type]);
    showSubtitle('* ' + POWERUP_NAMES[activePowerup.type] + ' *', 1.5);

    // Visual FX
    triggerImpactFrame({ color: '#' + POWERUP_COLORS[activePowerup.type].toString(16).padStart(6, '0'), duration: 220, hitstop: 0, flat: true });
    if (activePowerup.type === 'shield' && v2UI.shieldRing) v2UI.shieldRing.classList.add('active');
}

function updateActivePowerup(dt) {
    if (!activePowerup) {
        if (v2UI.powerup) v2UI.powerup.style.display = 'none';
        return;
    }
    activePowerup.timer -= dt;
    if (activePowerup.timer <= 0) {
        if (activePowerup.type === 'shield' && v2UI.shieldRing) v2UI.shieldRing.classList.remove('active');
        activePowerup = null;
        if (v2UI.powerup) v2UI.powerup.style.display = 'none';
        return;
    }
    // Update UI
    if (v2UI.powerup) v2UI.powerup.style.display = 'block';
    if (v2UI.puName) {
        const col = '#' + POWERUP_COLORS[activePowerup.type].toString(16).padStart(6, '0');
        v2UI.puName.textContent = POWERUP_NAMES[activePowerup.type];
        v2UI.puName.style.color = col;
        v2UI.powerup.style.borderColor = col;
        v2UI.powerup.style.color = col;
    }
    if (v2UI.puBarFill) {
        v2UI.puBarFill.style.width = (activePowerup.timer / TUNING.powerupDuration * 100) + '%';
    }
}

function isShieldActive() { return activePowerup && activePowerup.type === 'shield'; }
function isSpeedBoostActive() { return activePowerup && activePowerup.type === 'speed'; }
function isMagnetActive() { return activePowerup && activePowerup.type === 'magnet'; }

// Magnet effect: pull nearby cubes toward player
function applyMagnetEffect(dt) {
    if (!isMagnetActive()) return;
    for (const cube of cubes) {
        if (cube.userData.collected) continue;
        const dx = player.position.x - cube.position.x;
        const dz = player.position.z - cube.position.z;
        const distSq = dx * dx + dz * dz;
        if (distSq < TUNING.powerupMagnetRadius * TUNING.powerupMagnetRadius && distSq > 1) {
            const dist = Math.sqrt(distSq);
            const force = TUNING.powerupMagnetForce * dt;
            cube.position.x += (dx / dist) * force;
            cube.position.z += (dz / dist) * force;
        }
    }
}

// ===================== COMBO SYSTEM =====================
function addCombo() {
    if (!settingComboEnabled) return;
    comboCount++;
    comboTimer = TUNING.comboWindow;
    // Multiplier = 1 + floor(combo / 3), capped
    comboMultiplier = Math.min(TUNING.comboMaxMultiplier, 1 + Math.floor(comboCount / 3));
    if (comboMultiplier > maxComboReached) {
        maxComboReached = comboMultiplier;
        runStats.maxCombo = comboMultiplier;
    }
    if (comboMultiplier >= 5) unlockAchievement('combo_5');
    if (comboMultiplier >= 10) unlockAchievement('combo_10');
}

function updateCombo(dt) {
    if (!settingComboEnabled) {
        if (v2UI.combo) v2UI.combo.classList.remove('active');
        return;
    }
    if (comboCount === 0) {
        if (v2UI.combo) v2UI.combo.classList.remove('active');
        return;
    }
    comboTimer -= dt;
    if (comboTimer <= 0) {
        comboCount = 0;
        comboMultiplier = 1;
        if (v2UI.combo) v2UI.combo.classList.remove('active');
        return;
    }
    // Update UI
    if (v2UI.combo) v2UI.combo.classList.add('active');
    if (v2UI.comboXText) v2UI.comboXText.textContent = '×' + comboMultiplier;
    if (v2UI.comboBarFill) v2UI.comboBarFill.style.width = (comboTimer / TUNING.comboWindow * 100) + '%';
    // Rush mode bonus: time subtracted per cube at combo x2+
    if (gameMode === 'rush' && comboMultiplier >= 2) {
        // Negative time gain (subtracts from gameTime)
        gameTime -= TUNING.comboScoreBonusPerCube * dt * (comboMultiplier - 1);
        if (gameTime < 0) gameTime = 0;
    }
}

