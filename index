const ABILITY_COOLDOWN = 12.0;
let abilityCooldownTimer = 0;
let currentRunTime = 0;

function useAbility() {
    if (!gameStarted || gameEnded || isJumpscareActive || abilityCooldownTimer > 0) return;
    abilityCooldownTimer = ABILITY_COOLDOWN;
    runStats.flareUses++;
    runStats.abilitiesUsed++;
    if (runStats.flareUses >= 5) unlockAchievement('flare_5');
    triggerSonicBoom(player.position.clone());
    for (let i = 0; i < monsters.length; i++) {
        const m = monsters[i];
        if (!m.visible) continue;
        const dx = m.position.x - player.position.x;
        const dz = m.position.z - player.position.z;
        const distSq = dx * dx + dz * dz;
        if (distSq < TUNING.monsterFlareRadius * TUNING.monsterFlareRadius) {
            const dist = Math.sqrt(distSq) || 1;
            m.position.x += (dx / dist) * TUNING.monsterFlarePushDist;
            m.position.z += (dz / dist) * TUNING.monsterFlarePushDist;
            m.userData.stunTimer = TUNING.monsterFlareStunDuration;
        }
    }
    showCurseMsg('FLARE DEPLOYED', 1200);
}

// ===================== ABILITY: POWER DIVE =====================
// A dedicated heavy-slam dive on its own key (default V). Distinct from the
// regular slide-dive (which is just "press Ctrl while airborne" and gives a
// -26 u/s slam). The power dive fires a much harder -55 u/s slam, applies a
// steeper gravity multiplier while active, and triggers an impact frame +
// camera shake on landing for the anime "ground pound" feel.
//
// Constraints:
//   - Only fires when airborne (grounded press does nothing — you can still
//     regular-slide on the ground via Ctrl).
//   - Enforces a tiny min-air-time so jump + V in the same frame doesn't
//     instantly waste the dive into the floor.
//   - Cooldown is short (default 1.5s) so it chains naturally with jumps and
//     slides, but long enough that you can't spam it to fly.
//   - Cancelled automatically on landing, wall-run, or jump.
function usePowerDive() {
    if (!gameStarted || gameEnded || isJumpscareActive) return;
    if (isFlying) return;
    if (isGrounded) return;                  // can only dive from the air
    if (isWallRunning) return;               // wall-run takes precedence
    if (isPowerDiving) return;               // already diving
    if (powerDiveCooldownTimer > 0) return;  // on cooldown
    if (powerDiveAirTimeTracker < TUNING.powerDiveMinAirTime) return; // just left ground — too soon

    isPowerDiving = true;
    powerDiveCooldownTimer = TUNING.powerDiveCooldown;
    runStats.powerDiveUses++;
    runStats.abilitiesUsed++;

    // Hard downward slam — ~2.1x stronger than the regular air-dive's -26.
    velocity.y = TUNING.powerDiveSlamSpeed;

    // Small forward boost along look direction so the dive preserves momentum
    // and feels like a deliberate "commit" rather than just dropping.
    const fwd = new THREE.Vector3(0, 0, -1).applyAxisAngle(Y_AXIS, yaw).normalize();
    const curHSpeed = Math.hypot(velocity.x, velocity.z);
    // Only add the boost; never replace existing horizontal momentum (so a
    // Mach-3 power-dive keeps its speed instead of being clipped to 18 u/s).
    velocity.x += fwd.x * TUNING.powerDiveForwardBoost;
    velocity.z += fwd.z * TUNING.powerDiveForwardBoost;

    // Cancel any in-flight slide so the two states don't fight over gravity.
    if (isSliding) {
        isSliding = false;
        isDive = false;
        slideCooldownTimer = SLIDE_COOLDOWN;
    }

    // Audio + UI feedback. The rumble is lower/longer than the regular slide
    // noise so the power dive audibly hits harder.
    playNoise(0.45, 0.18, 28);
}


