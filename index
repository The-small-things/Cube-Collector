// --- Run-ID + pending-timer tracking (fixes quickRestart freezes) ---
// quickRestart needs to invalidate any pending setTimeout callbacks so
// they can't fire after the restart and corrupt the new run's state.
// The most common culprits:
//   - setTimeout(() => endGame('win'), 1500)     → fires endGame, sets gameEnded=true, FREEZES the new run
//   - setTimeout(() => endGame('caught'), 1500)  → same, from monster jumpscare
//   - setTimeout(() => updateCurse(), 360)       → may re-apply stale curse state
//   - setTimeout(() => {machText filter reset})  → cosmetic, harmless
//
// We track a `currentRunId` that increments on every quickRestart. Pending
// callbacks capture the run ID at scheduling time and check it before
// running — if the ID has changed, the callback is a stale leftover and
// is silently dropped.
let currentRunId = 0;
// Timestamp (performance.now()) of the last quickRestart. The pointerlockchange
// handler uses this to suppress the brief unlock-during-relock flicker for a
// short window (300ms) after a restart. After 300ms, normal pause/resume
// behavior is restored so ESC still works.
let _lastRestartTime = 0;
const RESTART_SUPPRESS_WINDOW_MS = 300;
// Wrap setTimeout so callbacks auto-skip if the run ID has changed.
function runScopedTimeout(fn, delay) {
    const scheduledRunId = currentRunId;
    return setTimeout(() => {
        if (scheduledRunId !== currentRunId) return; // stale — drop
        try { fn(); } catch (e) { /* ignore */ }
    }, delay);
}
// Force-clear any raw setTimeout handles we know about. Used by quickRestart
// as a belt-and-suspenders on top of the run-ID check.
let _pendingTimeouts = [];
function trackTimeout(handle) { _pendingTimeouts.push(handle); return handle; }
function clearTrackedTimeouts() {
    _pendingTimeouts.forEach(h => clearTimeout(h));
    _pendingTimeouts = [];
}

async function startLoadingSequence() {
    runTainted = false;
    const taintBadge = document.getElementById('taint-badge');
    if (taintBadge) taintBadge.style.display = 'none';
    const screen = document.getElementById('loading-screen');
    const bar = document.getElementById('loading-bar-inner');
    const status = document.getElementById('loading-status');
    
    instructions.style.display = 'none';
    screen.style.display = 'flex';
    
    // Apply pulsing effects based on curseFactor
    const pulseTime = 2.0 / (1 + curseFactor * 4); // Faster pulse if cursed
    screen.style.animation = `pulse-screen ${pulseTime}s infinite ease-in-out`;
    bar.style.animation = `pulse-bar ${pulseTime}s infinite ease-in-out`;
    if (curseFactor > 0.5) status.style.color = "#ff0000";

    initAudio();

    // 1. Pre-bake Reverb Cache (The main cause of cube pickup lag)
    // We generate buffers for durations 0.1s through 1.0s ahead of time.
    for (let i = 1; i <= 10; i++) {
        const dur = i / 10;
        status.textContent = `Baking Reverb Space: ${dur.toFixed(1)}s`;
        bar.style.width = (i * 5) + "%";
        buildReverbNow(dur);
        await new Promise(r => setTimeout(r, 20)); // Yield to allow UI update
    }

    // 2. Wait for Chase Music to decode
    status.textContent = "Decoding Horror Streams...";
    bar.style.width = "70%";
    if (musicLoadPromise) await musicLoadPromise;

    // 3. Pre-spawn Monsters (prevents lag hitch at 17 cubes)
    status.textContent = "Manifesting Horrors...";
    bar.style.width = "85%";
    const diffCfg = (DIFFICULTY_SETTINGS[difficulty] || DIFFICULTY_SETTINGS.normal);
    // Stalkers: state-machine predators — count now scales with difficulty
    const stalkerCount = diffCfg.stalkerCount || 3;
    for (let i = 0; i < stalkerCount; i++) {
        createStalker();
        await new Promise(r => setTimeout(r, 10));
    }
    // Hounds: momentum-based trackers, count scales with difficulty.
    const houndCount = diffCfg.houndCount;
    for (let i = 0; i < houndCount; i++) {
        createHound();
        await new Promise(r => setTimeout(r, 10));
    }
    // v2.0: Phantoms — teleporting ghosts, count scales with difficulty
    const phantomCount = diffCfg.phantomCount || 0;
    for (let i = 0; i < phantomCount; i++) {
        createPhantom();
        await new Promise(r => setTimeout(r, 10));
    }
    
    // v2.0: Initialize new systems + spawn power-ups + apply zen mode visuals
    initV2Systems();
    spawnPowerups();
    applyZenModeVisuals();
    if (v2UI.versionBadge) v2UI.versionBadge.classList.add('show');
    minimapVisible = settingMinimap;

    // v2.1: Sandbox mode setup — auto-taint (no leaderboard), snapshot TUNING, load overrides
    if (gameMode === 'sandbox') {
        taintRun('sandbox mode — no leaderboard');
        if (!originalTuningSnapshot) originalTuningSnapshot = JSON.parse(JSON.stringify(TUNING));
        loadTuningOverrides();
        try { updateCurse(); } catch (e) {}
    }
    updateTuningTabState();
    updateSandboxHintVisibility();
    
    bar.style.width = "100%";
    status.textContent = "Void Ready";
    
    setTimeout(() => {
        gameStarted = true;
        screen.style.display = 'none';
        document.body.classList.add('game-active');
        document.body.requestPointerLock();

        const timerEl = document.getElementById('run-timer');
        if (gameMode === 'timeattack' || gameMode === 'survival' || gameMode === 'rush') {
            document.getElementById('run-timer-label').textContent = gameMode === 'survival' ? 'SURVIVED' : 'TIME';
            document.getElementById('run-timer-value').textContent = formatTime(0);
            timerEl.style.display = 'block';
            // Show the time-multiplier indicator only in survival mode.
            const multEl = document.getElementById('run-timer-mult');
            if (multEl) multEl.style.display = (gameMode === 'survival') ? 'inline' : 'none';
        } else {
            timerEl.style.display = 'none';
        }
    }, 400);
}

