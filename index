    // Always open on the keybinds tab.
    showSettingsTab('keybinds');
    // Update back button label depending on whether we're mid-game
    const backBtn = document.getElementById('settings-back-btn');
    if (backBtn) {
        const midGame = gameStarted && !gameEnded;
        backBtn.innerHTML = '<span class="arrow">&#8592;</span> SAVE &amp; BACK TO ' + (midGame ? 'PAUSE MENU' : 'MENU');
