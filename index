const cubeMat = new THREE.MeshStandardMaterial({ color: 0xff0000, roughness: 0.2, metalness: 0.7, emissive: 0xff0000, emissiveIntensity: 3.0 }); // Brighter, more reflective cubes
const cubeGeo = new THREE.BoxGeometry(1.2, 1.2, 1.2);

