// =====================================================================
// PROCEDURAL GRASS & STONE TEXTURES
// Generated on a canvas so the file is self-contained (no external
// grass.jpg / stone.jpg that 404 in sandboxes) AND so we can bake in
// multi-scale grid lines for altitude perception. The grid pattern is
// what gives you depth cues when airborne — a single flat color makes
// it impossible to tell how high you are.
// =====================================================================

function makeGrassTexture() {
    const size = 512;
    const c = document.createElement('canvas');
    c.width = c.height = size;
    const ctx = c.getContext('2d');

    // Base grass color with vertical gradient bands for organic variation
    const base = ctx.createLinearGradient(0, 0, 0, size);
    base.addColorStop(0, '#6cb86c');
    base.addColorStop(0.5, '#5fae5f');
    base.addColorStop(1, '#73c273');
    ctx.fillStyle = base;
    ctx.fillRect(0, 0, size, size);

    // Sprinkle darker grass blades — gives the surface "grain" so motion
    // is visible even when sprinting at Mach 4.
    for (let i = 0; i < 1400; i++) {
        const x = Math.random() * size;
        const y = Math.random() * size;
        const len = 3 + Math.random() * 6;
        const shade = Math.random();
        ctx.strokeStyle = shade > 0.5
            ? `rgba(40, 90, 40, ${0.25 + Math.random() * 0.35})`
            : `rgba(120, 180, 110, ${0.2 + Math.random() * 0.3})`;
        ctx.lineWidth = 1 + Math.random() * 1.2;
        ctx.beginPath();
        ctx.moveTo(x, y);
        ctx.lineTo(x + (Math.random() - 0.5) * 2, y - len);
        ctx.stroke();
    }

    // Clumps of darker moss for larger-scale variation
    for (let i = 0; i < 40; i++) {
        const x = Math.random() * size;
        const y = Math.random() * size;
        const r = 6 + Math.random() * 14;
        const g = ctx.createRadialGradient(x, y, 0, x, y, r);
        g.addColorStop(0, 'rgba(45, 85, 45, 0.45)');
        g.addColorStop(1, 'rgba(45, 85, 45, 0)');
        ctx.fillStyle = g;
        ctx.beginPath();
        ctx.arc(x, y, r, 0, Math.PI * 2);
        ctx.fill();
    }

    // --- ALTITUDE GRID (the actual reason for this texture) ---
    // Three nested scales of grid lines so at any jump height you can
    // see distinct marks and gauge how far you are from the ground:
    //   - Fine:   every 1/8 of the tile (dense, for low-altitude strafing)
    //   - Medium: every 1/4 of the tile (visible at mid jump height)
    //   - Bold:   tile border (visible from very high up / slide-jumps)
    // The pattern tiles 160× across the 2000-unit map, so each tile is
    // 12.5 units — meaning the medium grid is every ~3 units, bold every
    // ~12.5 units, fine every ~1.5 units. Plenty of cues at any height.
    // (Alpha values kept low so the grid reads as a subtle floor pattern,
    // not a glowing overlay — keeps visual focus on the cubes.)

    // Fine grid (subtle)
    ctx.strokeStyle = 'rgba(30, 70, 30, 0.10)';
    ctx.lineWidth = 1;
    const fine = 8;
    for (let i = 1; i < fine; i++) {
        const p = (i / fine) * size;
        ctx.beginPath(); ctx.moveTo(p, 0); ctx.lineTo(p, size); ctx.stroke();
        ctx.beginPath(); ctx.moveTo(0, p); ctx.lineTo(size, p); ctx.stroke();
    }

    // Medium grid (more visible)
    ctx.strokeStyle = 'rgba(25, 60, 25, 0.18)';
    ctx.lineWidth = 1.5;
    const med = 4;
    for (let i = 1; i < med; i++) {
        const p = (i / med) * size;
        ctx.beginPath(); ctx.moveTo(p, 0); ctx.lineTo(p, size); ctx.stroke();
        ctx.beginPath(); ctx.moveTo(0, p); ctx.lineTo(size, p); ctx.stroke();
    }

    // Bold border (clearly visible from high up)
    ctx.strokeStyle = 'rgba(20, 50, 20, 0.28)';
    ctx.lineWidth = 2;
    ctx.strokeRect(0, 0, size, size);

    // Corner dots at every tile intersection — visible even at Mach 4
    // slide-jump altitude but kept dim so they don't draw the eye.
    ctx.fillStyle = 'rgba(255, 230, 150, 0.35)';
    ctx.beginPath();
    ctx.arc(0, 0, 4, 0, Math.PI * 2);
    ctx.fill();

    const tex = new THREE.CanvasTexture(c);
    tex.wrapS = tex.wrapT = THREE.RepeatWrapping;
    tex.repeat.set(160, 160); // tile 160x across the map
    tex.anisotropy = 4; // sharper at grazing angles
    return tex;
}

function makeStoneTexture() {
    // --- Seamless procedural stone texture ---
    // Builds up a believable rock face in layers: granular base → sedimentary
    // banding → mineral pockets → crack network. All in cool grey-blue tones
    // so the dim color tint applied later keeps it muted and receding.
    // 512×512 canvas, designed to tile seamlessly (noise wraps at edges by
    // drawing blobs that straddle the boundary on each side).
    const size = 512;
    const c = document.createElement('canvas');
    c.width = c.height = size;
    const ctx = c.getContext('2d');

    // --- Helper: tile-safe random blob (straddles edges so it wraps) ---
    // Without this, every noise blob that crosses the right/bottom edge
    // would leave a hard seam. We draw it 4 times: original + 3 wrapped
    // copies so the texture tiles seamlessly in all directions.
    function tileSafeBlob(drawBlob) {
        drawBlob(0, 0);
        drawBlob(-size, 0); drawBlob(size, 0);
        drawBlob(0, -size); drawBlob(0, size);
        drawBlob(-size, -size); drawBlob(size, -size);
        drawBlob(-size, size); drawBlob(size, size);
    }

    // 1) Base color: layered diagonal gradient in cool slate tones
    const base = ctx.createLinearGradient(0, 0, size, size);
    base.addColorStop(0, '#6c7682');
    base.addColorStop(0.5, '#7a8492');
    base.addColorStop(1, '#5e6975');
    ctx.fillStyle = base;
    ctx.fillRect(0, 0, size, size);

    // 2) Granular mineral speckle — tiny dots across the whole surface
    // to give the stone visible "grain" up close.
    for (let i = 0; i < 4000; i++) {
        const x = Math.random() * size;
        const y = Math.random() * size;
        const r = 0.5 + Math.random() * 1.5;
        const v = Math.random();
        // Mix of darker (mineral) and lighter (quartz) grains
        if (v > 0.6) {
            ctx.fillStyle = `rgba(40, 48, 58, ${0.2 + Math.random() * 0.3})`;
        } else if (v > 0.3) {
            ctx.fillStyle = `rgba(160, 170, 182, ${0.15 + Math.random() * 0.25})`;
        } else {
            ctx.fillStyle = `rgba(95, 105, 118, ${0.2 + Math.random() * 0.3})`;
        }
        ctx.beginPath();
        ctx.arc(x, y, r, 0, Math.PI * 2);
        ctx.fill();
    }

    // 3) Sedimentary banding — subtle horizontal color shifts that suggest
    // layered rock. Drawn as semi-transparent horizontal stripes with
    // irregular wavy edges so they don't look mechanical.
    for (let band = 0; band < 8; band++) {
        const y = (band / 8) * size + (Math.random() - 0.5) * 30;
        const h = 15 + Math.random() * 35;
        const dark = Math.random() > 0.5;
        ctx.fillStyle = dark
            ? `rgba(45, 55, 65, ${0.10 + Math.random() * 0.10})`
            : `rgba(150, 160, 172, ${0.06 + Math.random() * 0.08})`;
        ctx.beginPath();
        ctx.moveTo(0, y);
        // Wavy top edge
        for (let x = 0; x <= size; x += 16) {
            ctx.lineTo(x, y + Math.sin(x * 0.05 + band) * 4 + (Math.random() - 0.5) * 3);
        }
        ctx.lineTo(size, y + h);
        for (let x = size; x >= 0; x -= 16) {
            ctx.lineTo(x, y + h + Math.sin(x * 0.05 + band + 1) * 4 + (Math.random() - 0.5) * 3);
        }
        ctx.closePath();
        ctx.fill();
    }

    // 4) Mineral pockets — larger blobs where the stone has a different
    // composition (think quartz veins or iron deposits). Drawn with soft
    // radial gradients and tile-safe so they wrap across edges.
    for (let i = 0; i < 18; i++) {
        const cx = Math.random() * size;
        const cy = Math.random() * size;
        const r = 12 + Math.random() * 28;
        const light = Math.random() > 0.5;
        tileSafeBlob((ox, oy) => {
            const x = cx + ox, y = cy + oy;
            const g = ctx.createRadialGradient(x, y, 0, x, y, r);
            if (light) {
                g.addColorStop(0, 'rgba(180, 188, 198, 0.35)');
                g.addColorStop(1, 'rgba(180, 188, 198, 0)');
            } else {
                g.addColorStop(0, 'rgba(35, 42, 52, 0.40)');
                g.addColorStop(1, 'rgba(35, 42, 52, 0)');
            }
            ctx.fillStyle = g;
            ctx.beginPath();
            ctx.arc(x, y, r, 0, Math.PI * 2);
            ctx.fill();
        });
    }

    // 5) Crack network — branching jagged lines that look like real stone
    // fractures. Tile-safe by wrapping any crack that exits one edge to
    // enter from the opposite edge.
    function drawCrack(startX, startY, dirX, dirY, length, depth) {
        ctx.strokeStyle = `rgba(20, 25, 32, ${0.35 + depth * 0.15})`;
        ctx.lineWidth = 0.8 + depth * 0.6;
        ctx.beginPath();
        let x = startX, y = startY;
        ctx.moveTo(x, y);
        const segments = Math.floor(length / 6);
        for (let s = 0; s < segments; s++) {
            // Step forward with random jitter, occasionally branching
            x += dirX * 6 + (Math.random() - 0.5) * 4;
            y += dirY * 6 + (Math.random() - 0.5) * 4;
            // Wrap so the crack tiles seamlessly
            x = ((x % size) + size) % size;
            y = ((y % size) + size) % size;
            ctx.lineTo(x, y);
            // Occasional branch
            if (depth < 2 && Math.random() < 0.12) {
                const branchAngle = Math.atan2(dirY, dirX) + (Math.random() - 0.5) * 1.5;
                drawCrack(x, y, Math.cos(branchAngle), Math.sin(branchAngle), length * 0.5, depth + 1);
            }
        }
        ctx.stroke();
    }

    for (let i = 0; i < 10; i++) {
        const angle = Math.random() * Math.PI * 2;
        drawCrack(
            Math.random() * size,
            Math.random() * size,
            Math.cos(angle), Math.sin(angle),
            80 + Math.random() * 120,
            0
        );
    }

    // 6) Subtle border for edge definition (very dim so the surface
    // doesn't pop visually against the grass).
    ctx.strokeStyle = 'rgba(20, 28, 38, 0.18)';
    ctx.lineWidth = 1;
    ctx.strokeRect(0, 0, size, size);

    const tex = new THREE.CanvasTexture(c);
    tex.wrapS = tex.wrapT = THREE.RepeatWrapping;
    return tex;
}

// =====================================================================
// TEXTURE SETUP
// Ground: loaded from CDN (three.js r160 grasslight-big.jpg — a real
// seamless photo-based grass texture). Procedural canvas grass with the
// altitude grid is used as instant fallback while the CDN loads.
// Obstacles: procedural canvas STONE texture (no CDN — every rock/stone
// asset I tried on the three.js CDN 404s, and the moon texture doesn't
// tile). The procedural stone is built in layers: granular base →
// sedimentary banding → mineral pockets → branching crack network, with
// tile-safe wrapping so it tiles seamlessly. Dim color tint applied
// later keeps the surface muted so red cubes pop.
// =====================================================================

// --- Helper: configure a texture for perfect seamless tiling ---
// NOTE: Three.js r128 is in use here, so we use the old color-encoding
// API (tex.encoding = THREE.sRGBEncoding) instead of the new r152+
// colorSpace API. Behavior is equivalent for color (albedo) textures.
function configureTiledTexture(tex, repeatX, repeatY, aniso = 8) {
    tex.wrapS = tex.wrapT = THREE.RepeatWrapping;
    tex.repeat.set(repeatX, repeatY);
    tex.anisotropy = aniso;
    tex.generateMipmaps = true;
    tex.minFilter = THREE.LinearMipmapLinearFilter; // trilinear filtering = smooth at distance
    tex.magFilter = THREE.LinearFilter;
    if ('encoding' in tex) tex.encoding = THREE.sRGBEncoding; // r128 API
    tex.needsUpdate = true;
    return tex;
}

// Procedural textures used immediately + as fallback if CDN grass fails.
const grassTex = makeGrassTexture();
const stoneTex = makeStoneTexture();
// `realRockTex` is null because we use the procedural stone for obstacles.
// Kept as a let so makeBox's source-texture lookup stays consistent.
let realRockTex = null;

// --- Realistic seamless grass texture (CC0, from three.js examples) ---
// grasslight-big.jpg is a real photo-based seamless grass texture.
const grassCDN = new THREE.TextureLoader();
grassCDN.setCrossOrigin('anonymous');
grassCDN.load(
    'https://cdn.jsdelivr.net/gh/mrdoob/three.js@r160/examples/textures/terrain/grasslight-big.jpg',
    (tex) => {
        // 2000-unit map / 16-unit tile = 125 repeats across
        configureTiledTexture(tex, TUNING.grassTileRepeat, TUNING.grassTileRepeat, 8);
        groundMat.map = tex;
        groundMat.color.setHex(TUNING.groundTint); // keep the dim olive tint
        groundMat.needsUpdate = true;
        grassTex.dispose();
    },
    undefined,
    () => console.warn('Grass CDN load failed — using procedural fallback.')
);

// Ground material: dark greenish-brown tint multiplies the grass texture so
// it recedes into the background instead of competing with cubes/obstacles.
const groundMat = new THREE.MeshLambertMaterial({ map: grassTex, color: TUNING.groundTint });
const ground = new THREE.Mesh(new THREE.PlaneGeometry(MAP_SIZE, MAP_SIZE), groundMat);
ground.rotation.x = -Math.PI/2;
ground.matrixAutoUpdate = false;
ground.updateMatrix();
ground.receiveShadow = true;
scene.add(ground);

function makeBox(w, h, d, x, y, z, color=0x7a96b0, name='') {
    const geo = new THREE.BoxGeometry(w, h, d);
    // Per-mesh tiling: scale the texture so each face shows it at roughly
    // the same world-space density (1 tile per ~tileWorldSize units). For
    // a BoxGeometry, UVs are 0..1 per face, so repeat = face_size_in_units / tile_size.
    const tileWorldSize = TUNING.obstacleTileWorldSize;
    const repX = Math.max(1, Math.round(w / tileWorldSize));
    const repY = Math.max(1, Math.round(h / tileWorldSize));
    const repZ = Math.max(1, Math.round(d / tileWorldSize));
    // Box faces: +X/-X use (d, h); +Y/-Y use (w, d); +Z/-Z use (w, h).
    // We pick the largest repeat as a compromise — proper per-face UV would
    // require custom geometry, but this looks fine for boxes.
    const rep = Math.max(repX, repY, repZ);
    // Clone the source texture so each box can have its own repeat.
    // Use the CDN rock texture if loaded, else fall back to procedural stone.
    const srcTex = realRockTex || stoneTex;
    const texClone = srcTex.clone();
    texClone.wrapS = texClone.wrapT = THREE.RepeatWrapping;
    texClone.repeat.set(rep, rep);
    texClone.generateMipmaps = true;
    texClone.minFilter = THREE.LinearMipmapLinearFilter;
    texClone.magFilter = THREE.LinearFilter;
    if ('encoding' in texClone) texClone.encoding = THREE.sRGBEncoding; // r128 API
    texClone.anisotropy = TUNING.obstacleTextureAniso;
    texClone.needsUpdate = true;
    // --- TINT: dim the texture so it doesn't compete with red cubes ---
    // Multiply the stone texture by a dark muted grey-blue. The texture
    // detail is still visible but the surface recedes into the background.
    const dimColor = TUNING.obstacleTint;
    const mat = new THREE.MeshPhongMaterial({ map: texClone, color: dimColor, emissive: 0x000000 });
    const mesh = new THREE.Mesh(geo, mat);
    mesh.position.set(x, y + h/2, z);
    mesh.matrixAutoUpdate = false;
    mesh.updateMatrix();
    mesh.userData.name = name;
    scene.add(mesh);
    obstacles.push(mesh);
    return mesh;
}

