    beaconGroup.updateMatrix();

    const coreMat = new THREE.MeshPhongMaterial({
        color: 0xffffff, emissive: 0xffff00, emissiveIntensity: 3.0, // White core, yellow glow
        transparent: true, opacity: 0.7, fog: false
    });
    const core = new THREE.Mesh(beaconCoreGeo, coreMat);
    core.position.y = 250;
    beaconGroup.add(core);

    const glowMat = new THREE.MeshPhongMaterial({
        color: 0xe3d356, emissive: 0xe3d356, emissiveIntensity: 3.5, fog: false,
        transparent: true, opacity: 0.2, side: THREE.BackSide // Darker yellow glow, more transparent
    }); //
    const glow = new THREE.Mesh(beaconGlowGeo, glowMat);
    glow.position.y = 250;
    beaconGroup.add(glow);

    const rings = [];
    // reduce rings from 5 to 2 for performance; collect descriptors for instancing
    [8, 25].forEach(h => {
        const phase = Math.random() * Math.PI * 2;
        ringDescriptors.push({ bx: pos[0], bz: pos[2], baseY: h, phase });
        // keep placeholder entry for legacy array structure
        rings.push(null);
    });

    scene.add(beaconGroup);
    beacons.push(beaconGroup);
    beaconRings.push(rings);
    beaconMats.push({ core: coreMat, glow: glowMat });
});

// create instanced mesh for rings once descriptors are collected
if (ringDescriptors.length > 0) {
    const totalRings = ringDescriptors.length;
    const ringMatCommon = new THREE.MeshPhongMaterial({ color: 0xffffff, emissive: 0xffff00, emissiveIntensity: 2.0, transparent: true, opacity: 0.4, fog: false });
    ringInstanced = new THREE.InstancedMesh(beaconRingGeo, ringMatCommon, totalRings);
    ringInstanced.instanceMatrix.setUsage(THREE.DynamicDrawUsage);
    // set initial matrices
    for (let ri = 0; ri < totalRings; ri++) {
        const rd = ringDescriptors[ri];
        ringDummy.position.set(rd.bx, rd.baseY, rd.bz);
        ringDummy.rotation.x = Math.PI / 2;
        ringDummy.scale.setScalar(1);
        ringDummy.updateMatrix();
        ringInstanced.setMatrixAt(ri, ringDummy.matrix);
    }
    ringInstanced.instanceMatrix.needsUpdate = true;
    scene.add(ringInstanced);
}

// ===================== MONSTER BEACONS =====================
// Red beacons that follow each monster so the player can track them.
// Visually DISTINCT from the yellow cube beacons:
//   Yellow beacons = straight vertical cylinder beam + floating rings going UP
//   Red monster beacons = inverted cone pointing DOWN + pulsing ground rings
//                         expanding outward (sonar-ping style)
// The cone hangs above the monster like a targeting reticle; the ground
// rings radiate outward from the monster's feet and fade — pulsing
// continuously to signal "threat is HERE and moving".

const monsterBeacons = []; // { cone, coneMat, rings: [{mesh, mat, phase}], group }
const MONSTER_BEACON_RING_COUNT = 2; // staggered sonar pings
const MONSTER_BEACON_RING_MAX_SCALE = 18; // how far the ping expands
const MONSTER_BEACON_RING_CYCLE = 2.0; // seconds for one ping to complete

// Shared geometries (reused across all monster beacons for performance).
const monsterBeaconConeGeo = new THREE.ConeGeometry(2.5, 60, 6); // tall thin cone
// Ring geometry is reused from beaconRingGeo (TorusGeometry) but at a
// different scale/animation than the yellow beacon rings.

function createMonsterBeacon() {
    const group = new THREE.Group();

    // --- INVERTED CONE pointing down at the monster ---
    // Hangs high above the monster, point aimed at the ground. Red
    // emissive, semi-transparent, flickers like a warning signal.
    const coneMat = new THREE.MeshBasicMaterial({
        color: 0xff0000,
        transparent: true,
        opacity: 0.25,
        fog: false,
        depthWrite: false,
        side: THREE.DoubleSide
    });
    const cone = new THREE.Mesh(monsterBeaconConeGeo, coneMat);
    cone.position.y = 50;           // high above the monster
    cone.rotation.x = Math.PI;       // flip so the point faces DOWN
    group.add(cone);

    // --- PULSING GROUND RINGS (sonar ping) ---
    // Flat torus rings on the ground that expand outward and fade, then
    // reset — continuous radar-like ping. Two rings staggered so there's
    // always one mid-expansion.
    const rings = [];
    for (let i = 0; i < MONSTER_BEACON_RING_COUNT; i++) {
        const ringMat = new THREE.MeshBasicMaterial({
            color: 0xff0000,
            transparent: true,
            opacity: 0,
            fog: false,
            depthWrite: false,
            side: THREE.DoubleSide
        });
        const ring = new THREE.Mesh(beaconRingGeo, ringMat);
        ring.rotation.x = Math.PI / 2; // lay flat on the ground
        ring.position.y = 0.5;         // just above the floor
        group.add(ring);
        rings.push({
            mesh: ring,
            mat: ringMat,
            phase: (i / MONSTER_BEACON_RING_COUNT) * MONSTER_BEACON_RING_CYCLE // stagger
        });
    }

    group.visible = false; // hidden until monsters activate
    scene.add(group);
    const beacon = { group, cone, coneMat, rings };
    monsterBeacons.push(beacon);
    return beacon;
}

// Update all monster beacons each frame: follow the monster, animate the
// sonar ping rings, flicker the cone. Called from the main animate loop.
function updateMonsterBeacons(dt) {
    const tNow = performance.now() * 0.001;
    for (let i = 0; i < monsterBeacons.length; i++) {
        const mb = monsterBeacons[i];
        const m = monsters[i];
        if (!m) { mb.group.visible = false; continue; }
        // Beacon visible only when the monster itself is visible (i.e.
        // monster threshold reached + not stunned-invisible).
        mb.group.visible = m.visible;

        if (!m.visible) continue;

        // Follow the monster's XZ position.
        mb.group.position.x = m.position.x;
        mb.group.position.z = m.position.z;

        // Cone flicker — irregular warning pulse, intensifies with rage/speed.
        const rage = m.userData.rage || 0;
        const speed = m.userData.currentSpeed || 0;
        const threat = Math.max(rage, Math.min(1, speed / 12));
        const flickerBase = 0.2 + threat * 0.25;
        const flickerNoise = (Math.sin(tNow * 13) * 0.5 + 0.5) * 0.15;
        mb.coneMat.opacity = flickerBase + flickerNoise;

        // Sonar ping rings — expand outward and fade, then reset.
        for (let r = 0; r < mb.rings.length; r++) {
            const ring = mb.rings[r];
            ring.phase += dt;
            if (ring.phase >= MONSTER_BEACON_RING_CYCLE) {
                ring.phase -= MONSTER_BEACON_RING_CYCLE;
            }
            const progress = ring.phase / MONSTER_BEACON_RING_CYCLE; // 0..1
            const scale = 0.5 + progress * MONSTER_BEACON_RING_MAX_SCALE;
            ring.mesh.scale.set(scale, scale, scale);
            // Bright at the start, fades to zero by mid-cycle.
            ring.mat.opacity = (1 - progress) * 0.6;
        }
    }
}

