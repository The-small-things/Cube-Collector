        case 'invincibility':
            row = document.getElementById('cp-toggle-inv');
            statusEl = document.getElementById('cp-inv-status');
            active = godModeEnabled;
            break;
        case 'flashlight':
            row = document.getElementById('cp-toggle-light');
            statusEl = document.getElementById('cp-light-status');
            active = flashlight ? flashlight.visible : false;
            break;
    }
    if (row) row.classList.toggle('active', active);
    if (statusEl) statusEl.textContent = active ? 'ON' : 'OFF';
}

function syncSandboxToggles() {
    updateSandboxToggleUI('fly');
    updateSandboxToggleUI('invincibility');
    updateSandboxToggleUI('flashlight');
}
window.syncSandboxToggles = syncSandboxToggles;

function sandboxSetTimeScale(v) {
    sandboxTimeScaleMult = parseFloat(v);
    const valEl = document.getElementById('sandbox-timeScale-val');
    if (valEl) valEl.textContent = sandboxTimeScaleMult.toFixed(2) + 'x';
    // The animate loop reads `timeScale` directly — we override it via a hook
}
window.sandboxSetTimeScale = sandboxSetTimeScale;

function sandboxSetGravity(v) {
    sandboxGravityMult = parseFloat(v);
    const valEl = document.getElementById('sandbox-gravity-val');
    if (valEl) valEl.textContent = sandboxGravityMult.toFixed(2) + 'x';
    TUNING.gravity = 40.0 * sandboxGravityMult;
    TUNING.wallGravity = 3.5 * sandboxGravityMult;
}
window.sandboxSetGravity = sandboxSetGravity;

function sandboxSetSpeed(v) {
    sandboxSpeedMult = parseFloat(v);
    const valEl = document.getElementById('sandbox-speed-val');
    if (valEl) valEl.textContent = sandboxSpeedMult.toFixed(2) + 'x';
    TUNING.moveSpeed = 10.0 * sandboxSpeedMult;
    TUNING.sprintMult = 2.7 * sandboxSpeedMult;
}
window.sandboxSetSpeed = sandboxSetSpeed;

// --- Hook the animate loop's timeScale to apply sandboxTimeScaleMult ---
// We do this by intercepting the global timeScale variable. The animate loop
// reads `timeScale` directly, so we update it before each frame.
// Approach: hook requestAnimationFrame.
const _origRequestAnimationFrame = window.requestAnimationFrame;
let _sandboxHookInstalled = false;
function installSandboxHook() {
    if (_sandboxHookInstalled) return;
    _sandboxHookInstalled = true;
    // We can't easily intercept rAF without breaking the loop. Instead, we
    // update timeScale each frame via a lightweight interval.
    setInterval(() => {
        if (gameMode === 'sandbox' && typeof timeScale !== 'undefined') {
            timeScale = sandboxTimeScaleMult;
        }
    }, 50);
}

// --- Key handler for P (toggle sandbox panel) ---
const _origKeydown = document.onkeydown;
document.addEventListener('keydown', (e) => {
    if (e.code === 'KeyP' && !e.repeat && gameMode === 'sandbox' && gameStarted && !gameEnded) {
        // Don't trigger when typing in an input
        if (e.target && (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA')) return;
        e.preventDefault();
        toggleSandboxPanel();
    }
});

// --- Show sandbox hint when sandbox mode is active ---
function updateSandboxHintVisibility() {
    const hint = document.getElementById('sandbox-hint');
    if (!hint) return;
    if (gameMode === 'sandbox' && gameStarted && !gameEnded && !sandboxPanelOpen) {
        hint.style.display = 'block';
    } else {
        hint.style.display = 'none';
    }
}

// Hook selectMode + gameStarted to update hint
const _origSelectMode2 = selectMode;
selectMode = function(e, mode) {
    _origSelectMode2(e, mode);
    updateSandboxHintVisibility();
};
window.selectMode = selectMode;

// --- Initialize sandbox systems on script load ---
// Snapshot original TUNING values so we can reset to them later
originalTuningSnapshot = JSON.parse(JSON.stringify(TUNING));
// Load any saved overrides
loadTuningOverrides();
// Install the sandbox timeScale hook
installSandboxHook();
// Initial UI state
updateTuningTabState();

