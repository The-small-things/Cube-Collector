function updateCurse() {
    // v2.0: Zen mode = no curse build-up at all
    if (gameMode === 'zen') {
        curseFactor = 0;
    } else if (gameMode === 'survival') {
        // In survival mode the world starts already 'cursed' (thicker fog).
        // Preserve a baseline curse so temporary visual resets (like the
        // impact-frame flat style) don't drop fog to zero when cubesCollected
        // is low. Use the configured survival start value as a minimum.
        const SURVIVAL_BASE = 0.7; // matches quickRestart/start baseline
        curseFactor = Math.max(cubesCollected / 20, SURVIVAL_BASE);
    } else {
        curseFactor = cubesCollected / 20;
    }

    // Skip all scene-color tweaks while an impact-frame's flat 2D look is
    // active — it owns these properties for its short lifespan and restores
    // them itself; fighting it here would un-flatten the hit mid-flash.
    if (!impactFlatModeActive) {
    // Sky color lerps from skyColorStart (bright blue) → skyColorEnd (dark red)
    // based on curseFactor. Brightness mult lightens both endpoints.
    const skyStartR = ((TUNING.skyColorStart >> 16) & 0xff) / 255;
    const skyStartG = ((TUNING.skyColorStart >> 8) & 0xff) / 255;
    const skyStartB = (TUNING.skyColorStart & 0xff) / 255;
    const skyEndR = ((TUNING.skyColorEnd >> 16) & 0xff) / 255;
    const skyEndG = ((TUNING.skyColorEnd >> 8) & 0xff) / 255;
    const skyEndB = (TUNING.skyColorEnd & 0xff) / 255;
    const skyR = Math.min(1, THREE.MathUtils.lerp(skyStartR, skyEndR, curseFactor) * TUNING.brightnessMult);
    const skyG = Math.min(1, THREE.MathUtils.lerp(skyStartG, skyEndG, curseFactor) * TUNING.brightnessMult);
    const skyB = Math.min(1, THREE.MathUtils.lerp(skyStartB, skyEndB, curseFactor) * TUNING.brightnessMult);
    scene.background.setRGB(skyR, skyG, skyB);
    const baseFogDensity = gameMode === 'survival' ? 0.0235 : TUNING.fogDensityBase;
    scene.fog.color.setRGB(skyR, skyG, skyB);
    scene.fog.density = (curseFactor <= 0.15) ? TUNING.fogDensityStart : baseFogDensity + curseFactor * TUNING.fogDensityPerCurse;

    const vigAlpha = curseFactor * 0.7;
    vignette.style.background = `radial-gradient(ellipse at center, transparent 40%, rgba(${Math.floor(180*curseFactor)},0,0,${vigAlpha}) 100%)`; // Increased red hue

    // Ambient light: lerps from white → red as curse builds, with intensity
    // ramping from ambientLightStart → ambientLightEnd. Brightness mult
    // scales the intensity up so the whole scene gets brighter.
    ambientLight.color.setRGB(
        THREE.MathUtils.lerp(1.0, 0.2, curseFactor),
        THREE.MathUtils.lerp(1.0, 0.0, curseFactor),
        THREE.MathUtils.lerp(1.0, 0.0, curseFactor)
    );
    ambientLight.intensity = THREE.MathUtils.lerp(TUNING.ambientLightStart, TUNING.ambientLightEnd, curseFactor) * TUNING.brightnessMult;
    sunLight.intensity = THREE.MathUtils.lerp(TUNING.sunLightStart, TUNING.sunLightEnd, curseFactor) * TUNING.brightnessMult;

    // Ground material color: lerps from the configured groundTint (dim olive
    // by default) → near-black as curse builds. Brightness mult scales up
    // the color so the ground gets brighter overall.
    const gtR = ((TUNING.groundTint >> 16) & 0xff) / 255;
    const gtG = ((TUNING.groundTint >> 8) & 0xff) / 255;
    const gtB = (TUNING.groundTint & 0xff) / 255;
    const groundR = Math.min(1, THREE.MathUtils.lerp(gtR, 0.1, curseFactor) * TUNING.brightnessMult);
    const groundG = Math.min(1, THREE.MathUtils.lerp(gtG, 0.0, curseFactor) * TUNING.brightnessMult);
    const groundB = Math.min(1, THREE.MathUtils.lerp(gtB, 0.0, curseFactor) * TUNING.brightnessMult);
    groundMat.color.setRGB(groundR, groundG, groundB);
    }

    if (audioCtx) {
    if (cubesCollected >= 5) {
        ui.style.color = `rgb(${Math.floor(THREE.MathUtils.lerp(0x35,0xff,curseFactor*2))},${Math.floor(THREE.MathUtils.lerp(0xfc,0x00,(curseFactor)*2))},${Math.floor(THREE.MathUtils.lerp(0x0d,0x00,curseFactor*2))})`;
    }
        if (audioDistortionEnabled && distortionNode) {
            distortionNode.curve = makeDistortionCurve(curseFactor * 200);
        } else if (distortionNode) {
            distortionNode.curve = makeDistortionCurve(0);
        }
        buildReverb(0.3 + curseFactor * 2.5);
        masterGain.gain.value = 1.0 + curseFactor * 0.4;
    }

    if (cubesCollected >= MONSTER_THRESHOLD && (gameMode === 'survival' || cubesCollected > 0)) {
        monsters.forEach(m => m.visible = true);
        playMonsterMusic();
    }

    if (curseFactor > 0.4 && !impactFlatModeActive) {
        const tBase = curseFactor - 0.4;
        for (let i = 0; i < obstacles.length; i++) {
            const obs = obstacles[i];
            // materials already have emissive set; change intensity only
            obs.material.emissiveIntensity = tBase * 0.08 * (Math.sin(gameTime + i)*0.5+0.5);
        }
    }
}

