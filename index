// Performance preset → renderer / quality parameters.
const PERF_PROFILES = {
    fast:   { pixelRatio: 0.6, fogSmooth: false, skydomeSegments: 8,  monsterAuraSegs: 6 },
    medium: { pixelRatio: 1.0, fogSmooth: true,  skydomeSegments: 16, monsterAuraSegs: 12 },
    high:   { pixelRatio: 1.5, fogSmooth: true,  skydomeSegments: 32, monsterAuraSegs: 16 }
};

function applyPerformancePreset() {
    if (typeof renderer === 'undefined' || !renderer) return;
    const profile = PERF_PROFILES[performancePreset] || PERF_PROFILES.medium;
    const dpr = Math.min(window.devicePixelRatio || 1, profile.pixelRatio);
    renderer.setPixelRatio(dpr);
    renderer.setSize(window.innerWidth, window.innerHeight, false);
    // Fog smoothing: on 'fast', snap fog color changes instead of lerping
    // (handled by other systems reading this flag).
    window._perfFogSmooth = profile.fogSmooth;
}

function setPerformance(level) {
    if (!['fast', 'medium', 'high'].includes(level)) return;
    performancePreset = level;
    applyPerformancePreset();
    updateAdvancedUI();
    saveKeybinds();
}

function setParticleEffects(level) {
    if (!['off', 'low', 'on'].includes(level)) return;
    particleEffectsLevel = level;
    // If turning fully off, clear any live sonic booms so they don't linger.
    if (level === 'off') {
        for (let i = sonicBooms.length - 1; i >= 0; i--) {
            scene.remove(sonicBooms[i]);
            sonicBooms.splice(i, 1);
        }
        for (let i = diveImpacts.length - 1; i >= 0; i--) {
            scene.remove(diveImpacts[i]);
            diveImpacts.splice(i, 1);
        }
    }
    updateAdvancedUI();
    saveKeybinds();
}

