const MIN_PLAUSIBLE_TIME = { classic: 15, timeattack: 15, survival: 0 };
const MAX_PLAUSIBLE_TIME = 7200; // 2 hours — generous ceiling, just guards against garbage values

function isTimePlausible(time) {
    if (!isFinite(time) || time < 0) return false;
    if (time > MAX_PLAUSIBLE_TIME) return false;
    if (time < (MIN_PLAUSIBLE_TIME[gameMode] ?? 0)) return false;
    return true;
}

async function submitScore(time) {
    if (runTainted) return 'tainted';
    if (!isTimePlausible(time)) return 'implausible';

    if (!playerName) {
        let name = prompt('New leaderboard entry — enter your name:', 'PLAYER') || 'PLAYER';
        playerName = name.slice(0, 16);
        localStorage.setItem('redCubeName', playerName);
    }
    const key = leaderboardKey(gameMode, difficulty);
    try {
        let entries = await lbGet(key);
        entries.push({ name: playerName, time });
        const ascending = gameMode !== 'survival'; // lower time is better, except survival (longer is better)
        entries.sort((a, b) => ascending ? a.time - b.time : b.time - a.time);
        entries = entries.slice(0, 10);
        await lbSet(key, entries);
        return entries;
    } catch (e) {
        console.warn('Leaderboard submit failed', e);
        return null;
    }
}

