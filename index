// --- Sandbox action dispatcher ---
function sandboxAction(action) {
    if (gameMode !== 'sandbox') return;
    switch (action) {
        case 'toggleFly':
            isFlying = !isFlying;
            showSubtitle('* FLY: ' + (isFlying ? 'ON' : 'OFF') + ' *', 1.0);
            break;
        case 'toggleInvincibility':
            godModeEnabled = !godModeEnabled;
            // Invincibility only — no forced flying
            if (godModeEnabled) taintRun('invincibility enabled');
            showSubtitle('* INVINCIBILITY: ' + (godModeEnabled ? 'ON' : 'OFF') + ' *', 1.0);
            break;
        case 'teleportSpawn':
            player.position.set(0, TUNING.spawnY, 0);
            velocity.set(0, 0, 0);
            showSubtitle('* TELEPORTED TO SPAWN *', 1.0);
            break;
        case 'resetVelocity':
            velocity.set(0, 0, 0);
            showSubtitle('* VELOCITY RESET *', 1.0);
            break;
        case 'heal':
            isJumpscareActive = false;
            isSliding = false;
            isWallRunning = false;
            isPowerDiving = false;
            curseFactor = 0;
            updateCurse();
            showSubtitle('* STATE CLEARED *', 1.0);
            break;
        case 'refillAbilities':
            abilityCooldownTimer = 0;
            powerDiveCooldownTimer = 0;
            timeSlowCooldownTimer = 0;
            showSubtitle('* ABILITIES REFILLED *', 1.0);
            break;
        case 'collectAll':
            cubes.forEach((c, i) => {
                if (!c.userData.collected) {
                    c.userData.collected = true;
                    c.visible = false;
                    if (beacons[i]) beacons[i].visible = false;
                    cubesCollected++;
                    runStats.cubesCollected = cubesCollected;
                }
            });
            updateCurse();
            showSubtitle('* ALL CUBES COLLECTED *', 1.0);
            break;
        case 'uncollectAll':
            cubes.forEach((c, i) => {
                c.userData.collected = false;
                c.visible = true;
                if (beacons[i]) beacons[i].visible = true;
            });
            cubesCollected = 0;
            runStats.cubesCollected = 0;
            updateCurse();
            showSubtitle('* ALL CUBES RESET *', 1.0);
            break;
        case 'add5cubes':
            for (let i = 0; i < 5 && i < cubes.length; i++) {
                const c = cubes[i];
                if (!c.userData.collected) {
                    c.userData.collected = true;
                    c.visible = false;
                    if (beacons[i]) beacons[i].visible = false;
                    cubesCollected++;
                }
            }
            runStats.cubesCollected = cubesCollected;
            updateCurse();
            showSubtitle('* +5 CUBES *', 1.0);
            break;
        case 'resetCubes':
            cubes.forEach((c, i) => {
                c.userData.collected = false;
                c.visible = true;
                if (beacons[i]) beacons[i].visible = true;
            });
            cubesCollected = 0;
            runStats.cubesCollected = 0;
            updateCurse();
            showSubtitle('* CUBES RESET TO 0 *', 1.0);
            break;
        case 'spawnStalker':
            try { createStalker(); monsters[monsters.length-1].visible = true; showSubtitle('* STALKER SPAWNED *', 1.0); } catch (e) { console.warn(e); }
            break;
        case 'spawnHound':
            try { createHound(); monsters[monsters.length-1].visible = true; showSubtitle('* HOUND SPAWNED *', 1.0); } catch (e) { console.warn(e); }
            break;
        case 'spawnPhantom':
            try { createPhantom(); monsters[monsters.length-1].visible = true; showSubtitle('* PHANTOM SPAWNED *', 1.0); } catch (e) { console.warn(e); }
            break;
        case 'awakenMonsters':
            monsters.forEach(m => { m.visible = true; });
            MONSTER_THRESHOLD = 0;
            showSubtitle('* ALL MONSTERS AWAKENED *', 1.0);
            break;
        case 'stunAll':
            monsters.forEach(m => { m.userData.stunTimer = 5; });
            showSubtitle('* ALL MONSTERS STUNNED 5s *', 1.0);
            break;
        case 'killAll':
            // Remove all monsters from scene
            monsters.forEach(m => {
                if (m.userData.telegraphMesh) scene.remove(m.userData.telegraphMesh);
                scene.remove(m);
            });
            monsters.length = 0;
            monsterBeacons.forEach(mb => { if (mb.group) scene.remove(mb.group); });
            monsterBeacons.length = 0;
            showSubtitle('* ALL MONSTERS KILLED *', 1.0);
            break;
        case 'teleportMonstersAway':
            monsters.forEach(m => {
                const ang = Math.random() * Math.PI * 2;
                const dist = 600;
                m.position.set(player.position.x + Math.cos(ang) * dist, 0, player.position.z + Math.sin(ang) * dist);
            });
            showSubtitle('* MONSTERS TELEPORTED AWAY *', 1.0);
            break;
        case 'resetMonsters':
            monsters.forEach(m => {
                const ang = Math.random() * Math.PI * 2;
                m.position.set(Math.cos(ang) * 200, 0, Math.sin(ang) * 200);
                m.visible = false;
                m.userData.stunTimer = 0;
                if (m.userData.rage) m.userData.rage = 0;
                if (m.userData.aiState) m.userData.aiState = 'wander';
                if (m.userData.kind === 'phantom') resetPhantomState(m);
            });
            MONSTER_THRESHOLD = 9999;
            showSubtitle('* MONSTERS RESET *', 1.0);
            break;
        case 'toggleFlashlight':
            if (flashlight) {
                flashlight.visible = !flashlight.visible;
                showSubtitle('* FLASHLIGHT: ' + (flashlight.visible ? 'ON' : 'OFF') + ' *', 1.0);
            } else {
                enableFlashlight();
                showSubtitle('* FLASHLIGHT ENABLED *', 1.0);
            }
            break;
        case 'clearFog':
            if (scene.fog) scene.fog.density = 0;
            showSubtitle('* FOG CLEARED *', 1.0);
            break;
        case 'curseMax':
            curseFactor = 1;
            updateCurse();
            showSubtitle('* CURSE MAX *', 1.0);
            break;
        case 'curseZero':
            curseFactor = 0;
            updateCurse();
            showSubtitle('* CURSE ZERO *', 1.0);
            break;
        case 'spawnPowerup':
            // Spawn a single powerup at player position
            try {
                const type = POWERUP_TYPES[Math.floor(Math.random() * POWERUP_TYPES.length)];
                const color = POWERUP_COLORS[type];
                const geo = new THREE.IcosahedronGeometry(1.2, 0);
                const mat = new THREE.MeshPhongMaterial({ color, emissive: color, emissiveIntensity: 0.8, transparent: true, opacity: 0.85, shininess: 100 });
                const mesh = new THREE.Mesh(geo, mat);
                const fwd = new THREE.Vector3(0, 0, -1).applyAxisAngle(Y_AXIS, yaw);
                mesh.position.set(player.position.x + fwd.x * 8, player.position.y, player.position.z + fwd.z * 8);
                mesh.userData = { type, shell: null, spinPhase: 0 };
                scene.add(mesh);
                powerups.push({ mesh, type, respawnTimer: 0, active: true });
                showSubtitle('* POWERUP SPAWNED *', 1.0);
            } catch (e) { console.warn(e); }
            break;
        case 'nightTime':
            if (ambientLight) ambientLight.intensity = 0.1;
            if (sunLight) sunLight.intensity = 0.1;
            if (skyDome && skyDome.material) skyDome.material.color.setHex(0x0a0a1a);
            if (scene.fog) scene.fog.density = 0.02;
            showSubtitle('* NIGHT TIME *', 1.0);
            break;
        case 'quickRestart':
            toggleSandboxPanel(); // close panel first
            quickRestart();
            break;
        case 'endGame':
            toggleSandboxPanel();
            endGame('win');
            break;
        case 'openSettings':
            openSettings();
            break;
    }
}
window.sandboxAction = sandboxAction;

