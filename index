function quickRestart() {
    // Save current settings — these are the ONLY things preserved across
    // a quick restart. Everything else (player state, curse, fog, music,
    // impact frames, pending timers, etc.) is reset to a fresh-run state.
    const currentMode = gameMode;
    const currentDiff = difficulty;

    // --- CRITICAL: request pointer lock IMMEDIATELY, before anything else ---
    // Browsers only honor requestPointerLock() when called inside a user
    // gesture (the click on the QUICK RESTART button). If we do any other
    // work first — especially async-style synchronous DOM mutations that
    // hide the pause menu — some browsers consider the gesture "consumed"
    // and silently reject the pointer lock request. The result: the game
    // thinks isLocked=true (because we force it below) but the cursor is
    // actually still free, so the player can't look around.
    // Calling it first thing guarantees we're still in the gesture window.
    try { document.body.requestPointerLock(); } catch (e) { /* may throw if not user-activated */ }

    // --- CRITICAL: invalidate all pending run-scoped timers FIRST ---
    // This drops any stale setTimeout callbacks (endGame, jumpscare
    // recovery, beat-drop updateCurse, curse messages, mach flash, etc.)
    // that were scheduled by the previous run. Without this, a stale
    // endGame timer firing 1.5s after a restart would set gameEnded=true
    // and freeze the new run.
    currentRunId++;
    clearTrackedTimeouts();

    // --- Reset any persistent on-screen text that may have been left visible ---
    // showCurseMsg / showSubtitle schedule their hide via runScopedTimeout, which
    // is dropped when currentRunId increments above. Without this the red curse
    // message (and subtitle) stay on screen at opacity 1 for the entire new run.
    if (curseMsg) { curseMsg.classList.remove('visible', 'fadeout'); }
    if (v2UI && v2UI.subtitles) v2UI.subtitles.classList.remove('show');

    // --- CRITICAL: clear impact-frame state ---
    // If quickRestart is called during an impact frame (e.g. player collects
    // a cube then immediately presses R / clicks quick restart), the
    // impactFlatModeActive flag stays true and _flatModeSnapshot stays
    // non-null. The FOV lerp, camera bob, and wall-run tilt are all gated
    // on !impactFlatModeActive, so the game appears frozen even though
    // the animate loop is still running. Force-clearing these unfreezes
    // the camera systems immediately.
    if (impactFlatModeActive) {
        // Restore the snapshot if it exists so scene/material state isn't
        // left in the flat-mode configuration (white background, lights off).
        try { setFlatImpactStyle(false); } catch (e) { /* ignore */ }
    }
    impactFlatModeActive = false;
    _flatModeSnapshot = null;
    _fovWasFrozen = false;
    impactFrameHitstopUntil = 0;
    if (impactFrameEl) {
        impactFrameEl.classList.remove('firing');
        clearTimeout(impactFrameEl._hideTimer);
    }
    if (window._impactFlatTimer) {
        clearTimeout(window._impactFlatTimer);
        window._impactFlatTimer = null;
    }
    // Clear any pending impact-shake on the canvas
    if (renderer && renderer.domElement) {
        renderer.domElement.classList.remove('impact-shake');
        clearTimeout(renderer.domElement._shakeTimer);
    }

    // Reset player position and state
    player.position.set(0, TUNING.spawnY, 0); // On top of 1.5-tall start platform (eye = 1.5+1.8+0.5)
    velocity.set(0, 0, 0);
    isSliding = false;
    slideCooldownTimer = 0;
    isWallRunning = false;
    yaw = 0;
    pitch = 0;
    camera.rotation.set(0, 0, 0);
    player.rotation.y = 0;
    camera.position.set(0, 0, 0);

    // Reset player state
    isGrounded = true;
    wasGroundedLastFrame = true;
    canDoubleJump = false;
    isSlideJump = false;
    coyoteTimer = 0;
    jumpBufferTimer = 0;
    cubeBoostTimer = 0;
    currentPlayerHeight = playerHeight;
    currentSprintMultiplier = 1.0;
    isFlying = false;
    preservedSlideSpeed = 0;

    // Reset game progress
    cubesCollected = 0;
    curseFactor = 0; // reset to 0 here; updateCurse() below will set the
                     // correct starting curse for the mode (0 for non-survival,
                     // 0.7 for survival) and apply the matching fog.
    gameTime = 0;
    realTime = 0;
    gameEnded = false;
    isJumpscareActive = false;

    // v2.0: reset all v2.0 systems state (combo, stamina, time slow, power-ups, stats)
    resetV2State();
    applyZenModeVisuals();

    // v2.1: sandbox mode re-init after restart
    if (gameMode === 'sandbox') {
        taintRun('sandbox mode — no leaderboard');
        if (!originalTuningSnapshot) originalTuningSnapshot = JSON.parse(JSON.stringify(TUNING));
        loadTuningOverrides();
    }
    updateTuningTabState();
    updateSandboxHintVisibility();

    // Reset music / beat-drop timers (prevents immediate re-trigger of
    // the beat-drop impact frame that would re-freeze the camera).
    beatDropTriggered = false;
    musicStartTime = 0;
    if (monsterMusicSource) {
        try { monsterMusicSource.stop(); } catch (e) { /* already stopped */ }
        monsterMusicSource = null;
    }

    // Reset audio distortion (cleared when curseFactor goes back to 0)
    if (distortionNode) distortionNode.curve = makeDistortionCurve(0);

    // Reset cubes and beacons
    cubes.forEach(cube => {
        cube.userData.collected = false;
        cube.userData.respawnTimer = 0;
        cube.visible = true;
    });
    beacons.forEach(beacon => beacon.visible = true);

    // Reset monsters
    monsters.forEach(m => {
        const ang = Math.random() * Math.PI * 2;
        m.position.set(Math.cos(ang) * 200, 0, Math.sin(ang) * 200);
        m.visible = false;
        m.userData.stunTimer = 0;
        // Reset AI state for the appropriate kind so neither carries
        // stale hunt/lunge momentum into the new run.
        if (m.userData.kind === 'hound') {
            m.userData.currentSpeed = TUNING.houndResetSpeed;
            m.userData.heading.set(Math.cos(ang), 0, Math.sin(ang));
        } else if (m.userData.kind === 'phantom') {
            // v2.0: reset phantom state
            m.userData.rage = 0;
            m.userData.teleportTimer = 2 + Math.random() * 2;
            m.userData.telegraphTimer = 0;
            if (m.userData.telegraphMesh) {
                scene.remove(m.userData.telegraphMesh);
                m.userData.telegraphMesh = null;
            }
        } else {
            m.userData.aiState = 'wander';
            m.userData.rage = 0;
            m.userData.lungeTimer = 0;
            m.userData.lungeCooldown = 0;
        }
    });
    // Hide all monster beacons immediately (don't wait for next animate frame).
    monsterBeacons.forEach(mb => { mb.group.visible = false; });

    // Reset ability
    abilityCooldownTimer = 0;
    // Reset power dive state
    isPowerDiving = false;
    powerDiveCooldownTimer = 0;
    powerDiveAirTimeTracker = 0;

    // Reset keys
    keys.w = false;
    keys.a = false;
    keys.s = false;
    keys.d = false;
    keys.space = false;
    keys.shift = false;
    keys.control = false;

    // Restore settings (these are the only things preserved)
    gameMode = currentMode;
    difficulty = currentDiff;
    recomputeMonsterThreshold();

    // Reset curse effects — this re-applies the correct starting curse for
    // the current mode (0 for non-survival, 0.7 for survival) and the
    // matching fog/sky/lighting. After this call, the visual state matches
    // a fresh run of the selected mode.
    updateCurse();

    // --- EXPLICIT FOG + VIGNETTE RESET ---
    // updateCurse() above sets the correct fog density for the starting
    // curse level, but in survival mode the previous run may have left
    // fog density very high (end-game curse ~1.0). We force-set it here
    // to be absolutely sure the player sees a clean starting state.
    // Survival uses a higher base fog density than other modes (0.0235 vs
    // TUNING.fogDensityBase) — see updateCurse() for the matching logic.
    if (gameMode === 'survival') {
        // Survival: curse starts at 0.7, fog = 0.0235 + 0.7 * 0.025 = 0.041
        const survivalFogBase = 0.0235;
        scene.fog.density = survivalFogBase + 0.7 * TUNING.fogDensityPerCurse;
    } else {
        // Non-survival: curse starts at 0, no fog
        scene.fog.density = TUNING.fogDensityStart;
    }
    scene.fog.color.copy(scene.background);

    // --- CLEAR PROXIMITY VIGNETTE PULSE ---
    // The monster AI loop sets vignette.style.boxShadow to a red inset
    // shadow whenever a monster is within 80 units of the player. That
    // code only runs when cubesCollected >= MONSTER_THRESHOLD, so on a
    // fresh run (cubesCollected = 0) it never executes — meaning any
    // red boxShadow left over from the previous run persists indefinitely.
    // Force-clear it here so the player sees a clean (curse-only) vignette.
    if (vignette) vignette.style.boxShadow = '';

    // Hide menus and request pointer lock
    pauseMenu.style.display = 'none';
    winScreen.style.display = 'none';
    instructions.style.display = 'none';

    // --- FORCE isLocked = true + set restart timestamp ---
    // The animate loop early-returns when !isLocked, which means game
    // logic doesn't run. After requestPointerLock() there's a brief
    // async window where isLocked is still false. If the browser is slow
    // to engage pointer lock (or denies it), the game appears frozen.
    // Setting isLocked = true here lets the animate loop run immediately.
    //
    // _lastRestartTime is checked by the pointerlockchange handler to
    // suppress the brief unlock-during-relock flicker (some browsers fire
    // locked=false then locked=true when re-locking). The suppression only
    // lasts RESTART_SUPPRESS_WINDOW_MS (300ms) — after that, normal ESC
    // behavior is restored so the player can pause normally.
    isLocked = true;
    _lastRestartTime = performance.now();

    // Pointer lock was already requested at the top of quickRestart() while
    // we were still firmly inside the user-gesture window. The retry below
    // is a fallback for browsers that didn't engage it on the first call —
    // note that it may NOT work in some browsers (no user gesture context
    // at that point), but we try anyway since some browsers do allow it.

    // Small delay to ensure pointer lock engages — if it didn't, retry.
    // Also re-assert isLocked = true in case the pointerlockchange
    // handler flipped it to false during the transition.
    trackTimeout(setTimeout(() => {
        if (!document.pointerLockElement) {
            try { document.body.requestPointerLock(); } catch (e) { /* ignore */ }
        }
        // If pointer lock still didn't engage after retry, force isLocked
        // true anyway so the player can keep playing — better a slightly
        // janky pointer than a frozen screen.
        if (!document.pointerLockElement) {
            isLocked = true;
        }
    }, 50));
}

document.addEventListener('pointerlockchange', () => {
    const newLocked = document.pointerLockElement === document.body;
    // --- Suppress pause-menu flicker for a short window after quick-restart ---
    // When quickRestart calls requestPointerLock(), some browsers fire:
    //   pointerlockchange (locked = false)  ← brief transition
    //   pointerlockchange (locked = true)   ← final state
    // The first event would re-show the pause menu and suspend audio,
    // creating a visible flicker + audio dropout. We suppress unlock
    // events for RESTART_SUPPRESS_WINDOW_MS (300ms) after a restart —
    // long enough to skip the flicker, short enough that a real ESC
    // press 1+ second later still works normally.
    const sinceRestart = performance.now() - _lastRestartTime;
    const inRestartWindow = sinceRestart < RESTART_SUPPRESS_WINDOW_MS;
    if (inRestartWindow && !newLocked) {
        // Brief unlock during re-lock transition — ignore, wait for re-lock.
        // Do NOT update isLocked here — keep it true so the animate loop
        // keeps running the game.
        return;
    }
    isLocked = newLocked;
    if (!isJumpscareActive && !gameEnded) {
        if (isLocked) {
            instructions.style.display = 'none';
            pauseMenu.style.display = 'none';
            // Resume audio context if suspended; if music hasn't been started yet
            // and we meet the monster threshold, start it.
            if (audioCtx && audioCtx.state === 'suspended') {
                audioCtx.resume();
            }
        } else {
            if (gameStarted) {
                pauseMenu.style.display = 'block';
                // Update pause menu stats
                document.getElementById('pause-cubes').textContent = cubesCollected;
                document.getElementById('pause-time').textContent = formatTime(gameTime);
                // Suspend audio while paused so music resumes where it left off
                if (audioCtx && audioCtx.state === 'running') {
                    audioCtx.suspend();
                }
            } else {
                instructions.style.display = 'block';
            }
        }
    }
});

// Pointer lock can fail silently (browser policy, missing user gesture,
// document not focused, etc.). When it does, the player would be stuck
// with no way to look around and no feedback. Show the pause menu as a
// fallback — its RESUME button re-issues the pointer lock request from
// a fresh user-gesture click, which is the only reliable way to re-engage
// pointer lock after a failed request.
document.addEventListener('pointerlockerror', () => {
    // Only surface the prompt if a game is actually running.
    if (!gameStarted || gameEnded || isJumpscareActive) return;
    // Drop the forced isLocked so the animate loop doesn't keep running
    // while the player can't actually look around.
    isLocked = false;
    // Show the pause menu — the RESUME button provides a fresh user-gesture
    // path back into pointer lock.
    pauseMenu.style.display = 'block';
    document.getElementById('pause-cubes').textContent = cubesCollected;
    document.getElementById('pause-time').textContent = formatTime(gameTime);
});

function openSettings(e) {
    if (e) e.stopPropagation();
