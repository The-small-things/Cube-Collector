// ===================== AUDIO =====================
let audioCtx = null;
let masterGain, distortionNode, reverbNode;
let monsterMusicBuffer = null;
let monsterMusicSource = null;
let musicLoadPromise = null;
let musicStartTime = 0;
let beatDropTriggered = false;

function initAudio() {
    if (audioCtx) return;
    audioCtx = new (window.AudioContext || window.webkitAudioContext)();
    masterGain = audioCtx.createGain();
    masterGain.gain.value = 1.0;

    distortionNode = audioCtx.createWaveShaper();
    distortionNode.curve = makeDistortionCurve(0);
    distortionNode.oversample = '4x';

    reverbNode = audioCtx.createConvolver();
    buildReverb(0.3);

    distortionNode.connect(reverbNode);
    reverbNode.connect(masterGain);
    masterGain.connect(audioCtx.destination);

    // Load and decode the chase music, store promise for loading screen
    musicLoadPromise = fetch('OFF WITH YOUR HEAD [MAX SEVERITY] - Grace UST-(123k).mp3')
        .then(res => res.arrayBuffer())
        .then(data => audioCtx.decodeAudioData(data))
        .then(buf => {
            monsterMusicBuffer = buf;
            // Auto-start the monster music immediately only for survival mode.
            if (gameMode === 'survival') playMonsterMusic();
        })
        .catch(e => console.warn("Monster music failed to load:", e));
}

function makeDistortionCurve(amount) {
    const n = 256, curve = new Float32Array(n);
    for (let i = 0; i < n; i++) {
        const x = (i * 2) / n - 1;
        curve[i] = amount === 0 ? x : ((Math.PI + amount) * x) / (Math.PI + amount * Math.abs(x));
    }
    return curve;
}

// Reverb building can be expensive and cause frame hitches when invoked
// synchronously during gameplay (e.g. on cube pickup). Cache generated buffers
// and schedule heavy work to run during idle time.
const reverbCache = new Map();
let _reverbNoise = null;
let _scheduledReverbKey = null;
let _activeReverbKey = null;

function buildReverbNow(dur) {
    if (!audioCtx || !reverbNode) return;
    // Snap duration to 0.1s increments to ensure we hit the pre-baked cache
    const clamped = Math.round(Math.max(0.1, Math.min(dur, 1.0)) * 10) / 10;
    const key = Math.round(clamped * 10);
    
    if (_activeReverbKey === key) return;
    if (reverbCache.has(key)) {
        reverbNode.buffer = reverbCache.get(key);
        _activeReverbKey = key;
        return;
    }
    
    const len = Math.floor(audioCtx.sampleRate * clamped);
    const buf = audioCtx.createBuffer(2, len, audioCtx.sampleRate);
    if (!_reverbNoise) {
        _reverbNoise = new Float32Array(audioCtx.sampleRate);
        for (let i = 0; i < _reverbNoise.length; i++) _reverbNoise[i] = Math.random() * 2 - 1;
    }
    for (let c = 0; c < 2; c++) {
        const d = buf.getChannelData(c);
        const off = c * 1024;
        for (let i = 0; i < len; i++) {
            const decay = 1 - i / len;
            d[i] = _reverbNoise[(i + off) % _reverbNoise.length] * decay * decay;
        }
    }
    reverbCache.set(key, buf);
    reverbNode.buffer = buf;
    _activeReverbKey = key;
}

function scheduleBuildReverb(dur) {
    // Since we pre-bake everything in the loading screen, we can call this immediately
    buildReverbNow(dur);
}

function buildReverb(dur) {
    scheduleBuildReverb(dur);
}

function getOutput() {
    if (!audioCtx) return null;
    if (audioDistortionEnabled && distortionNode) return distortionNode;
    if (reverbNode) return reverbNode;
    return audioCtx.destination;
}

function playTone(freq, type, dur, vol, freqEnd) {
    if (!audioCtx) return;
    const osc = audioCtx.createOscillator();
    const g = audioCtx.createGain();
    osc.type = type;
    osc.frequency.setValueAtTime(freq * (1 + curseFactor * 0.4 * (Math.random()-0.5)), audioCtx.currentTime);
    if (freqEnd) osc.frequency.exponentialRampToValueAtTime(freqEnd, audioCtx.currentTime + dur);
    // SFX volume scales the per-call volume (separate from master volume).
    g.gain.setValueAtTime(vol * sfxVolume, audioCtx.currentTime);
    g.gain.linearRampToValueAtTime(0.001, audioCtx.currentTime + dur);
    osc.connect(g); g.connect(getOutput());
    osc.start(); osc.stop(audioCtx.currentTime + dur);
}

function playNoise(dur, vol, filterFreq) {
    if (!audioCtx) return;
    const len = Math.floor(audioCtx.sampleRate * dur);
    const buf = audioCtx.createBuffer(1, len, audioCtx.sampleRate);
    const d = buf.getChannelData(0);
    for (let i = 0; i < len; i++) d[i] = Math.random()*2-1;
    const src = audioCtx.createBufferSource(); src.buffer = buf;
    const f = audioCtx.createBiquadFilter(); f.type = 'lowpass'; f.frequency.value = filterFreq;
    // SFX volume scales the per-call volume (separate from master volume).
    const g = audioCtx.createGain(); g.gain.setValueAtTime(vol * sfxVolume, audioCtx.currentTime);
    g.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + dur);
    src.connect(f); f.connect(g); g.connect(getOutput());
    src.start();
}

function playJump() { playTone(140 + curseFactor*60, 'triangle', 0.18, 0.13, 300 + curseFactor*100); }
function playLand() { playNoise(0.12, 0.12, 150 + curseFactor*200); }
function playStep(v=0.05) { playTone(55 + curseFactor*30*(Math.random()-0.5), 'sine', 0.09, v); }

function playCollect(n) {
    if (!audioCtx) return;
    const baseFreq = 440 + n * 30;
    playTone(baseFreq, 'triangle', 0.15, 0.18, baseFreq*1.5);
    setTimeout(() => playTone(baseFreq*1.5, 'sine', 0.2, 0.12), 100);
    if (n > 5) {
        setTimeout(() => playTone(baseFreq * 0.5 * (0.8 + Math.random()*0.4), 'sawtooth', 0.3, 0.08), 50);
    }
}

function playMonsterSound() {
    if (!audioCtx || curseFactor < 0.8) return;
    // Deep distorted growl + sub-bass thump
    const f = 50 + Math.random()*30;
    playTone(f, 'sawtooth', 0.4 + Math.random()*0.4, 0.06 + curseFactor*0.05);
    playNoise(0.3, 0.04 + curseFactor*0.04, 200);
}

// NEW: distant whisper — a brittle, breathy hiss that seems to come from nowhere.
// Used by monsters in the "stalk" state to unnerve the player before they get close.
function playMonsterWhisper() {
    if (!audioCtx) return;
    const dur = 0.6 + Math.random() * 0.6;
    const len = Math.floor(audioCtx.sampleRate * dur);
    const buf = audioCtx.createBuffer(1, len, audioCtx.sampleRate);
    const d = buf.getChannelData(0);
    // Amplitude-modulated noise = breathy "ssss... hhhh..." texture
    for (let i = 0; i < len; i++) {
        const t = i / audioCtx.sampleRate;
        const env = Math.sin(t * Math.PI / dur);          // rise then fall
        const mod = 0.5 + 0.5 * Math.sin(t * 38);          // fast tremolo
        d[i] = (Math.random()*2 - 1) * env * mod * 0.5;
    }
    const src = audioCtx.createBufferSource(); src.buffer = buf;
    const f = audioCtx.createBiquadFilter();
    f.type = 'bandpass';
    f.frequency.value = 1800 + Math.random() * 1200;       // sharp sibilance
    f.Q.value = 6;
    const g = audioCtx.createGain();
    g.gain.setValueAtTime(0.001, audioCtx.currentTime);
    g.gain.exponentialRampToValueAtTime(0.05 + curseFactor*0.05, audioCtx.currentTime + 0.1);
    g.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + dur);
    src.connect(f); f.connect(g); g.connect(getOutput());
    src.start();
}

// NEW: hunting scream — a sudden, jarring, detuned screech used when a monster
// enters the "lunge" state or transitions into close-range "hunt" mode.
let _lastScreamTime = 0;
function playMonsterScream() {
    if (!audioCtx) return;
    const now = audioCtx.currentTime;
    if (now - _lastScreamTime < 0.4) return; // throttle to avoid stacking
    _lastScreamTime = now;
    // Two detuned saw oscillators sliding in opposite directions = dissonant shriek
    const baseF = 380 + Math.random() * 180;
    const osc1 = audioCtx.createOscillator(); osc1.type = 'sawtooth';
    osc1.frequency.setValueAtTime(baseF, now);
    osc1.frequency.exponentialRampToValueAtTime(baseF * 2.2, now + 0.35);
    osc1.frequency.exponentialRampToValueAtTime(baseF * 0.5, now + 0.9);
    const osc2 = audioCtx.createOscillator(); osc2.type = 'sawtooth';
    osc2.frequency.setValueAtTime(baseF * 1.06, now);
    osc2.frequency.exponentialRampToValueAtTime(baseF * 0.55, now + 0.4);
    const g = audioCtx.createGain();
    g.gain.setValueAtTime(0.0001, now);
    g.gain.exponentialRampToValueAtTime(0.18, now + 0.04);
    g.gain.exponentialRampToValueAtTime(0.001, now + 0.9);
    // harsh distortion on the scream
    const shaper = audioCtx.createWaveShaper();
    shaper.curve = makeDistortionCurve(80);
    shaper.oversample = '4x';
    osc1.connect(shaper); osc2.connect(shaper);
    shaper.connect(g); g.connect(getOutput());
    osc1.start(now); osc2.start(now);
    osc1.stop(now + 0.95); osc2.stop(now + 0.95);
    // sub-bass thump underneath for physical impact
    playTone(42, 'sine', 0.5, 0.18, 22);
}

// NEW: heartbeat — a soft "lub-dub" that plays periodically when any monster
// is in the "hunt" state near the player. Tempo scales with the closest monster's
// proximity, so the player feels the panic rise as it closes in.
let _lastHeartbeatTime = 0;
function playMonsterHeartbeat(intensity) {
    if (!audioCtx) return;
    const now = audioCtx.currentTime;
    if (now - _lastHeartbeatTime < 0.45) return;
    _lastHeartbeatTime = now;
    const vol = 0.04 + intensity * 0.16;
    const lub = () => playTone(58, 'sine', 0.13, vol);
    const dub = () => playTone(50, 'sine', 0.11, vol * 0.7);
    lub();
    setTimeout(dub, 160);
}

function playMonsterMusic() {
    if (!monsterMusicBuffer || monsterMusicSource || !audioCtx) return;
    monsterMusicSource = audioCtx.createBufferSource();
    monsterMusicSource.buffer = monsterMusicBuffer;
