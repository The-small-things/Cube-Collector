// ---- Global backend config ----
// Create a free Firebase project (firebase.google.com -> Realtime Database),
// set its rules to allow public read/write to the "leaderboard" node (see
// the rules snippet provided alongside this file), then paste the database
// URL below. Leave it as null to fall back to local-only scoring.
const FIREBASE_DB_URL = "https://cube-collector-default-rtdb.firebaseio.com"; // <-- replace, or set to null

function leaderboardPath(mode, diff) { return `leaderboard/${mode}/${diff}`; }

let backendStatus = 'unknown'; // 'online' | 'offline' | 'unconfigured'

function isFirebaseConfigured() {
    return !!FIREBASE_DB_URL && !FIREBASE_DB_URL.includes('YOUR-PROJECT-ID');
}

// Reads/writes go to Firebase Realtime Database (true global, shared by every
// player) when configured. Falls back to window.storage (global, but only
// inside a Claude.ai artifact), then to localStorage (this browser only).
async function lbGet(path) {
    if (isFirebaseConfigured()) {
        try {
            const res = await fetch(`${FIREBASE_DB_URL}/${path}.json`);
            if (!res.ok) throw new Error('bad response');
            const data = await res.json();
            backendStatus = 'online';
            return Array.isArray(data) ? data.filter(Boolean) : [];
        } catch (e) {
            backendStatus = 'offline';
            console.warn('Firebase read failed, falling back to local storage', e);
        }
    } else {
        backendStatus = 'unconfigured';
    }
    if (window.storage) {
        try {
            const res = await window.storage.get(path.replace(/\//g, ':'), true);
            return res ? JSON.parse(res.value) : [];
        } catch (e) { return []; }
    }
    try {
        const raw = localStorage.getItem(path);
        return raw ? JSON.parse(raw) : [];
    } catch (e) { return []; }
}

async function lbSet(path, entries) {
    if (isFirebaseConfigured()) {
        try {
            const res = await fetch(`${FIREBASE_DB_URL}/${path}.json`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(entries)
            });
            if (!res.ok) throw new Error('bad response');
            backendStatus = 'online';
            return;
        } catch (e) {
            backendStatus = 'offline';
            console.warn('Firebase write failed, falling back to local storage', e);
        }
    }
    if (window.storage) {
        try { await window.storage.set(path.replace(/\//g, ':'), JSON.stringify(entries), true); return; } catch (e) {}
    }
    try { localStorage.setItem(path, JSON.stringify(entries)); } catch (e) {}
}

function leaderboardKey(mode, diff) { return leaderboardPath(mode, diff); }

function formatTime(t) {
    const m = Math.floor(t / 60);
    const s = (t % 60).toFixed(1);
    return `${m}:${s.padStart(4, '0')}`;
}

function escapeName(s) {
    return (s || '???').toString().slice(0, 16).replace(/[<>&]/g, c => ({'<':'&lt;','>':'&gt;','&':'&amp;'}[c]));
}

