// ===================== MAIN LOOP =====================
const clock = new THREE.Clock();
let timeScale = 1.0;
let droneTimer = 0;
let monsterGroanTimer = 0;
let frameCount = 0;
let lastFPSUpdate = 0;
let currentFPS = 60;

const speedContainer = document.getElementById('speed-container');
const speedBarFill = document.getElementById('speed-bar-fill');
const machText = document.getElementById('mach-text');
let lastMach = 0;

// reusable temporaries to avoid allocations
const tmpInput = new THREE.Vector3();
const tmpMove = new THREE.Vector3();
const tmpRay = new THREE.Raycaster();
const tmpDirA = new THREE.Vector3(-1,0,-0.2);
const tmpDirB = new THREE.Vector3(1,0,-0.2);
const tmpToPlayer = new THREE.Vector3();
// common axis vectors reused instead of allocating per-frame
const Y_AXIS = new THREE.Vector3(0,1,0);
const FORWARD = new THREE.Vector3(0,0,-1);
const X_AXIS = new THREE.Vector3(1,0,0);
const tmpAxis = new THREE.Vector3();

let lastUIContent = "";
// =====================================================================
// PHYSICS / MOVEMENT / COLLISION ENGINE
// Organized into small focused functions, all operating on the shared
// player/velocity state declared above. Order of calls (see animate()):
//   1. applyGravityAndFlight   - vertical forces
//   2. getInputDirection       - reads keys -> tmpInput/tmpMove
//   3. updateSlideState        - slide start/continue/end
//   4. updateHorizontalVelocity- ground/air/fly acceleration + friction
//   5. updateWallRunDetection  - wall raycast + wall-run state + camera tilt
//   6. handleJumpInput         - jump / wall-jump / slide-jump / double-jump
//   7. integrateAndResolveCollisions - moves the player and resolves
//      collisions in fixed-size substeps so fast motion (slides, parries,
//      Mach 4 sprints) can't tunnel through obstacles.
// =====================================================================

// Max distance the player is allowed to move per collision substep.
// Anything faster than this in one frame gets split into multiple
// smaller steps so thin walls/platforms can't be skipped over.
// Bumped MAX_SUBSTEPS from 8 to 12 to handle the new 80 u/s slide cap
// without tunneling through obstacle faces.
const MAX_SUBSTEP_DIST = TUNING.maxSubstepDist;
const MAX_SUBSTEPS = TUNING.maxSubsteps;

function getHorizontalSpeed() {
    return Math.hypot(velocity.x, velocity.z);
}

function applyGravityAndFlight(dt) {
    // Update current player height (for sliding)
    let targetPlayerEyeHeight = playerHeight;
    if (isSliding) targetPlayerEyeHeight = playerHeight * 0.5;
    currentPlayerHeight = THREE.MathUtils.lerp(currentPlayerHeight, targetPlayerEyeHeight, dt * 25);

    // Sprint multiplier ramps to SPRINT_MULT when shift held; resets on ground when not.
    // We use SPRINT_MULT (1.55) as the target, not the old 1.95, because the new
    // MOVE_SPEED is already fast — sprint is a moderate bump, not a 2x blowout.
    // v2.1: stamina removed — sprint is always available; power-up speed boost still applies
    if (keys.shift) {
        currentSprintMultiplier = THREE.MathUtils.lerp(currentSprintMultiplier, SPRINT_MULT, dt * TUNING.sprintRampRate);
    } else if (isGrounded) {
        currentSprintMultiplier = THREE.MathUtils.lerp(currentSprintMultiplier, 1.0, dt * TUNING.sprintDecayRate);
    }

    if (isFlying) {
        // flying mode: no gravity, free movement
        velocity.y = 0;
    } else if (isWallRunning) {
        // Wall runs hang — gravity is light, and we boost upward slightly so
        // you don't immediately slide down. Preserves the Ultrakill "stick
        // to the wall" feel.
        velocity.y -= WALL_GRAVITY * dt;
        if (velocity.y < TUNING.wallRunMaxFallSpeed) velocity.y = TUNING.wallRunMaxFallSpeed;
    } else if (!isGrounded) {
        let gravityMult = 1.0;
        if (isPowerDiving) gravityMult = TUNING.powerDiveGravityMult; // Power dive slams down hardest
        else if (isSliding && isDive) gravityMult = TUNING.diveGravityMult; // Dives slam down harder (Grace slam)
        // Variable jump height: if the player releases jump early while rising,
        // cut upward velocity. Lets you do tiny hops vs. full jumps by tap-vs-hold.
        if (velocity.y > TUNING.variableJumpCutoffVel && !keys.space) gravityMult *= TUNING.variableJumpGravityMult;
        velocity.y -= GRAVITY * gravityMult * dt;
    }
}

function getInputDirection() {
    tmpInput.set(0, 0, 0);
    if (keys.w) tmpInput.z -= 1;
    if (keys.s) tmpInput.z += 1;
    if (keys.a) tmpInput.x -= 1;
    if (keys.d) tmpInput.x += 1;
    // NOTE: we do NOT normalize here for air strafing — Quake-style accel
    // is sensitive to wishspeed, and we want a non-normalized wishDir for
    // diagonal inputs to behave naturally. We normalize when needed inside
    // the accelerate() path.
    tmpMove.copy(tmpInput).applyAxisAngle(Y_AXIS, yaw);
    return tmpInput;
}

// --- Quake/Source-style acceleration core ---
// This is THE function that gives the movement its feel. Wishspeed is the
// max speed we'd LIKE to reach in wishDir. CurrentSpeed is the component
// of velocity already pointing along wishDir. We can only add up to
// (wishSpeed - currentSpeed), and accel*dt*wishSpeed is the most we add
// per frame. The asymmetry between ground (high wishspeed) and air
// (capped wishspeed) is what makes strafe-jumping work.
function accelerate(wishDirX, wishDirZ, wishSpeed, accel, dt) {
    // Project current velocity onto wishDir
    const currentSpeed = velocity.x * wishDirX + velocity.z * wishDirZ;
    const addSpeed = wishSpeed - currentSpeed;
    if (addSpeed <= 0) return; // already moving at/above wishSpeed in this dir
    let accelSpeed = accel * dt * wishSpeed;
    if (accelSpeed > addSpeed) accelSpeed = addSpeed;
    velocity.x += accelSpeed * wishDirX;
    velocity.z += accelSpeed * wishDirZ;
}

// Ground friction — Quake-style exponential decay. The lower the friction
// constant, the longer your speed carries when you stop pressing inputs.
// Crucially this only applies on the ground when no input is held; with
// input, accelerate() takes over and lets you re-steer without losing
// much speed (because GROUND_ACCEL is high enough to push you back up to
// wishspeed before friction eats much).
function applyGroundFriction(dt) {
    const speed = Math.hypot(velocity.x, velocity.z);
    if (speed < 0.1) { velocity.x = 0; velocity.z = 0; return; }
    const drop = speed * GROUND_FRICTION * dt;
    const newSpeed = Math.max(0, speed - drop);
    const scale = newSpeed / speed;
    velocity.x *= scale;
    velocity.z *= scale;
}

// --- SLIDING & MOVEMENT PHYSICS (Ultrakill / Grace style) ---
function updateSlideState(dt, hSpeed) {
    // Start a new slide. Cooldown is honored even mid-air now — it used to be
    // bypassed whenever airborne (to allow diving shortly after a normal jump,
    // which never touches the cooldown anyway), but that bypass also meant a
    // slide-jump could chain straight into another slide-jump with zero gap
    // between them: each one adds upward velocity with no time to fall in
    // between, so holding forward+jump+slide+sprint together stacked velocity
    // every frame and the player never came back down. Real air-dives after a
    // plain jump are unaffected since the cooldown is already 0 in that case.
    if (keys.control && !isSliding && slideCooldownTimer <= 0 && hSpeed > 4.0) {
        isSliding = true;
        slideTimer = SLIDE_DURATION;
        isDive = !isGrounded;
        isSlideJump = false;

        if (!isGrounded) {
            // Mid-air Slide (Dive / Grace slam): Direction based on where looking
            slideDirection.set(0, 0, -1).applyAxisAngle(Y_AXIS, yaw).normalize();
            if (cubeBoostTimer <= 0) velocity.y = TUNING.diveSlamSpeed; // Harder slam
        } else {
            // Ground Slide: Direction based on current movement (or facing if stationary)
            if (hSpeed > 1.0) {
                slideDirection.set(velocity.x, 0, velocity.z).normalize();
            } else {
                slideDirection.set(0, 0, -1).applyAxisAngle(Y_AXIS, yaw).normalize();
            }
        }

        // Massive initial speed kick — scales hard with current speed so
        // chaining slide-jump-slide keeps ramping you up to SLIDE_MAX_SPEED.
        const boost = THREE.MathUtils.clamp(
            hSpeed * SLIDE_BOOST_FROM_SPEED_MULT + SLIDE_INITIAL_SPEED_OVERRIDE,
            SLIDE_INITIAL_SPEED_OVERRIDE,
            SLIDE_MAX_SPEED
        );
        velocity.x = slideDirection.x * boost;
        velocity.z = slideDirection.z * boost;
        preservedSlideSpeed = boost; // remember for slide-jump preservation
        playNoise(0.25, 0.12, 38); // Deep rumble — punchier
    }

    if (isSliding) {
        slideTimer -= dt;
        const progress = THREE.MathUtils.clamp(1.0 - (slideTimer / SLIDE_DURATION), 0, 1);
        // Very gradual decay — Grace slides hold their speed a LONG time before
        // tailing off. The exponent is lower so the curve stays flatter longer.
        const decayCurve = Math.pow(1.0 - progress, TUNING.slideDecayExponent);
        const targetSpeed = Math.max(preservedSlideSpeed, SLIDE_INITIAL_SPEED_OVERRIDE) * decayCurve;

        // Slide velocity is a blend of the slide direction (dominant) and a
        // small steering input from current key presses (so you can curve a
        // slide without losing all momentum). Lerp rate is low so the slide
        // holds its line — Ultrakill slides barely steer — but high enough
        // that you can still curve around obstacles.
        const steerInfluence = TUNING.slideSteerInfluence;
        velocity.x = THREE.MathUtils.lerp(velocity.x, slideDirection.x * targetSpeed + tmpMove.x * steerInfluence, dt * TUNING.slideSteerLerp);
        velocity.z = THREE.MathUtils.lerp(velocity.z, slideDirection.z * targetSpeed + tmpMove.z * steerInfluence, dt * TUNING.slideSteerLerp);

        // Apply tiny slide friction so extremely long slides eventually end
        const sp = getHorizontalSpeed();
        const slideDrop = sp * SLIDE_FRICTION * dt;
        const newSp = Math.max(0, sp - slideDrop);
        if (sp > 0.01) {
            const scl = newSp / sp;
            velocity.x *= scl;
            velocity.z *= scl;
        }

        hSpeed = getHorizontalSpeed();
        // End conditions — note: lowering the floor from 4 to 3 so slides
        // carry further before auto-ending.
        if (slideTimer <= 0 || (!keys.control && isGrounded) || (isGrounded && hSpeed < 3.0)) {
            isSliding = false;
            slideCooldownTimer = SLIDE_COOLDOWN;
        }
    } else {
        preservedSlideSpeed = 0;
    }
    return hSpeed;
}

function updateHorizontalVelocity(dt) {
    if (isFlying) {
        // Space/Shift for vertical flight
        if (keys.space) tmpInput.y += 1;
        if (keys.shift) tmpInput.y -= 1;
    }

    const cubeBoostActiveMult = cubeBoostTimer > 0 ? 1.45 : 1.0;
    // v2.0: power-up speed boost + time slow player speed boost
    let puSpeedMult = 1.0;
    try { if (isSpeedBoostActive()) puSpeedMult *= TUNING.powerupSpeedMult; } catch (e) {}
    if (timeSlowActive) puSpeedMult *= TUNING.timeSlowSpeedMult;
    const speedMult = currentSprintMultiplier * (1 + curseFactor * 0.15) * cubeBoostActiveMult * puSpeedMult;
    const flySpeed = 25.0;

    if (isFlying) {
        velocity.x = tmpMove.x * flySpeed;
        velocity.y = tmpMove.y * flySpeed;
        velocity.z = tmpMove.z * flySpeed;
        return { cubeBoostActiveMult, speedMult };
    }

    // Don't run normal ground/air accel during a slide — slide physics
    // own the horizontal velocity until the slide ends.
    if (isSliding) return { cubeBoostActiveMult, speedMult };

    // --- Compute normalized wishDir and wishSpeed ---
    const wishLen = Math.hypot(tmpInput.x, tmpInput.z);
    const hasInput = wishLen > 0.001;
    const wishDirX = hasInput ? tmpMove.x / wishLen : 0;
    const wishDirZ = hasInput ? tmpMove.z / wishLen : 0;

    if (isGrounded) {
        // Ground: friction (only when no input OR when below max speed) + strong accel
        // Quake applies friction BEFORE accel — this lets you keep speed when
        // chaining b-hops because friction is small relative to your speed.
        if (!hasInput) {
            applyGroundFriction(dt);
        } else {
            const wishSpeed = MOVE_SPEED * speedMult;
            const totalSpeed = Math.hypot(velocity.x, velocity.z);

            // --- GROUND STEERING (the "W follows my camera" fix) ---
            // Without this, landing at 60 u/s with wishSpeed=28 means
            // accelerate() is a no-op (you're already above cap), so your
            // velocity direction never updates to follow the camera. Player
            // has to use A/D to redirect — feels like the camera is broken.
            //
            // Fix: rotate velocity toward wishDir at a capped rate. Strong
            // at normal speeds (full arcade control: W follows camera),
            // weaker when way over wishSpeed (so b-hops survive but you
            // can still curve gently).
            if (totalSpeed > 0.5) {
                const velDirX = velocity.x / totalSpeed;
                const velDirZ = velocity.z / totalSpeed;
                const currentDir = Math.atan2(velDirZ, velDirX);
                const wishAtan = Math.atan2(wishDirZ, wishDirX);
                let angleDiff = wishAtan - currentDir;
                while (angleDiff > Math.PI) angleDiff -= 2 * Math.PI;
                while (angleDiff < -Math.PI) angleDiff += 2 * Math.PI;

                // Turn rate: full groundSteerTurnRate at/below wishSpeed,
                // fading to groundSteerMinTurnRate when 2x over wishSpeed.
                // Lets you turn sharply while running, but commits you to
                // your b-hop direction at high over-speed.
                let turnRate = TUNING.groundSteerTurnRate;
                if (totalSpeed > wishSpeed) {
                    const over = (totalSpeed - wishSpeed) / wishSpeed; // 0 at wishSpeed, 1 at 2x
                    const range = TUNING.groundSteerTurnRate - TUNING.groundSteerMinTurnRate;
                    turnRate = TUNING.groundSteerTurnRate - Math.min(over, 1.0) * range;
                }
                const maxTurn = turnRate * dt;
                const turn = Math.max(-maxTurn, Math.min(maxTurn, angleDiff));
                const newDir = currentDir + turn;
                velocity.x = Math.cos(newDir) * totalSpeed;
                velocity.z = Math.sin(newDir) * totalSpeed;
            }

            // Light friction on TOTAL speed when above wishSpeed — lets b-hops
            // survive a few frames on the ground before decaying. Slower than
            // the steering so you can turn AND keep speed briefly.
            if (totalSpeed > wishSpeed) {
                const over = totalSpeed - wishSpeed;
                const drop = over * TUNING.groundOverSpeedFriction * dt; // slow decay
                const newOver = Math.max(0, over - drop);
                const target = wishSpeed + newOver;
                const scl = target / totalSpeed;
                velocity.x *= scl;
                velocity.z *= scl;
            }
            // Re-accelerate toward wishDir up to wishSpeed (no-op if already
            // moving faster than wishSpeed in that direction).
            accelerate(wishDirX, wishDirZ, wishSpeed, GROUND_ACCEL, dt);
        }
    } else {
        // AIR: Quake/Source-style air strafing. The cap on wishSpeed is the
        // magic — AIR_MOVE_SPEED is tiny (1.6), so holding W alone barely
        // adds speed. But if you press A/D and turn the mouse, your wishDir
        // is now perpendicular to your velocity, so currentSpeed (projection
        // onto wishDir) is near zero — and accelerate() can add the full
        // AIR_MOVE_SPEED worth of speed in that new direction, INCREASING your
        // total velocity vector magnitude. That's a strafe jump.
        if (hasInput) {
            // In the air, wishspeed is capped at AIR_MOVE_SPEED — UNLESS
            // we're sliding-launching (preservedSlideSpeed > 0) in which
            // case we let the slide's speed ride along.
            let airWishSpeed = AIR_MOVE_SPEED * speedMult;
            // Higher cap while sprinting in air so air-strafe gains are
            // more generous when sprinting.
            if (keys.shift) airWishSpeed *= TUNING.airSpeedSprintMult;
            accelerate(wishDirX, wishDirZ, airWishSpeed, AIR_ACCEL, dt);
        }

        // --- AIR STEERING (the "I can actually turn" fix) ---
        // Pure Quake air physics means holding W in the air does almost
        // nothing to redirect you — you keep moving in your old direction.
        // That's authentic but feels broken for players who expect "W follows
        // the camera." This hybrid adds a separate steering channel that
        // ROTATES the velocity vector toward wishDir at a capped rate, so:
        //   - Holding W + turning the camera → you curve toward where you look
        //   - Holding A/D + flicking mouse (strafe-jump) → steering is OFF
        //     (because wishDir is perpendicular to velocity, alignment ~ 0),
        //     so the strafe-jump tech still works for building speed.
        // The steering strength scales with alignment, so partial-diagonal
        // inputs get partial steering — smooth and intuitive.
        if (hasInput) {
            const speed = Math.hypot(velocity.x, velocity.z);
            if (speed > 1.0) {
                const velDirX = velocity.x / speed;
                const velDirZ = velocity.z / speed;
                const alignment = velDirX * wishDirX + velDirZ * wishDirZ;
                // Only steer when pushing roughly forward (above airSteerAlignThreshold).
                // Below that the player is strafing or backpedaling — leave
                // their velocity alone so strafe-jumps stay pure.
                if (alignment > TUNING.airSteerAlignThreshold) {
                    // Squared falloff: full steering when aligned, near-zero
                    // when barely-forward. Keeps the strafe-jump window clean.
                    const steerStrength = Math.min(1, (alignment - TUNING.airSteerAlignThreshold) / (1 - TUNING.airSteerAlignThreshold));
                    const currentDir = Math.atan2(velDirZ, velDirX);
                    const wishAtan = Math.atan2(wishDirZ, wishDirX);
                    let angleDiff = wishAtan - currentDir;
                    while (angleDiff > Math.PI) angleDiff -= 2 * Math.PI;
                    while (angleDiff < -Math.PI) angleDiff += 2 * Math.PI;
                    // Max turn rate: airSteerMaxRate at full alignment.
                    // Fast enough to feel responsive, slow enough that you
                    // can't insta-180 in the air (which would break momentum).
                    const maxTurn = TUNING.airSteerMaxRate * steerStrength * dt;
                    const turn = Math.max(-maxTurn, Math.min(maxTurn, angleDiff));
                    const newDir = currentDir + turn;
                    velocity.x = Math.cos(newDir) * speed;
                    velocity.z = Math.sin(newDir) * speed;
                }
            }
        }

        // Hard cap on total air speed to prevent runaway from parry flings,
        // cube boosts, etc. Only enforced if we're over the limit — momentum
        // below the cap is fully preserved (no decay).
        const airSpeed = Math.hypot(velocity.x, velocity.z);
        if (airSpeed > AIR_SPEED_LIMIT) {
            const scl = AIR_SPEED_LIMIT / airSpeed;
            velocity.x *= scl;
            velocity.z *= scl;
        }
    }

    return { cubeBoostActiveMult, speedMult };
}

function updateWallRunDetection(dt) {
    let nearWall = false;
    const pPos = player.position;

    if (!isGrounded && !isFlying && keys.w) {
        const nearObstacles = [];
        for (let i = 0; i < obstacles.length; i++) {
            const obs = obstacles[i];
            const dx = obs.position.x - pPos.x;
            const dz = obs.position.z - pPos.z;
            if (dx * dx + dz * dz < 225) nearObstacles.push(obs);
        }

        const rayDirs = [tmpDirA, tmpDirB];
        for (let ri = 0; ri < 2; ri++) {
            const dirLocal = rayDirs[ri];
            // transform local dir by yaw into world
            const dir = tmpMove.set(dirLocal.x, dirLocal.y, dirLocal.z).applyAxisAngle(Y_AXIS, yaw).normalize();
            tmpRay.set(pPos, dir);
            tmpRay.far = playerRadius + 0.8;
            const hits = tmpRay.intersectObjects(nearObstacles, true);
            if (hits.length > 0) { nearWall = true; wallNormal.copy(hits[0].face.normal); break; }
        }
    }

    let targetTilt;
    if (nearWall && !isGrounded && !isFlying) {
        if (!isWallRunning) {
            // Pop upward slightly when first sticking — feels like Ultrakill
            // wall-run "grabbing" the wall. Also refresh double jump so you
            // can chain wall-jumps across multiple walls.
            velocity.y = Math.max(velocity.y, TUNING.wallRunPopVel);
            canDoubleJump = true;
            // Wall-run overrides power dive — cancel the dive state so the
            // boosted gravity multiplier doesn't fight the wall-run gravity.
            isPowerDiving = false;
            playJump();
        }
        isWallRunning = true;
        tmpAxis.copy(X_AXIS).applyAxisAngle(Y_AXIS, yaw);
        targetTilt = tmpAxis.dot(wallNormal) * TUNING.wallRunTiltAmount; // Ultrakill lean
    } else {
        isWallRunning = false;
        targetTilt = tmpInput.x * 0.08;
    }
    // Skip camera tilt lerp during impact frames — against the flat white
    // background, any camera.rotation.z change looks like a FOV tweak.
    // The tilt freezes at its pre-impact value and resumes smoothly after.
    if (!impactFlatModeActive) {
        camera.rotation.z = THREE.MathUtils.lerp(camera.rotation.z, targetTilt, dt * TUNING.wallRunTiltLerp);
    }
}

function handleJumpInput(dt) {
    // Buffer decays on its own; coyote timer is fed from ground-state tracking
    // in resolveWorldAndObstacleCollisions(). Both just count down here.
    if (jumpBufferTimer > 0) jumpBufferTimer -= dt;
    if (coyoteTimer > 0) coyoteTimer -= dt;

    if (isFlying) return;
    const wantsJump = jumpBufferTimer > 0;
    if (!wantsJump) return;

    // Jumping cancels a power dive — once you commit upward velocity the dive
    // state is no longer meaningful, so clear it so the boosted gravity
    // multiplier doesn't yank you back down mid-jump.
    if (isPowerDiving) isPowerDiving = false;

    const groundedJumpAvailable = isGrounded || coyoteTimer > 0;
    // Triple jump is available when at Mach 4+ horizontal speed AND the
    // double jump has already been used (it's a 3rd air jump, not a
    // replacement for the 2nd). The check is real-time — drop below
    // Mach 4 and you lose the ability instantly.
    const hSpeedNow = Math.hypot(velocity.x, velocity.z);
    const canTripleJump = hSpeedNow >= TUNING.mach4Speed;
    if (!(groundedJumpAvailable || isWallRunning || canDoubleJump || canTripleJump)) return;

    if (isSliding && !isDive) {
        // GROUND SLIDE-JUMP (slam storage): launch upward but PRESERVE all
        // horizontal momentum. preservedSlideSpeed guarantees the slide's
        // velocity isn't clipped by the air cap when you take off. This is
        // the cornerstone of Grace/Ultrakill movement — slide, jump, slide,
        // jump, building speed each time. Refreshes canDoubleJump so you
        // get an air jump after the slide-jump. ONLY for ground slides —
        // jumping out of a DIVE (air slide) is handled below as a double
        // jump to prevent infinite slide-jump → double-jump → dive →
        // slide-jump fly chains.
        velocity.y = JUMP_FORCE * TUNING.slideJumpMult;
        // Re-assert horizontal slide velocity in case friction ate any
        if (preservedSlideSpeed > 0 && slideDirection.lengthSq() > 0) {
            const currentH = Math.hypot(velocity.x, velocity.z);
            if (currentH < preservedSlideSpeed) {
                velocity.x = slideDirection.x * preservedSlideSpeed;
                velocity.z = slideDirection.z * preservedSlideSpeed;
            }
        }
        isSliding = false;
        isSlideJump = true;
        slideCooldownTimer = SLIDE_COOLDOWN;
        canDoubleJump = true; // Allow air jump after slide launch
    } else if (isWallRunning) {
        // WALL-JUMP: pop up + strong lateral kick in the wall's normal direction.
        // Also keep your current forward momentum — you don't lose speed on
        // wall-jumps, you just change direction. This is what lets you chain
        // wall-jumps back and forth between two walls and climb indefinitely.
        velocity.y = WALL_JUMP_FORCE_UP;
        velocity.addScaledVector(wallNormal, WALL_JUMP_FORCE_SIDE);
        // Add a small forward boost in the direction the player is looking
        // so wall-jumping up a single wall still moves you along it.
        const fwdX = -Math.sin(yaw);
        const fwdZ = -Math.cos(yaw);
        velocity.x += fwdX * TUNING.wallJumpForwardBoost;
        velocity.z += fwdZ * TUNING.wallJumpForwardBoost;
        canDoubleJump = true; // Refresh double jump on wall contact
        runStats.wallJumps++;
        runStats.jumps++;
    } else if (groundedJumpAvailable) {
        // B-HOP-FRIENDLY JUMP: ONLY touch velocity.y — leave horizontal
        // velocity completely alone. This means landing and immediately
        // jumping preserves your full horizontal speed (b-hop). The previous
        // code did the same but the lerp-based ground accel would immediately
        // clamp it; with Quake-style accel above wishspeed, friction barely
        // touches you in the few frames you're on the ground.
        velocity.y = JUMP_FORCE;
        canDoubleJump = true; // First jump enables the second
        runStats.jumps++;
    } else if (canDoubleJump) {
        // DOUBLE JUMP — also used to EXIT A DIVE (air slide). Treating dive-
        // exit as a double jump (consumes canDoubleJump) instead of a slide-
        // jump (refreshes canDoubleJump) prevents the infinite fly chain:
        //   slide-jump (refresh) → double jump → dive → slide-jump (refresh) → ...
        // Now: slide-jump (refresh) → double jump (consume) → dive →
        //      double-jump-exit (consume, already empty) → fall. No more fly.
        if (isSliding) {
            // Exiting a dive — end the slide state before jumping.
            isSliding = false;
            slideCooldownTimer = SLIDE_COOLDOWN;
        }
        velocity.y = JUMP_FORCE * TUNING.doubleJumpMult;
        const fwdX = -Math.sin(yaw);
        const fwdZ = -Math.cos(yaw);
        // Only add forward kick if it would increase speed (don't slow down
        // a faster b-hop by forcing into a slower direction)
        const proj = velocity.x * fwdX + velocity.z * fwdZ;
        const kick = TUNING.doubleJumpForwardKick;
        if (proj < kick) {
            const add = kick - proj;
            velocity.x += fwdX * add;
            velocity.z += fwdZ * add;
        }
        canDoubleJump = false; // Air jump uses it up
    } else if (canTripleJump) {
        // TRIPLE JUMP — only available when hSpeed ≥ Mach 4 (65 u/s).
        // This is the reward for maintaining extreme speed: an extra air
        // jump after the double jump. Real-time check: if you drop below
        // Mach 4 (e.g. hit a wall, friction), canTripleJump becomes false
        // and this branch is skipped — you fall.
        //
        // Unlike the double jump, the triple jump does NOT consume a
        // persistent flag — it's purely speed-gated. As long as you stay
        // at Mach 4+, you can triple jump again after landing. But you
        // still need to land first to reset canDoubleJump, so this can't
        // be chained into quadruple-jumps mid-air.
        if (isSliding) {
            // Exiting a dive via triple jump — end the slide state.
            isSliding = false;
            slideCooldownTimer = SLIDE_COOLDOWN;
        }
        velocity.y = JUMP_FORCE * TUNING.tripleJumpMult;
        const fwdX = -Math.sin(yaw);
        const fwdZ = -Math.cos(yaw);
        // Triple jump gives a bigger forward kick than double jump —
        // rewards maintaining Mach 4+ with extra horizontal momentum.
        const proj = velocity.x * fwdX + velocity.z * fwdZ;
        const kick = TUNING.tripleJumpForwardKick;
        if (proj < kick) {
            const add = kick - proj;
            velocity.x += fwdX * add;
            velocity.z += fwdZ * add;
        }
        // Don't set canDoubleJump — the triple jump is the last air jump.
        // Landing will reset canDoubleJump (and the triple jump is
        // re-enabled as long as you're still at Mach 4+ when you next
        // need it).
    }
    isGrounded = false;
    coyoteTimer = 0;
    isWallRunning = false;
    playJump();
    jumpBufferTimer = 0; // Consume buffered input
    keys.space = false; // Avoid re-triggering while held (no bunny-hop spam)
}

// Resolves world bounds, the ground plane, and obstacle AABBs for the
// player's CURRENT position. Called once per collision substep.
function resolveWorldAndObstacleCollisions() {
    const pPos = player.position;

    if (pPos.y < -12) {
        player.position.set(0, TUNING.spawnY, 0);
        velocity.set(0, 0, 0);
        isSliding = false;
        slideCooldownTimer = 0; // No cooldown on respawn
        isWallRunning = false;
        playNoise(0.5, 0.2, 400);
        return;
    }

    const halfMap = MAP_SIZE / 2 - 5;
    if (Math.abs(pPos.x) > halfMap) {
        player.position.x = Math.sign(pPos.x) * halfMap;
        velocity.x = 0;
        if (isSliding) { isSliding = false; slideCooldownTimer = SLIDE_COOLDOWN; }
    }
    if (Math.abs(pPos.z) > halfMap) {
        player.position.z = Math.sign(pPos.z) * halfMap;
        velocity.z = 0;
        if (isSliding) { isSliding = false; slideCooldownTimer = SLIDE_COOLDOWN; }
    }

    // ground snap
    // NOTE: only snap + set isGrounded when velocity.y <= 0 (falling or
    // stationary). If velocity.y > 0 the player just jumped and is leaving
    // the ground — snapping them back and marking them grounded would let
    // them spam jump every frame and fly indefinitely. Let them leave the
    // ground naturally; they'll be snapped when they fall back.
    isGrounded = false;
    if (pPos.y <= currentPlayerHeight + 0.01 && velocity.y <= 0) {
        player.position.y = currentPlayerHeight;
        velocity.y = 0;
        isGrounded = true;
        coyoteTimer = COYOTE_TIME;
    }

    // obstacle collisions using precomputed boxes (no per-frame setFromObject)
    const feetY = pPos.y - currentPlayerHeight; // Distance from eye to feet is now currentPlayerHeight
    const pxMin = pPos.x - playerRadius;
    const pxMax = pPos.x + playerRadius;
    const pzMin = pPos.z - playerRadius;
    const pzMax = pPos.z + playerRadius;
    for (let i = 0; i < obstacleBoxes.length; i++) {
        const obs = obstacles[i];
        // Fast spatial culling for physics loop
        if (Math.abs(pPos.x - obs.position.x) > 35 || Math.abs(pPos.z - obs.position.z) > 35) continue;

        const box = obstacleBoxes[i];
        const overlapX = Math.min(pxMax, box.max.x) - Math.max(pxMin, box.min.x);
        const overlapY = Math.min(pPos.y, box.max.y) - Math.max(feetY, box.min.y); // feetY is pPos.y - currentPlayerHeight
        const overlapZ = Math.min(pzMax, box.max.z) - Math.max(pzMin, box.min.z);
        if (overlapX <= 0 || overlapY <= 0 || overlapZ <= 0) continue;

        // first resolve vertical landing / ceiling collision
        const isLanding = velocity.y <= 0.1 && pPos.y >= box.max.y && feetY >= box.max.y - 0.4;
        if (isLanding) {
            player.position.y = box.max.y + currentPlayerHeight; // Snap eye level to top of box + current eye height
            velocity.y = 0;
            isGrounded = true;
            coyoteTimer = COYOTE_TIME;
            continue;
        }
        const isCeilingHit = velocity.y > 0 && pPos.y <= box.min.y + currentPlayerHeight;
        if (isCeilingHit) {
            player.position.y = box.min.y + currentPlayerHeight;
            velocity.y = 0;
            continue;
        }

        // Horizontal resolution if in vertical overlap
        if (overlapX < overlapZ) {
            const push = Math.min(overlapX + 0.001, 1.0); // Clamp push to prevent flinging
            if (pPos.x > (box.min.x + box.max.x) * 0.5) {
                player.position.x += push;
            } else {
                player.position.x -= push;
            }
            velocity.x = 0;
            if (isSliding) {
                isSliding = false; // Immediately kill slide state on wall impact
                slideCooldownTimer = SLIDE_COOLDOWN;
                velocity.z *= 0.5; // Dampen remaining momentum to stabilize
            }
        } else {
            const push = Math.min(overlapZ + 0.001, 1.0); // Clamp push to prevent flinging
            if (pPos.z > (box.min.z + box.max.z) * 0.5) {
                player.position.z += push;
            } else {
                player.position.z -= push;
            }
            velocity.z = 0;
            if (isSliding) {
                isSliding = false; // Immediately kill slide state on wall impact
                slideCooldownTimer = SLIDE_COOLDOWN;
                velocity.x *= 0.5; // Dampen remaining momentum to stabilize
            }
        }
    }
}

// Moves the player by velocity*dt, splitting the move into multiple
// smaller substeps when traveling fast so collisions can't be skipped
// over (tunneling) during slides, parries, or Mach 3-4 sprinting.
function integrateAndResolveCollisions(dt) {
    // Safety: catch any NaN/Infinity that crept into velocity or position from
    // elsewhere (parry launches, wall-jump boosts, etc.) BEFORE computing substeps.
    // Without this check, a poisoned velocity makes `steps` itself NaN, which
    // would make the loop below never execute even once -> permanent freeze.
    if (!Number.isFinite(velocity.x) || !Number.isFinite(velocity.y) || !Number.isFinite(velocity.z) ||
        !Number.isFinite(player.position.x) || !Number.isFinite(player.position.y) || !Number.isFinite(player.position.z)) {
        console.warn("⚠️ Physics NaN/Infinity detected! Resetting position...");
        player.position.set(0, TUNING.spawnY, 0);
        velocity.set(0, 0, 0);
        return;
    }

    const speed = velocity.length();
    const totalDist = speed * dt;
    let steps = isFlying ? 1 : Math.ceil(totalDist / MAX_SUBSTEP_DIST);
    if (!Number.isFinite(steps) || steps < 1) steps = 1;
    steps = Math.min(MAX_SUBSTEPS, steps);
    const stepDt = dt / steps;

    for (let s = 0; s < steps; s++) {
        player.position.addScaledVector(velocity, stepDt);

        // Safety: Prevent NaN corruption from "yeeting" the player
        if (!Number.isFinite(player.position.x) || !Number.isFinite(player.position.y) || !Number.isFinite(player.position.z)) {
            console.warn("⚠️ Physics NaN detected! Resetting position...");
            player.position.set(0, TUNING.spawnY, 0);
            velocity.set(0, 0, 0);
            break;
        }

        if (!isFlying) {
            resolveWorldAndObstacleCollisions();
        }
    }
}

