<script type="module">
// NOTE: this runs as an ES module. Top-level `let`/`const` declared below are
// module-scoped, NOT exposed as bare globals — so typing e.g. `cubesCollected
// = 999` directly into the browser devtools console no longer reaches the
// real game state. The only intentionally-exposed surface is `window.debug`,
// and every gameplay-affecting command there marks the run as ineligible for
// the leaderboard (see taintRun / runTainted).
//
// Inline onclick="" attributes in the HTML run in the page's global scope,
// so the handful of functions referenced that way are explicitly attached to
// window below (function declarations hoist, so placement here is fine).
window.selectMode = (...a) => selectMode(...a);
window.selectDifficulty = (...a) => selectDifficulty(...a);
window.openLeaderboard = (...a) => openLeaderboard(...a);
window.closeLeaderboard = (...a) => closeLeaderboard(...a);
window.openSettings = (...a) => openSettings(...a);
window.closeSettings = (...a) => closeSettings(...a);
window.resetToDefaults = (...a) => resetToDefaults(...a);
window.setPerformance = (...a) => setPerformance(...a);
window.setParticleEffects = (...a) => setParticleEffects(...a);
window.showSettingsTab = (...a) => showSettingsTab(...a);
window.setColorblind = (...a) => setColorblind(...a);
window.showRunStats = (...a) => showRunStats(...a);
window.closeStatsPanel = (...a) => closeStatsPanel(...a);
window.resumeGame = (...a) => resumeGame(...a);
window.quickRestart = (...a) => quickRestart(...a);

// =====================================================================
// TUNING — single source of truth for all movement & UI parameters
// =====================================================================
// Every tunable value lives here. To rebalance the game, edit values in
// this object only — all the per-system constants below (GRAVITY,
// JUMP_FORCE, etc.) and all inline magic numbers throughout the movement
// and UI code are aliases that read from this object.
//
// IMPORTANT: this object is declared at the very top of the script so
// that any code that runs at parse time (makeBox, playerRadius, the
// obstacle scaling loop, etc.) can safely reference TUNING.* without
// hitting the const temporal-dead-zone error that would break the page.
//
// Sections:
//   1. CORE MOVEMENT     — gravity, base speed, sprint
//   2. JUMP              — forces, multipliers, coyote/buffer, var-jump
//   3. WALL JUMP / RUN   — wall-jump forces, wall-run hang/tilt
//   4. ACCELERATION      — Quake-style ground/air accel + caps
//   5. GROUND STEERING   — "W follows camera" turn rate
//   6. AIR STEERING      — hybrid in-air W steering
//   7. SLIDE             — duration, boost, friction, dive slam
//   8. CUBE PARRY        — fling magnitude formula
//   9. LOOK / MOUSE      — base sens, speed-scaled sens
//  10. FOV               — speed/sprint/slide/curse FOV curve + cap
//  11. MACH METER        — speed thresholds + speedometer max
//  12. CAMERA BOB        — head bob amplitude, slide drop
//  13. PLAYER            — height, radius, spawn Y
//  14. PHYSICS SAFETY    — substep count/dist (anti-tunneling)
//  15. OBSTACLES         — size mult, tint, tile settings
//  16. GROUND            — tint, grass tile repeat
//  17. START PLATFORM    — size, height
// =====================================================================
const TUNING = {
    // --- 1. CORE MOVEMENT ---
    gravity: 40.0,              // downward acceleration (u/s²)
    wallGravity: 3.5,           // gentler gravity while wall-running
    moveSpeed: 10.0,            // base wish speed (u/s) — sprint multiplies this
    airMoveSpeed: 2,          // base air wish-speed cap (u/s) — air-equivalent of moveSpeed. Tiny value is what makes strafe-jumping work (holding W adds almost nothing, but A/D + mouse turn redirects wishDir so the cap applies to a new direction and ADDS to total speed). Increase = easier air movement but weaker strafe-jump tech; decrease = harder air control but purer strafe-jump gains.
    sprintMult: 2.7,            // target sprint multiplier on wish speed
    sprintRampRate: 12.0,       // how fast sprint multiplier ramps up (per sec)
    sprintDecayRate: 8.0,       // how fast sprint multiplier decays on ground (per sec)

    // --- 2. JUMP ---
    jumpForce: 19.0,            // base jump velocity (u/s). Max height = jumpForce² / (2·gravity)
    slideJumpMult: 1.3,         // slide-jump = jumpForce * this (slam-storage pop)
    doubleJumpMult: 1.05,       // double-jump = jumpForce * this
    doubleJumpForwardKick: 8.0, // forward velocity added on double jump (u/s)
    tripleJumpMult: 1.0,        // triple-jump = jumpForce * this (only at Mach 4+)
    tripleJumpForwardKick: 12.0,// forward velocity added on triple jump (u/s)
    coyoteTime: 0.13,           // grace window after walking off ledge (s)
    jumpBufferTime: 0.15,       // window for early-jump input before landing (s)
    variableJumpCutoffVel: 4.0, // release jump above this upward vel → heavier gravity
    variableJumpGravityMult: 1.8, // gravity multiplier when jump released early

    // --- 3. WALL JUMP / WALL RUN ---
    wallJumpForceUp: 16.0,      // wall-jump upward velocity
    wallJumpForceSide: 18.0,    // wall-jump lateral kick (along wall normal)
    wallJumpForwardBoost: 4.0,  // extra forward kick on wall-jump (u/s)
