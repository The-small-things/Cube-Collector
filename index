// ===================== MINIMAP =====================
function updateMinimap() {
    if (!settingMinimap || !minimapVisible || !minimapCtx) {
        if (v2UI.minimap) v2UI.minimap.style.display = 'none';
        return;
    }
    if (v2UI.minimap) v2UI.minimap.style.display = 'block';
    const ctx = minimapCtx;
    const W = 160, H = 160;
    const range = 400; // world units shown
    const scale = W / (range * 2);
    const cx = player.position.x;
    const cz = player.position.z;

    // Clear with translucent black
    ctx.fillStyle = 'rgba(0,0,0,0.65)';
    ctx.fillRect(0, 0, W, H);

    // Grid
    ctx.strokeStyle = 'rgba(80,80,80,0.3)';
    ctx.lineWidth = 1;
    ctx.beginPath();
    ctx.moveTo(W/2, 0); ctx.lineTo(W/2, H);
    ctx.moveTo(0, H/2); ctx.lineTo(W, H/2);
    ctx.stroke();

    // Cubes (colored based on colorblind mode)
    let cubeCol = '#ff3030';
    if (settingColorblind === 'protan' || settingColorblind === 'deutan') cubeCol = '#3088ff';
    else if (settingColorblind === 'tritan') cubeCol = '#ff8800';
    for (const cube of cubes) {
        if (cube.userData.collected) continue;
        const dx = (cube.position.x - cx) * scale + W/2;
        const dz = (cube.position.z - cz) * scale + H/2;
        if (dx < 0 || dx > W || dz < 0 || dz > H) continue;
        ctx.fillStyle = cubeCol;
        ctx.fillRect(dx - 2, dz - 2, 4, 4);
    }

    // Power-ups (gold/magenta/cyan dots)
    for (const p of powerups) {
        if (!p.active) continue;
        const dx = (p.mesh.position.x - cx) * scale + W/2;
        const dz = (p.mesh.position.z - cz) * scale + H/2;
        if (dx < 0 || dx > W || dz < 0 || dz > H) continue;
        const col = POWERUP_COLORS[p.mesh.userData.type];
        ctx.fillStyle = '#' + col.toString(16).padStart(6, '0');
        ctx.beginPath();
        ctx.arc(dx, dz, 3, 0, Math.PI * 2);
        ctx.fill();
    }

    // Monsters (red dots, only if visible/awake)
    for (const m of monsters) {
        if (!m.visible) continue;
        const dx = (m.position.x - cx) * scale + W/2;
        const dz = (m.position.z - cz) * scale + H/2;
        // Clamp to edge if off-map
        const cdx = Math.max(4, Math.min(W - 4, dx));
        const cdz = Math.max(4, Math.min(H - 4, dz));
        ctx.fillStyle = m.userData.kind === 'phantom' ? '#ff00ff' : '#ff0000';
        ctx.beginPath();
        ctx.arc(cdx, cdz, 3, 0, Math.PI * 2);
        ctx.fill();
        // Arrow indicator if off-map
        if (dx !== cdx || dz !== cdz) {
            ctx.strokeStyle = '#ff0000';
            ctx.lineWidth = 1;
            ctx.beginPath();
            ctx.moveTo(W/2, H/2); ctx.lineTo(cdx, cdz);
            ctx.stroke();
        }
    }

    // Player (center, white arrow)
    ctx.save();
    ctx.translate(W/2, H/2);
    ctx.rotate(-yaw + Math.PI);
    ctx.fillStyle = '#ffffff';
    ctx.beginPath();
    ctx.moveTo(0, -5);
    ctx.lineTo(-3, 4);
    ctx.lineTo(3, 4);
    ctx.closePath();
    ctx.fill();
    ctx.restore();

    // Border
    ctx.strokeStyle = '#444';
    ctx.lineWidth = 1;
    ctx.strokeRect(0.5, 0.5, W - 1, H - 1);
}

function toggleMinimap() {
    minimapVisible = !minimapVisible;
