// --- SCALE ALL OBSTACLES BY TUNING.obstacleSizeMult ---
// Multiplies width/height/depth AND x/y/z positions by obstacleSizeMult
// so obstacles are visibly bigger while preserving the relative spacing
// between pieces within a pattern. Without scaling positions, pieces that
// were 9 units apart edge-to-edge become only 8 units apart with thicker
// boxes — and the altor pattern's central platform ends up sitting right
// on top of its four pillars instead of floating above them.
// y is also clamped to >= 0 after scaling so nothing clips below the
// floor plane (the ninja-parckore walls originally y=-1 seat into ground;
// 1.5x scaling puts them at y=-1.5 which we lift to 0).
const OBSTACLE_SIZE_MULT = TUNING.obstacleSizeMult;
OBSTACLE_PATTERNS.forEach(pattern => {
    pattern.forEach(p => {
        p[0] *= OBSTACLE_SIZE_MULT; // w
        p[1] *= OBSTACLE_SIZE_MULT; // h
        p[2] *= OBSTACLE_SIZE_MULT; // d
        p[3] *= OBSTACLE_SIZE_MULT; // x: spread pieces apart proportionally
        p[4] = Math.max(0, p[4] * OBSTACLE_SIZE_MULT); // y: scale + clamp to floor
        p[5] *= OBSTACLE_SIZE_MULT; // z: spread pieces apart proportionally
    });
});

// Randomly select patterns and spread them across the map
function generateObstacles(patterns, count = 20) {
    const selectedPatterns = [];
    const spacing = MAP_SIZE * 0.42; // Spread patterns across the new map scale
    // Min distance between pattern centers — scaled up by OBSTACLE_SIZE_MULT
    // since each pattern is now 1.5x bigger in every dimension. Without this,
    // two patterns placed 200 units apart could overlap because each pattern's
    // outermost piece is now 1.5x further from its own center.
    const minDistBetweenPatterns = TUNING.obstacleMinDistBetween * OBSTACLE_SIZE_MULT;
    const patternCenters = [];
    
    for (let i = 0; i < count; i++) {
        const pattern = patterns[i % patterns.length];
        
        // generate random position with more spread
        let angle, dist, baseX, baseZ;
        let attempts = 0;
        let positionValid = false;
        
        while (!positionValid && attempts < 10) {
            angle = (i / count) * Math.PI * 2 + (Math.random() - 0.5) * 1.2; 
            dist = spacing * (0.4 + Math.random() * 0.6); 
            baseX = Math.cos(angle) * dist;
            baseZ = Math.sin(angle) * dist;
            
            // check distance from other patterns
            positionValid = true;
            for (let pc of patternCenters) {
                const dx = pc.x - baseX;
                const dz = pc.z - baseZ;
                const distToOther = Math.sqrt(dx*dx + dz*dz);
                if (distToOther < minDistBetweenPatterns) {
                    positionValid = false;
                    break;
                }
            }
            attempts++;
        }
        
        patternCenters.push({ x: baseX, z: baseZ });
        
        // Find the highest point in this pattern to host the cube
        let highestIdx = 0;
        let maxY = -Infinity;
        pattern.forEach((p, idx) => {
            const topY = p[4] + p[1]; // y + height
            if (topY > maxY) {
                maxY = topY;
                highestIdx = idx;
            }
        });

        // offset each block and tag the highest one as the cube host
        const offsetPattern = pattern.map((p, blockIdx) => [
            p[0], p[1], p[2],
            baseX + p[3],
            p[4],
            baseZ + p[5],
            p[6], 
            blockIdx === highestIdx ? 'CUBE_PLATFORM' : (p[7] || '')
        ]);
        
        selectedPatterns.push(...offsetPattern);
    }
    
    return selectedPatterns;
}

let randomizedPlatformData = generateObstacles(OBSTACLE_PATTERNS);
const platformData = randomizedPlatformData;
platformData.forEach(p => makeBox(...p));

// precompute static obstacle boxes once
const playerRadius = TUNING.playerRadius;
function buildObstacleBoxes() {
    obstacleBoxes.length = 0;
    for (let i = 0; i < obstacles.length; i++) {
        const b = new THREE.Box3().setFromObject(obstacles[i]);
        // expand by player radius to simplify collision checks
        b.min.x -= playerRadius; b.min.z -= playerRadius;
        b.max.x += playerRadius; b.max.z += playerRadius;
        obstacleBoxes.push(b);
    }
}
