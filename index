function formatBind(code) {
    if (!code) return '';
    if (code.startsWith('Mouse')) {
        const b = code.replace('Mouse', '');
        if (b === '0') return 'L-MOUSE';
        if (b === '1') return 'M-MOUSE';
        if (b === '2') return 'R-MOUSE';
        return `MOUSE-${b}`;
    }
    return code
        .replace('Key', '')
        .replace('Digit', '')
        .replace('Numpad', 'NUM-')
        .replace('KP_', 'NUM-')
        .replace('Arrow', '')
        .replace('ShiftLeft', 'L-SHIFT')
        .replace('ShiftRight', 'R-SHIFT')
        .replace('ControlLeft', 'L-CTRL')
        .replace('ControlRight', 'R-CTRL')
        .replace('AltLeft', 'L-ALT')
        .replace('AltRight', 'R-ALT')
        .replace('Space', 'SPACE')
        .replace('Enter', 'ENTER')
        .replace('Escape', 'ESC')
        .replace('PageUp', 'PG-UP')
        .replace('PageDown', 'PG-DN')
        .replace('Delete', 'DEL')
        .replace('Insert', 'INS')
        .replace('Backspace', 'BS')
        .replace('Tab', 'TAB')
        .replace('BracketLeft', '[')
        .replace('BracketRight', ']')
        .replace('Semicolon', ';')
        .replace('Quote', "'")
        .replace('Comma', ',')
        .replace('Period', '.')
        .replace('Slash', '/')
        .replace('Backslash', '\\')
        .replace('Minus', '-')
        .replace('Equal', '=')
        .replace('Backquote', '`')
        .replace('Capslock', 'CAPS')
        .toUpperCase();
}

