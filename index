// Auto-init when DOM is ready (after the module finishes loading the existing init code)
// We'll call initV2Systems() from the loading sequence instead to ensure scene exists.


function animate() {
    requestAnimationFrame(animate);
    const rawDt = Math.min(clock.getDelta(), 0.05);
    // Brief freeze-frame while an impact-frame hitstop is active (the moment
    // anime holds the hit before the speed-lines burst). The render call
    // still runs below so the frozen frame is visible under the flash/lines.
    const inImpactHitstop = performance.now() < impactFrameHitstopUntil;
    const dt = inImpactHitstop ? 0 : rawDt * timeScale;

    if (isJumpscareActive) {
        renderer.render(scene, camera);
        return;
    }
    if (!isLocked) {
        renderer.render(scene, camera);
        return;
    }

    gameTime += dt;

    // v2.0: Update new systems every frame (uses non-time-slowed dt — these are
    // player-perspective systems, not world systems).
    try {
        updateTimeSlow(dt);
        updateCombo(dt);
        updateActivePowerup(dt);
        updatePowerups(dt);
        applyMagnetEffect(dt);
        updateMinimap();
    } catch (e) { /* v2 systems not yet initialized */ }

    // --- SURVIVAL: TIME ACCELERATION PER CUBE ---
    // In survival mode, every cube collected compounds a 1.1x multiplier on
    // the game clock. This makes the displayed "survived time" tick faster
    // the more cubes you've collected, incentivizing active cube-hunting
    // over passive hiding. Cubes respawn after 8s in survival, so the
    // multiplier compounds indefinitely — collecting 20 cubes = ~6.7x time,
    // 30 cubes = ~17.4x time. The leaderboard score (currentRunTime) is
    // derived from gameTime, so this scaled value IS the submitted score.
    //
    // We only add the BONUS here (the base dt was already added above) so
    // the multiplier effect compounds cleanly: bonus = dt * (mult - 1).
    if (gameMode === 'survival' && cubesCollected > 0) {
        const timeMult = Math.pow(1.1, cubesCollected);
        gameTime += dt * (timeMult - 1);
    }

    // realTime tracks wall-clock elapsed time (immune to the survival time
    // multiplier) so the FPS counter and other real-time-sensitive systems
    // stay accurate.
    realTime += dt;

    // FPS counter (uses realTime, NOT gameTime, so survival time-scaling
    // doesn't inflate the FPS reading).
    frameCount++;
    if (realTime - lastFPSUpdate >= 0.5) {
        currentFPS = Math.round(frameCount / (realTime - lastFPSUpdate));
        frameCount = 0;
        lastFPSUpdate = realTime;
        const fpsCounter = document.getElementById('fps-counter');
        if (fpsCounter && showFPS) {
            fpsCounter.textContent = currentFPS + ' FPS';
            fpsCounter.style.display = 'block';
        } else if (fpsCounter) {
            fpsCounter.style.display = 'none';
        }
    }
    if (gameMode === 'timeattack' || gameMode === 'survival') {
        const timerVal = document.getElementById('run-timer-value');
        if (timerVal) timerVal.textContent = formatTime(gameTime);
        // In survival mode, show the current time multiplier next to the
        // timer so the player can see the cube-collection bonus building.
        // 1 cube = 1.1x, 10 cubes = 2.59x, 20 cubes = 6.73x, etc.
        if (gameMode === 'survival') {
            const multVal = document.getElementById('run-timer-mult');
            if (multVal) {
                const mult = cubesCollected > 0 ? Math.pow(1.1, cubesCollected) : 1;
                multVal.textContent = `×${mult.toFixed(2)}`;
                // Color shifts from grey (no bonus) → orange → red as it climbs.
                if (cubesCollected === 0) {
                    multVal.style.color = '#666';
                } else if (mult < 2) {
                    multVal.style.color = '#ffaa00';
                } else if (mult < 5) {
                    multVal.style.color = '#ff6600';
                } else {
                    multVal.style.color = '#ff2222';
                }
            }
        }
    }
    droneTimer += dt;
    monsterGroanTimer += dt;
    if (slideCooldownTimer > 0) slideCooldownTimer -= dt;

    if (abilityCooldownTimer > 0) {
        abilityCooldownTimer = Math.max(0, abilityCooldownTimer - dt);
        const pct = (abilityCooldownTimer / ABILITY_COOLDOWN) * 100;
        document.getElementById('ability-bar-fill').style.width = (100 - pct) + '%';
        document.getElementById('ability-label').textContent = `FLARE [${formatBind(keyMapping.ability)}] — ${abilityCooldownTimer.toFixed(1)}s`;
    } else if (document.getElementById('ability-label').textContent.indexOf('READY') === -1) {
        document.getElementById('ability-bar-fill').style.width = '100%';
        document.getElementById('ability-label').textContent = `FLARE [${formatBind(keyMapping.ability)}] — READY`;
    }

    // Power dive cooldown + air-time tracker + UI bar update.
    // air-time tracker: counts up while airborne so usePowerDive() can enforce
    // a tiny min-air-time before allowing the dive (prevents accidental
    // insta-trigger when jump + V are pressed in the same frame).
    if (!isGrounded && !isFlying) {
        powerDiveAirTimeTracker += dt;
    } else {
        powerDiveAirTimeTracker = 0;
    }
    if (powerDiveCooldownTimer > 0) {
        powerDiveCooldownTimer = Math.max(0, powerDiveCooldownTimer - dt);
        const pdPct = (powerDiveCooldownTimer / TUNING.powerDiveCooldown) * 100;
        const pdFill = document.getElementById('power-dive-bar-fill');
        const pdLabel = document.getElementById('power-dive-label');
        if (pdFill) pdFill.style.width = (100 - pdPct) + '%';
        if (pdLabel) pdLabel.textContent = `DIVE [${formatBind(keyMapping.powerDive)}] — ${powerDiveCooldownTimer.toFixed(1)}s`;
    } else {
        const pdFill = document.getElementById('power-dive-bar-fill');
        const pdLabel = document.getElementById('power-dive-label');
        if (pdFill) pdFill.style.width = '100%';
        if (pdLabel && pdLabel.textContent.indexOf('READY') === -1) {
            pdLabel.textContent = `DIVE [${formatBind(keyMapping.powerDive)}] — READY`;
        }
    }
    if (cubeBoostTimer > 0) cubeBoostTimer -= dt;

    if (droneTimer > 4.0 && curseFactor > 0.25) {
        droneTimer = 0;
        playAmbientDrone();
    }
    if (monsterGroanTimer > 2.5 + Math.random()*2 && curseFactor > 0.8) {
        monsterGroanTimer = 0;
        playMonsterSound();
    }

    wasGroundedLastFrame = isGrounded;

    applyGravityAndFlight(dt);
    getInputDirection();

    let hSpeed = getHorizontalSpeed();
    // v2.0: track top speed for run stats
    try { updateRunStats(dt, hSpeed); } catch (e) {}

    // --- PIZZA TOWER SPEED-O-METER ---
    // Mach thresholds are TUNING.mach{1,2,3,4}Speed. Speedometer max is
    // TUNING.speedOMeterMax (h-speed at which the bar is 100% full).
    const speedPercent = Math.min((hSpeed / TUNING.speedOMeterMax) * 100, 100);
    speedBarFill.style.width = speedPercent + '%';

    let mach = 0;
    let machColor = '#ffffff';
    if (hSpeed > TUNING.mach5Speed) { mach = 5; machColor = '#b967ff'; }       // purple — Mach 5
    else if (hSpeed > TUNING.mach4Speed) { mach = 4; machColor = '#f759ab'; } // hot pink
    else if (hSpeed > TUNING.mach3Speed) { mach = 3; machColor = '#ff4d4f'; } // red
    else if (hSpeed > TUNING.mach2Speed) { mach = 2; machColor = '#ffec3d'; } // yellow
    else if (hSpeed > TUNING.mach1Speed) { mach = 1; machColor = '#ffffff'; } // white
    else { mach = 0; machColor = '#666666'; } // Mach 0 for low speeds/standing still

    // Pulse effect: text gets bigger as you go faster within a Mach tier
    const pulse = 1.0 + (speedPercent / 100) * TUNING.machPulseMax;
    machText.style.transform = `skewX(-10deg) scale(${pulse})`;

    // Rank up flash effect
    if (mach > lastMach) {
        machText.style.filter = 'brightness(3) saturate(2)';
        trackTimeout(runScopedTimeout(() => { machText.style.filter = 'none'; }, 150));
    }
    lastMach = mach;

    machText.innerText = `MACH ${mach}`;
    machText.style.color = machColor;
    // Shake the meter and camera at high mach — but skip camera position
    // shake during impact frames (it looks like a FOV tweak during the
    // flat-mode visual disruption).
    if (mach >= 3) {
        speedContainer.style.animation = 'mach-shake 0.1s infinite';
        if (mach === 4 && screenShakeEnabled && !impactFlatModeActive) {
            camera.position.x += (Math.random() - 0.5) * 0.05;
            camera.position.y += (Math.random() - 0.5) * 0.05;
        }
    } else {
        speedContainer.style.animation = 'none';
    }

    hSpeed = updateSlideState(dt, hSpeed);
    const isSprinting = keys.shift && !isFlying; // For UI/FOV, not direct speed
    const { cubeBoostActiveMult } = updateHorizontalVelocity(dt);

    // FOV curve now also factors in raw horizontal speed — so air strafing
    // up to Mach 4 widens the FOV dramatically even without sprint, giving
    // that Ultrakill "tunnel vision at speed" feel. All values are TUNING.*
    // so the FOV curve can be retuned in one place.
    const speedFOV = THREE.MathUtils.clamp(
        (hSpeed - TUNING.fovSpeedStartSpeed) / TUNING.fovSpeedRange, 0, 1
    ) * TUNING.fovSpeedBoost;
    const totalBoostForFOV = (currentSprintMultiplier * cubeBoostActiveMult) - 1.0;
    let targetFOV = THREE.MathUtils.lerp(baseFOV, baseFOV + TUNING.fovSprintBoost, totalBoostForFOV / 1.9)
                   + curseFactor * TUNING.fovCurseBoost
                   + speedFOV;
    if (isSliding) targetFOV += TUNING.fovSlideBoost;
    // v2.0: Time Slow ability adds purple FOV boost
    if (timeSlowActive) targetFOV += TUNING.timeSlowFOVBoost;
    // Hard cap — without this, sprint + slide + cube boost + curse can stack
    // the FOV past 150°, which looks like the camera is broken (and induces
    // motion sickness). TUNING.fovMax keeps the speed feel without going crazy.
    targetFOV = Math.min(targetFOV, TUNING.fovMax);

    // Skip FOV lerp entirely while an impact frame is active (hitstop OR
    // flat mode). When the impact ends, snap camera.fov to targetFOV on
    // the first frame to eliminate the visible "catch-up" lerp that would
    // otherwise happen as targetFOV resumes from its current (possibly
    // shifted) value vs the frozen camera.fov.
    if (impactFlatModeActive) {
        // Impact active — freeze camera.fov entirely.
        _fovWasFrozen = true;
    } else {
        if (_fovWasFrozen) {
            // First frame after impact ended — snap instead of lerp.
            camera.fov = targetFOV;
            camera.updateProjectionMatrix();
            _fovWasFrozen = false;
        } else if (Math.abs(camera.fov - targetFOV) > 0.1) {
            camera.fov = THREE.MathUtils.lerp(camera.fov, targetFOV, dt * TUNING.fovLerpRate);
            camera.updateProjectionMatrix();
        }
    }

    updateWallRunDetection(dt);
    handleJumpInput(dt);
    integrateAndResolveCollisions(dt);

    // On landing: refresh double-jump eligibility (handled by canDoubleJump=false here
    // so the NEXT grounded jump will set it back to true). isSlideJump flag reset.
    // Horizontal momentum is preserved automatically — landing only zeros velocity.y.
    if (!isFlying && isGrounded && !wasGroundedLastFrame) {
        playLand();
        canDoubleJump = false;
        isSlideJump = false;
        // Dive landing: fire an impact frame + camera shake for the anime
        // "ground pound" punch, spawn a radial red/black lightning burst at
        // the impact point, then launch the player back upward. Power dive
        // hits harder/launches higher than a regular slide-dive.
        if (isPowerDiving) {
            triggerImpactFrame({
                color: '#ff5500',
                duration: 280,
                hitstop: 70,
                shake: true,
                flat: false // keep the 3D scene visible — flat mode would hide the landing
            });
            triggerDiveImpact(player.position.clone(), 1.6);
            playNoise(0.5, 0.22, 22); // deep thud on impact
            isPowerDiving = false;
            isGrounded = false; // launching back up — not resting on the ground
            velocity.y = TUNING.powerDiveLaunchSpeed;
        } else if (isSliding && isDive) {
            // Regular air-dive landing — smaller lightning burst + smaller launch.
            triggerDiveImpact(player.position.clone(), 1.0);
            isGrounded = false;
            velocity.y = TUNING.diveLaunchSpeed;
            isDive = false;
        }
    }

    // Camera bobbing — amplitudes come from TUNING.bobAmount{Y,X} and the
    // slide camera drop from TUNING.slideCameraDrop.
    // During impact frames, freeze camera.position to (0,0) for a stable
    // view — the bob/shake looks like a FOV tweak during the flat-mode
    // visual disruption.
    if (impactFlatModeActive) {
        camera.position.x = THREE.MathUtils.lerp(camera.position.x, 0, dt * 15);
        camera.position.y = THREE.MathUtils.lerp(camera.position.y, 0, dt * 15);
        stepTimer = 0;
    } else if (isSliding) {
        camera.position.y = THREE.MathUtils.lerp(camera.position.y, TUNING.slideCameraDrop, dt * 10);
        camera.position.x = THREE.MathUtils.lerp(camera.position.x, 0, dt * 10); // No X bob during slide
        stepTimer = 0; // No steps during slide
    } else {
        if ((isGrounded || isWallRunning) && hSpeed > 1.0) {
            const sm = isWallRunning ? 1.8 : 1.4;
            bobTimer += dt * hSpeed * sm;
            stepTimer += dt * hSpeed * sm;
            const curseBob = 1 + curseFactor * 1.5;
            camera.position.y = Math.sin(bobTimer) * TUNING.bobAmountY * curseBob;
            camera.position.x = Math.cos(bobTimer*0.5) * TUNING.bobAmountX * curseBob;
            if (stepTimer >= Math.PI) { playStep(isWallRunning?0.03:0.06); stepTimer=0; }
        } else {
            camera.position.y = THREE.MathUtils.lerp(camera.position.y, 0, dt * 10); // Reset camera Y bob
            camera.position.x = THREE.MathUtils.lerp(camera.position.x, 0, dt * 10); // Reset camera X bob
            stepTimer = 0;
        }
    }

    // Curse camera shake — skip during impact frames (looks like FOV tweak).
    if (curseFactor > 0.6 && screenShakeEnabled && !impactFlatModeActive) {
        const shakeAmt = (curseFactor - 0.6) * 0.018;
        camera.position.x += (Math.random()-0.5) * shakeAmt;
        camera.position.y += (Math.random()-0.5) * shakeAmt;
    }

    // cubes update: use distanceToSquared
    for (let i = 0; i < cubes.length; i++) {
        const cube = cubes[i];
        if (cube.userData.collected) {
            // Survival mode: respawn cubes after 8 seconds
            if (gameMode === 'survival') {
                cube.userData.respawnTimer -= dt;
                if (cube.userData.respawnTimer <= 0) {
                    cube.userData.collected = false;
                    cube.visible = true;
                    beacons[i].visible = true;
                }
            }
            continue;
        }
        cube.rotation.y += dt * (1 + curseFactor * 2);
        cube.rotation.x += dt * 0.4;
        cube.material.emissiveIntensity = 2.5 + Math.sin(gameTime * 4 + i) * 1.5;

        const dx = player.position.x - cube.position.x;
        const dy = player.position.y - cube.position.y;
        const dz = player.position.z - cube.position.z;
        const distSq = dx*dx + dy*dy + dz*dz;
        if (distSq < 4.0) { // radius 2 -> 4
            cube.userData.collected = true;
            cube.visible = false;
            beacons[i].visible = false;
            if (gameMode === 'survival') {
                cube.userData.respawnTimer = 8.0; // Respawn after 8 seconds in survival
            }
            cubesCollected++;
            runStats.cubesCollected = cubesCollected;
            addCombo(); // v2.0: chain cube pickups for combo multiplier
            if (cubesCollected === 1) unlockAchievement('first_cube');
            playCollect(cubesCollected);
            cubeBoostTimer = 2.5; // 2.5 second speed boost on collection

            // v2.0: Rush mode — checkpoint every N cubes (reset monster positions)
            if (gameMode === 'rush' && cubesCollected % TUNING.rushCheckpointEvery === 0) {
                monsters.forEach(m => {
                    if (m.userData.kind === 'phantom') resetPhantomState(m);
                    else {
                        const a = Math.random() * Math.PI * 2;
                        const d = TUNING.monsterCatchRespawnDist + Math.random() * 80;
                        m.position.set(player.position.x + Math.cos(a) * d, 0, player.position.z + Math.sin(a) * d);
                        if (m.userData.aiState) m.userData.aiState = 'wander';
                        if (m.userData.rage) m.userData.rage = 0;
                    }
                });
                showCurseMsg('CHECKPOINT', 1500);
            }

            // Parry-style fling: launch the player in the direction they are looking.
            // Tuned for Ultrakill/Grace — bigger base launch, harder fall-speed
            // reward (diving into a cube gives a HUGE horizontal fling), and a
            // higher vertical pop so you can chain into another slide-jump.
            // All magnitudes are TUNING.parry* so the fling can be retuned in
            // one place.
            const currentHSpeed = new THREE.Vector2(velocity.x, velocity.z).length();
            const fallSpeed = Math.max(0, -velocity.y); // Capture downward momentum

            // Calculate the horizontal launch magnitude, incorporating fallSpeed
            const horizontalLaunchMag = Math.min(
                TUNING.parryBase + (currentHSpeed * TUNING.parryHSpeedMult) + (fallSpeed * TUNING.parryFallSpeedMult),
                AIR_SPEED_LIMIT * 1.15 // just slightly above cap so the parry feels rewarding
            );

            camera.getWorldDirection(tmpToPlayer);
            const horizontalCameraDir = new THREE.Vector3(tmpToPlayer.x, 0, tmpToPlayer.z).normalize();
            velocity.x = horizontalCameraDir.x * horizontalLaunchMag;
            velocity.z = horizontalCameraDir.z * horizontalLaunchMag;
            velocity.y = JUMP_FORCE * TUNING.parryVerticalMult;
            preservedSlideSpeed = Math.max(preservedSlideSpeed, horizontalLaunchMag);

            isGrounded = false;
            isSliding = false;
            canDoubleJump = true; // Refresh jump as a reward

            updateCurse();

            if (curseMessages[cubesCollected]) {
                showCurseMsg(curseMessages[cubesCollected]);
            }

            if (cubesCollected === 10) {
                enableFlashlight();
                showCurseMsg("you found a flashlight\nit won't help", 3000);
            }

            if (cubesCollected === 20 && gameMode !== 'survival') {
                unlockAchievement('all_cubes');
                if (gameMode === 'zen') unlockAchievement('zen_master');
                if (difficulty === 'insane') unlockAchievement('insane_win');
                trackTimeout(runScopedTimeout(() => endGame('win'), 1500));
            }
        }
    }

    // beacons animation using pre-cached rings
    for (let i = 0; i < beacons.length; i++) {
        const bg = beacons[i];
        if (!bg.visible) continue;
    }
    // update instanced rings once per frame
    if (ringInstanced) {
        for (let ri = 0; ri < ringDescriptors.length; ri++) {
            const rd = ringDescriptors[ri];
            const beaconIndex = Math.floor(ri / 2);
            const beacon = beacons[beaconIndex];
            if (!beacon || !beacon.visible) {
                ringDummy.position.set(rd.bx, -999, rd.bz);
                ringDummy.rotation.x = Math.PI / 2;
                ringDummy.scale.set(0.0001, 0.0001, 0.0001);
                ringDummy.updateMatrix();
                ringInstanced.setMatrixAt(ri, ringDummy.matrix);
                continue;
            }
            rd.phase += dt * 0.8;
            const floatY = (rd.baseY + rd.phase * 6) % 80;
            ringDummy.position.set(rd.bx, floatY, rd.bz);
            ringDummy.rotation.x = Math.PI / 2;
            const s = 1.0 + floatY * 0.025;
            ringDummy.scale.set(s, s, s);
            ringDummy.updateMatrix();
            ringInstanced.setMatrixAt(ri, ringDummy.matrix);
        }
        ringInstanced.instanceMatrix.needsUpdate = true;
    }

    // Update red monster beacons — follow each monster + animate sonar ping.
    // Always called (even below threshold) so the beacons hide cleanly when
    // monsters are invisible; the function checks m.visible per-beacon.
    updateMonsterBeacons(dt);

    if (cubesCollected >= MONSTER_THRESHOLD) {
        const diffSettings = DIFFICULTY_SETTINGS[difficulty];
        // Track the closest any monster got to the player this frame, for the
        // proximity heartbeat + red vignette pulse (handled below the loop).
        let closestDistSqThisFrame = Infinity;
        const playerSpeedSq = velocity.x*velocity.x + velocity.z*velocity.z;

        for (let mi = 0; mi < monsters.length; mi++) {
            const m = monsters[mi];
            if (!m.visible) continue;

            // ---- STUNNED (from flare): skip AI, just shudder in place ----
            if (m.userData.stunTimer > 0) {
                m.userData.stunTimer -= dt;
                m.position.y = 0;
                m.rotation.z = Math.sin(performance.now() * 0.025) * 0.18;
                m.rotation.x = Math.cos(performance.now() * 0.022) * 0.12;
                // dim eyes while stunned — both kinds
                if (m.userData.refs) {
                    if (m.userData.refs.haloL) m.userData.refs.haloL.material.opacity = 0.08;
                    if (m.userData.refs.haloR) m.userData.refs.haloR.material.opacity = 0.08;
                    if (m.userData.refs.eyeHalo) m.userData.refs.eyeHalo.material.opacity = 0.08;
                }
                continue;
            }

            tmpToPlayer.copy(player.position).sub(m.position);
            tmpToPlayer.y = 0;
            const distSq = tmpToPlayer.lengthSq();
            const dist = Math.sqrt(distSq);
            if (distSq < closestDistSqThisFrame) closestDistSqThisFrame = distSq;

            const S = m.userData.scale || 3.8;
            // Catch radius is sized to be slightly BIGGER than the monster's
            // physical model so the player gets caught when they're clearly
            // in contact with it. The multiplier is kind-specific because
            // the two monsters have very different proportions:
            //
            //   Stalker: tall humanoid with 4 long reaching arms (~S*3.7
            //            reach from center). Hitbox S*3.0 covers the body
            //            + arm reach + a small contact margin.
            //
            //   Hound: long quadruped (~S*4.0 nose-to-tail, S*2.0 forward
            //            reach). Hitbox S*3.4 covers the full body length
            //            plus a contact margin. Larger than the Stalker's
            //            because the Hound is longer than it is tall.
            //
            // Both are bigger than the visible model so you can't scrape
            // the model without getting caught — but not SO big that you
            // get caught from unreasonable distances.
            const catchRadiusMult = (m.userData.kind === 'hound') ? 3.4 : (m.userData.kind === 'phantom' ? TUNING.phantomCatchRadius : 3.0);
            const catchRadius = S * catchRadiusMult * diffSettings.catchMult;
            const catchRadiusSq = catchRadius * catchRadius;

            // ---- VERTICAL EXTENT CHECK ----
            // The horizontal catch check above ignores Y entirely, which
            // means a player wall-running or jumping 50 units overhead
            // would still get "caught" if they were horizontally close.
            // Fix: also require the player's FEET to be within the monster's
            // vertical extent (plus a small clearance margin). The monster
            // is always at Y=0, so its vertical extent is [0, monsterTopY].
            //
            //   Stalker: skull top ~S*5.2, but it has FOUR long reaching
            //            arms (~S*3.7 each) that can swipe upward at
            //            players above it. monsterTopY = S*8.0 makes the
            //            vertical catch zone extend well above the head,
            //            so you genuinely can't escape a Stalker by
            //            jumping or wall-running over it — you have to
            //            break line of sight horizontally. (S*8.0 ≈ 29-40
            //            units depending on scale, taller than most
            //            platforms a player can realistically stand on.)
            //
            //   Hound: top of body ~S*1.9 → monsterTopY = S*2.5 (margin)
            //          You CAN jump over a Hound — it's only ~6 units tall
            //          and its legs don't reach upward.
            //
            // player.position.y is the EYE level; feet are at
            // player.position.y - currentPlayerHeight. We check feet so
            // standing on top of a monster still counts as a catch.
            const monsterTopY = (m.userData.kind === 'hound') ? S * 2.5 : (m.userData.kind === 'phantom' ? S * 3.5 : S * 8.0);
            const playerFeetY = player.position.y - currentPlayerHeight;
            const verticalSafe = playerFeetY > monsterTopY;

            // ============================================================
            // KIND-BRANCHED AI
            //   Stalker: state machine (wander → stalk → hunt → lunge) + rage
            //   Hound:   always hunts, momentum-based (accel on straights,
            //            decel on turns) — always knows player position.
            //   Phantom (v2.0): slow drift + teleport toward player, phases
            //            through obstacles, telegraphs arrival.
            // Both branches must set `speed` (for animation tempo) and
            // `newState` (for animation poses + sound selection).
            // ============================================================
            let speed = 0;
            let newState = 'hunt';

            // v2.0: apply time slow factor to monster dt (world slows, player doesn't)
            const mdt = dt * (timeSlowActive ? TUNING.timeSlowFactor : 1.0);

            if (m.userData.kind === 'phantom') {
                // ---------------------- PHANTOM AI (v2.0) ----------------------
                const caught = updatePhantom(m, mdt, diffSettings);
                speed = TUNING.phantomBaseSpeed * (1 + m.userData.rage * TUNING.phantomRageSpeedBonus);
                newState = m.userData.aiState || 'wander';
                if (caught && !isJumpscareActive && !godModeEnabled) {
                    // v2.0: shield blocks one catch
                    if (isShieldActive()) {
                        activePowerup = null;
                        if (v2UI.shieldRing) v2UI.shieldRing.classList.remove('active');
                        unlockAchievement('shield_save');
                        showSubtitle('* SHIELD ABSORBED THE HIT! *', 2.0);
                        resetPhantomState(m);
                        // Brief invuln period after shield save
                        triggerImpactFrame({ color: '#00ccff', duration: 320, hitstop: 80 });
                    } else {
                        // Trigger catch (set catchRadiusSq artificially to force the catch handler below)
                        // Use a sentinel — set distSq very small
                        // We'll just call the catch handler here directly via the shared code below
                        // by setting a flag and the catch check below will fire.
                        // Actually the cleanest approach: teleport on top of player.
                        // But the shared catch handler runs after this branch — so we let it run.
                        // Phantom's catchRadius check will catch this case naturally.
                    }
                }
            }
            else if (m.userData.kind === 'hound') {
                // ---------------------- HOUND AI ----------------------
                // The Hound ALWAYS knows where the player is. It accelerates
                // while its heading aligns with the direction to the player
                // (running in a straight line) and decelerates in proportion
                // to how sharply it has to turn. This makes it terrifying in
                // open terrain but weaker when the player jukes around
                // obstacles or cuts hard.
                const HOUND_ACCEL_BASE    = TUNING.houndAccelBase;
                const HOUND_ACCEL_SPEED   = TUNING.houndAccelPerSpeed;
                const HOUND_DECEL_PER_RAD = TUNING.houndDecelPerRad;
                const HOUND_SPEED_MIN     = TUNING.houndSpeedMin;
                const HOUND_SPEED_MAX_BASE = TUNING.houndSpeedMaxBase;
                const HOUND_TURN_RATE     = TUNING.houndTurnRate;
                // Difficulty-scaled acceleration: harder diffs = Hounds snap to top speed faster.
                const HOUND_ACCEL_MULT    = (diffSettings.houndAccelMult != null) ? diffSettings.houndAccelMult : 1.0;

                // Lead-prediction target (always knows where player is going).
                const predictX = player.position.x + velocity.x * TUNING.houndLeadPredictTime;
                const predictZ = player.position.z + velocity.z * TUNING.houndLeadPredictTime;
                const dxH = predictX - m.position.x;
                const dzH = predictZ - m.position.z;
                const dH = Math.sqrt(dxH*dxH + dzH*dzH) || 1;
                const desiredX = dxH / dH;
                const desiredZ = dzH / dH;

                // Heading error angle (0 = perfectly aligned, π = opposite)
                let dot = m.userData.heading.x * desiredX + m.userData.heading.z * desiredZ;
                dot = THREE.MathUtils.clamp(dot, -1, 1);
                const angleErr = Math.acos(dot);

                // Accelerate on straights, decelerate on turns.
                const maxSpeed = HOUND_SPEED_MAX_BASE * diffSettings.speedMult;
                m.userData.topSpeed = maxSpeed;
                let speedDelta;
                if (angleErr < 0.2) {
                    // Straight-line: accelerate, more aggressively the faster it already goes.
                    // Scaled by HOUND_ACCEL_MULT so higher difficulty Hounds wind up faster.
                    speedDelta = (HOUND_ACCEL_BASE + m.userData.currentSpeed * HOUND_ACCEL_SPEED) * HOUND_ACCEL_MULT * dt;
                } else {
                    // Turning: lose speed proportional to angle error.
                    speedDelta = -HOUND_DECEL_PER_RAD * angleErr * dt;
                }
                m.userData.currentSpeed = THREE.MathUtils.clamp(
                    m.userData.currentSpeed + speedDelta,
                    HOUND_SPEED_MIN,
                    maxSpeed
                );

                // Steer heading gradually toward desired direction (can't snap —
                // this is what lets a juke actually cost the Hound speed).
                const factor = 1 - Math.exp(-HOUND_TURN_RATE * dt / Math.max(angleErr, 0.01));
                const newHX = m.userData.heading.x + (desiredX - m.userData.heading.x) * factor;
                const newHZ = m.userData.heading.z + (desiredZ - m.userData.heading.z) * factor;
                const hLen = Math.sqrt(newHX*newHX + newHZ*newHZ) || 1;
                m.userData.heading.set(newHX / hLen, 0, newHZ / hLen);

                // Move along current heading.
                if (!isJumpscareActive) {
                    m.position.x += m.userData.heading.x * m.userData.currentSpeed * dt;
                    m.position.z += m.userData.heading.z * m.userData.currentSpeed * dt;
                    // Face the PLAYER directly (not the travel heading) — the
                    // Hound always knows where you are and locks its gaze on
                    // you even while momentum carries it sideways during turns.
                    // This matches the Stalker's facing behavior and keeps the
                    // cyclops eye + jaws pointed at the prey at all times.
                    m.lookAt(player.position.x, m.position.y, player.position.z);
                }

                // Subtle high-speed body roll (no twitch — Hound is purposeful).
                const speedFrac = m.userData.currentSpeed / maxSpeed;
                m.rotation.z = Math.sin(performance.now() * 0.018) * speedFrac * 0.06;

                speed = m.userData.currentSpeed;
                newState = 'hunt'; // Hound is always hunting — used by shared anim/sound
            }
            else {
                // ---------------------- STALKER AI ----------------------
                // ---- RAGE meter: builds while the player is in detection range,
                //      decays slowly when the player escapes. Higher rage = faster
                //      top speed and a brighter aura/eyes.
                if (dist < TUNING.stalkerRageDetectionDist) {
                    m.userData.rage = Math.min(1, m.userData.rage + dt * TUNING.stalkerRageBuildRate);
                } else {
                    m.userData.rage = Math.max(0, m.userData.rage - dt * TUNING.stalkerRageDecayRate);
                }

                // ---- STATE MACHINE ----
                //   wander  (dist > stalkerWanderDistThresh)  : patrol randomly, low speed
                //   stalk   (stalkerStalkDistThresh < d < stalkerWanderDistThresh) : circle the player, occasional whisper
                //   hunt    (stalkerHuntDistThresh < d < stalkerStalkDistThresh)  : direct chase with prediction
                //   lunge   (d < 20)       : telegraphed dash, very fast, short
                newState = m.userData.aiState;
                if (dist > TUNING.stalkerWanderDistThresh)        newState = 'wander';
                else if (dist > TUNING.stalkerStalkDistThresh)    newState = 'stalk';
                else if (dist > TUNING.stalkerHuntDistThresh)    newState = 'hunt';
                else                   newState = 'lunge';

                // State transitions: trigger sound effects on entry.
                if (newState !== m.userData.aiState) {
                    const prev = m.userData.aiState;
                    m.userData.aiState = newState;
                    m.userData.stateTimer = 0;
                    if (newState === 'hunt' && prev !== 'lunge' && dist < TUNING.stalkerHuntScreamDist && Math.random() < TUNING.stalkerHuntScreamChance) {
                        playMonsterScream();
                    }
                    if (newState === 'lunge') {
                        m.userData.lungeTimer = TUNING.stalkerLungeDuration;
                        playMonsterScream();
                    }
                    if (newState === 'stalk' && prev === 'wander' && dist < TUNING.stalkerStalkWhisperDist && Math.random() < TUNING.stalkerStalkWhisperChance) {
                        playMonsterWhisper();
                    }
                }

                // Lunge cooldown prevents immediate re-lunge after escaping.
                if (m.userData.lungeCooldown > 0) m.userData.lungeCooldown -= dt;

                // ---- SPEED per state ----
                // Stalker base speed now ramps harder with difficulty via stalkerSpeedMult
                // (stacks on top of the generic speedMult). At higher diffs Stalkers are
                // noticeably faster out of the gate, before rage/curse even kick in.
                const STALKER_DIFF_MULT = (diffSettings.stalkerSpeedMult != null) ? diffSettings.stalkerSpeedMult : 1.0;
                const baseSpeed = (MONSTER_SPEED_BASE + curseFactor * TUNING.stalkerCurseSpeedBonus + m.userData.rage * TUNING.stalkerRageSpeedBonus) * diffSettings.speedMult * STALKER_DIFF_MULT;
                speed = baseSpeed;
                if (newState === 'wander')      speed *= TUNING.stalkerWanderSpeedMult;
                else if (newState === 'stalk')  speed *= TUNING.stalkerStalkSpeedMult;
                else if (newState === 'hunt')   speed *= TUNING.stalkerHuntSpeedMult;
                else if (newState === 'lunge')  speed *= TUNING.stalkerLungeSpeedMult;

                // ---- MOVEMENT per state ----
                if (distSq > 0.0001 && !isJumpscareActive) {
                    if (newState === 'wander') {
                        // Pick a new wander target periodically.
                        m.userData.nextWanderUpdate -= dt;
                        const wt = m.userData.wanderTarget;
                        const dxT = wt.x - m.position.x;
                        const dzT = wt.z - m.position.z;
                        const dT = Math.sqrt(dxT*dxT + dzT*dzT);
                        if (dT < TUNING.stalkerWanderArrivalThresh || m.userData.nextWanderUpdate <= 0) {
                            const wa = Math.random() * Math.PI * 2;
                            const wd = TUNING.stalkerWanderDistMin + Math.random() * TUNING.stalkerWanderDistRange;
                            wt.set(m.position.x + Math.cos(wa) * wd, 0, m.position.z + Math.sin(wa) * wd);
                            m.userData.nextWanderUpdate = TUNING.stalkerWanderUpdateMin + Math.random() * TUNING.stalkerWanderUpdateRange;
                        } else {
                            m.position.x += (dxT / dT) * speed * dt;
                            m.position.z += (dzT / dT) * speed * dt;
                        }
                        m.lookAt(m.position.x + dxT, m.position.y, m.position.z + dzT);
                    }
                    else if (newState === 'stalk') {
                        // Circle the player at a comfortable distance, sometimes
                        // switching direction to feel predatory and unpredictable.
                        m.userData.stateTimer += dt;
                        if (m.userData.stateTimer > TUNING.stalkerStalkDirFlipMin + Math.random() * TUNING.stalkerStalkDirFlipRange) {
                            m.userData.stalkDir *= -1;
                            m.userData.stateTimer = 0;
                            if (Math.random() < 0.4) playMonsterWhisper();
                        }
                        const dInv = dist > 0.01 ? 1 / dist : 0;
                        const radX = tmpToPlayer.x * dInv;
                        const radZ = tmpToPlayer.z * dInv;
                        // perpendicular (rotate 90deg) — direction sign sets CW/CCW
                        const perpX = -radZ * m.userData.stalkDir;
                        const perpZ =  radX * m.userData.stalkDir;
                        // pull in / push out to maintain ~90 unit ring
                        const targetDist = TUNING.stalkerStalkTargetDist;
                        const radialAdjust = (dist - targetDist) * TUNING.stalkerStalkRadialPull;
                        const moveX = (perpX + radX * radialAdjust) * speed * dt;
                        const moveZ = (perpZ + radZ * radialAdjust) * speed * dt;
                        m.position.x += moveX;
                        m.position.z += moveZ;
                        // Face the player while circling (head tracks prey).
                        m.lookAt(player.position.x, m.position.y, player.position.z);
                    }
                    else {
                        // hunt & lunge: chase with lead-prediction based on player velocity.
                        let leadTime = TUNING.stalkerHuntLeadTime;
                        if (newState === 'lunge') leadTime = TUNING.stalkerLungeLeadTime;
                        const predictX = player.position.x + velocity.x * leadTime;
                        const predictZ = player.position.z + velocity.z * leadTime;
                        const dxP = predictX - m.position.x;
                        const dzP = predictZ - m.position.z;
                        const dP = Math.sqrt(dxP*dxP + dzP*dzP) || 1;
                        m.position.x += (dxP / dP) * speed * dt;
                        m.position.z += (dzP / dP) * speed * dt;
                        m.lookAt(player.position.x, m.position.y, player.position.z);

                        if (newState === 'lunge') {
                            m.userData.lungeTimer -= dt;
                            if (m.userData.lungeTimer <= 0) {
                                // Lunge spent — drop back to hunt, brief cooldown.
                                m.userData.aiState = 'hunt';
                                m.userData.lungeCooldown = TUNING.stalkerLungeCooldown;
                            }
                        }
                    }
                }

                // ---- TWITCH: hunt/lunge monsters jitter rapidly to feel wrong ----
                if (newState === 'hunt' || newState === 'lunge') {
                    m.userData.twitchTimer -= dt;
                    if (m.userData.twitchTimer <= 0) {
                        m.userData.twitchOffset.set(
                            (Math.random() - 0.5) * TUNING.stalkerTwitchMagnitude,
                            0,
                            (Math.random() - 0.5) * TUNING.stalkerTwitchMagnitude
                        );
                        m.userData.twitchTimer = TUNING.stalkerTwitchIntervalMin + Math.random() * TUNING.stalkerTwitchIntervalRange;
                    }
                } else {
                    m.userData.twitchOffset.multiplyScalar(0.88);
                }
                m.position.x += m.userData.twitchOffset.x;
                m.position.z += m.userData.twitchOffset.z;
            }

            m.position.y = (m.userData.kind === 'phantom') ? m.position.y : 0;

            // ---- ANIMATION: branch by kind ----
            if (m.userData.limbPhase === undefined) m.userData.limbPhase = 0;
            m.userData.limbPhase += dt * (3 + speed * 0.35);

            const refs = m.userData.refs;
            if (refs) {
                if (m.userData.kind === 'phantom') {
                    // v2.0: Phantom animation — handled by updatePhantom above (aura/eye/core pulse).
                    // Just add a subtle body sway here.
                    m.rotation.z = Math.sin(m.userData.limbPhase * 0.4) * 0.05;
                } else if (m.userData.kind === 'hound') {
                    // Hound: legs pump faster with speed, tail sways, eye brightens,
                    // tongue waggles, aura intensifies — all driven by currentSpeed.
                    const speedFrac = m.userData.currentSpeed / (m.userData.topSpeed || 12);
                    // Body roll (subtle bob at speed)
                    m.rotation.z = Math.sin(m.userData.limbPhase * 0.7) * 0.04 * speedFrac + m.rotation.z * 0.6;
                    m.rotation.x = Math.sin(m.userData.limbPhase) * 0.03;
                    // Legs gallop — phase offset gives a quadrupedal gait
                    for (let li = 0; li < refs.legs.length; li++) {
                        const leg = refs.legs[li];
                        leg.pivot.rotation.x = Math.sin(m.userData.limbPhase * (1 + speedFrac) + leg.phase) * (0.25 + speedFrac * 0.5);
                    }
                    // Tail sways faster at speed
                    if (refs.tailPivot) {
                        refs.tailPivot.rotation.y = Math.sin(m.userData.limbPhase * 1.3) * (0.2 + speedFrac * 0.4);
                        refs.tailPivot.rotation.z = Math.sin(m.userData.limbPhase * 0.8) * 0.15;
                    }
                    // Head bobs slightly with the gait
                    if (refs.headGroup) {
                        refs.headGroup.rotation.z = Math.sin(m.userData.limbPhase * 2) * 0.05;
                    }
                    // Tongue wags
                    if (refs.tongue) {
                        refs.tongue.rotation.y = Math.sin(m.userData.limbPhase * 2.5) * 0.2;
                    }
                    // Aura pulses with speed
                    const tNow = performance.now() * 0.005;
                    const auraPulse = 1 + Math.sin(tNow * (2 + speedFrac * 4)) * 0.1;
                    refs.aura.scale.set(auraPulse, auraPulse, auraPulse);
                    // Particle-effects setting scales aura opacity (off → invisible).
                    const auraVisMult = particleEffectsLevel === 'off' ? 0 :
                                        particleEffectsLevel === 'low' ? 0.4 : 1;
                    refs.aura.material.opacity = (0.1 + speedFrac * 0.35) * auraVisMult;
                    // Eye halo brightens with speed
                    if (refs.eyeHalo) {
                        refs.eyeHalo.material.opacity = 0.25 + speedFrac * 0.55 + Math.sin(tNow * 8) * 0.06;
                    }
                } else {
                    // Stalker: existing animation — body sway, arm swings, leg pumps,
                    // aura pulse, eye halos, head tilt, jaw open.
                    m.rotation.z = Math.sin(m.userData.limbPhase * 0.7) * 0.08 + m.userData.twitchOffset.x * 0.6;
                    m.rotation.x = Math.sin(m.userData.limbPhase) * 0.05 + m.userData.twitchOffset.z * 0.4;

                    // Arms swing; reach forward when lunging.
                    const swingAmount = (newState === 'lunge') ? 0.7 :
                                        (newState === 'hunt')  ? 0.5 : 0.25;
                    for (let ai = 0; ai < refs.arms.length; ai++) {
                        const arm = refs.arms[ai];
                        arm.pivot.rotation.x = Math.sin(m.userData.limbPhase + arm.phase) * swingAmount;
                        arm.pivot.rotation.z = (newState === 'lunge') ? -0.9 : arm.baseFwd * 0.4;
                        if (arm.forearmPivot) {
                            arm.forearmPivot.rotation.x = (newState === 'lunge') ? -0.6 :
                                                           Math.sin(m.userData.limbPhase * 1.3 + arm.phase) * 0.2;
                        }
                    }
                    // Legs pump.
                    for (let li = 0; li < refs.legs.length; li++) {
                        const leg = refs.legs[li];
                        leg.pivot.rotation.x = Math.sin(m.userData.limbPhase + leg.phase) * 0.35;
                        if (leg.shinPivot) {
                            leg.shinPivot.rotation.x = Math.sin(m.userData.limbPhase + leg.phase + 0.6) * 0.45;
                        }
                    }
                    // Aura pulses faster + brighter as rage rises.
                    const tNow = performance.now() * 0.005;
                    const pulseRate = 1 + m.userData.rage * 4;
                    const auraPulse = 1 + Math.sin(tNow * pulseRate) * 0.12;
                    refs.aura.scale.set(auraPulse, auraPulse, auraPulse);
                    // Particle-effects setting scales aura opacity (off → invisible).
                    const auraVisMult = particleEffectsLevel === 'off' ? 0 :
                                        particleEffectsLevel === 'low' ? 0.4 : 1;
                    refs.aura.material.opacity = (0.12 + m.userData.rage * 0.3) * auraVisMult;
                    // Eye halos brighten with rage.
                    const haloOpacity = 0.25 + m.userData.rage * 0.5 + Math.sin(tNow * 6) * 0.05;
                    refs.haloL.material.opacity = haloOpacity;
                    refs.haloR.material.opacity = haloOpacity;
                    // Head tilts toward player slightly when hunting (predatory lean).
                    if (refs.headGroup) {
                        refs.headGroup.rotation.x = (newState === 'hunt' || newState === 'lunge') ? 0.18 : 0.05;
                    }
                    // Teeth/jaw open wider when lunging.
                    if (refs.teethGroup) {
                        const targetOpen = (newState === 'lunge') ? 0.45 :
                                           (newState === 'hunt')  ? 0.2 : 0;
                        refs.teethGroup.rotation.x = (refs.teethGroup.rotation.x || 0) * 0.85 + targetOpen * 0.15;
                    }
                }
            }

            // ---- SOUND: kind-branched ----
            if (m.userData.groanTimer === undefined) m.userData.groanTimer = 0;
            m.userData.groanTimer += dt;
            if (m.userData.kind === 'phantom') {
                // v2.0: Phantom — ethereal hum + occasional ghostly whisper
                const phantomInterval = 3.5 + m.userData.rage * -2; // faster when enraged
                if (m.userData.groanTimer > phantomInterval + Math.random() * 1.5) {
                    m.userData.groanTimer = 0;
                    if (distSq < 130 * 130) {
                        // Eerie high-pitched hum
                        playTone(220 + m.userData.rage * 100, 'sine', 0.5, 0.08 + curseFactor * 0.04);
                        if (m.userData.rage > 0.5 && Math.random() < 0.4) playMonsterWhisper();
                    }
                }
            } else if (m.userData.kind === 'hound') {
                // Hound: deep baying pant that gets faster as it gets closer.
                // At high speed it pants rapidly; at low speed it bay-howls.
                const speedFrac = m.userData.currentSpeed / (m.userData.topSpeed || 12);
                const interval = 2.5 - speedFrac * 1.8; // 0.7s at full speed, 2.5s at min
                if (m.userData.groanTimer > interval + Math.random() * 0.5) {
                    m.userData.groanTimer = 0;
                    if (distSq < 140 * 140) {
                        if (speedFrac > 0.7) {
                            // Full sprint — fast harsh pants
                            playTone(80 + Math.random() * 20, 'sawtooth', 0.12, 0.08 + curseFactor * 0.04);
                            playNoise(0.15, 0.05, 400);
                        } else {
                            // Slow bay — long, low, mournful
                            playTone(45 + Math.random() * 15, 'sawtooth', 0.6, 0.1 + curseFactor * 0.05, 30);
                            playNoise(0.4, 0.04, 150);
                        }
                    }
                }
                // Occasional snarl when very close
                if (distSq < 30 * 30 && Math.random() < 0.01) {
                    playMonsterScream();
                }
            } else {
                // Stalker: state-dependent groans / whispers / screams
                const groanInterval = newState === 'lunge' ? 0.6 :
                                      newState === 'hunt'  ? 1.6 :
                                      newState === 'stalk' ? 3.5 : 6.0;
                if (m.userData.groanTimer > groanInterval + Math.random() * 1.5) {
                    m.userData.groanTimer = 0;
                    if (distSq < 130 * 130) {
                        if (newState === 'lunge')                  playMonsterScream();
                        else if (newState === 'stalk')             playMonsterWhisper();
                        else                                       playMonsterSound();
                    }
                }
            }

            // ---- CATCH: trigger jumpscare (shared by all kinds) ----
            // v2.0: shield blocks one catch (only for non-survival modes)
            // Requires: within horizontal catch radius AND not vertically
            // safe (player's feet must be within the monster's vertical
            // extent — see the verticalSafe check above).
            if (distSq < catchRadiusSq && !verticalSafe && !isJumpscareActive && !godModeEnabled) {
                // v2.0: shield check first
                if (isShieldActive()) {
                    activePowerup = null;
                    if (v2UI.shieldRing) v2UI.shieldRing.classList.remove('active');
                    unlockAchievement('shield_save');
                    showSubtitle('* SHIELD ABSORBED THE HIT! *', 2.0);
                    // Teleport this monster away to give breathing room
                    const angS = Math.random() * Math.PI * 2;
                    m.position.set(player.position.x + Math.cos(angS) * TUNING.monsterCatchRespawnDist, 0, player.position.z + Math.sin(angS) * TUNING.monsterCatchRespawnDist);
                    if (m.userData.kind === 'phantom') resetPhantomState(m);
                    triggerImpactFrame({ color: '#00ccff', duration: 320, hitstop: 80 });
                } else {
                isJumpscareActive = true;
                const jsOverlay = document.getElementById('jumpscare-overlay');

                document.exitPointerLock();
                isLocked = false;

                jsOverlay.style.display = 'flex';
                instructions.style.display = 'none';

                // Layered jumpscare audio: noise burst + dual detuned screech + sub drop.
                playNoise(0.9, 0.6, 250);
                playTone(45, 'sawtooth', 0.9, 0.5);
                playTone(90, 'sawtooth', 0.9, 0.3);
                playMonsterScream();

                trackTimeout(runScopedTimeout(() => {
                    jsOverlay.style.display = 'none';

                    if (gameMode === 'survival') {
                        endGame('caught');
                        return;
                    }

                    player.position.set(0, TUNING.spawnY, 0);
                    velocity.set(0, 0, 0);
                    isSliding = false;
                    slideCooldownTimer = 0;
                    isWallRunning = false;
                    yaw = 0;
                    pitch = 0;
                    camera.rotation.x = 0;
                    player.rotation.y = 0;

                    for (let m2i = 0; m2i < monsters.length; m2i++) {
                        const m2 = monsters[m2i];
                        const ang = Math.random() * Math.PI * 2;
                        m2.position.set(Math.cos(ang) * TUNING.monsterCatchRespawnDist + player.position.x, 0, Math.sin(ang) * TUNING.monsterCatchRespawnDist + player.position.z);
                        // Reset AI state for the appropriate kind so neither
                        // immediately re-catches the player after the teleport.
                        if (m2.userData.kind === 'hound') {
                            // Point the Hound back toward the player but kill its
                            // momentum — gives the player a brief window to escape.
                            m2.userData.currentSpeed = TUNING.houndResetSpeed;
                            const dxRP = player.position.x - m2.position.x;
                            const dzRP = player.position.z - m2.position.z;
                            const dRP = Math.sqrt(dxRP*dxRP + dzRP*dzRP) || 1;
                            m2.userData.heading.set(dxRP / dRP, 0, dzRP / dRP);
                        } else if (m2.userData.kind === 'phantom') {
                            // v2.0: Phantom reset
                            resetPhantomState(m2);
                        } else {
                            // Stalker: reset state machine + rage + cooldowns.
                            m2.userData.aiState = 'wander';
                            m2.userData.rage = 0;
                            m2.userData.lungeTimer = 0;
                            m2.userData.lungeCooldown = TUNING.stalkerLungeCooldownOnCatch;
                        }
                    }
                    
                    isJumpscareActive = false;
                    instructions.style.display = 'block';
                }, 1500));
                } // end of else (shield not active)
            }
        }

        // ---- PROXIMITY AUDIO + VISUAL: heartbeat + vignette pulse driven by
        //      the closest monster's distance to the player. Skipped during jumpscares.
        if (!isJumpscareActive && closestDistSqThisFrame !== Infinity) {
            const closestDist = Math.sqrt(closestDistSqThisFrame);
            // Heartbeat only triggers when something is within ~80m and hunting.
            if (closestDist < TUNING.monsterCatchProximityAudioDist) {
                const intensity = 1 - (closestDist / TUNING.monsterCatchProximityAudioDist); // 0..1
                playMonsterHeartbeat(intensity);
                // Vignette pulse: scale the existing #vignette element with rage color.
                if (vignette) {
                    const pulse = 0.5 + 0.5 * Math.sin(performance.now() * (0.008 + intensity * 0.018));
                    const v = Math.max(0, intensity * pulse);
                    vignette.style.boxShadow = `inset 0 0 ${120 + v * 220}px ${30 + v * 120}px rgba(140,0,0,${0.35 + v * 0.5})`;
                }
            } else if (vignette) {
                // Let the normal curse system take over again.
                vignette.style.boxShadow = '';
            }
        }
    }

    // Beat drop fog increase at 12 seconds in survival mode
    if (gameMode === 'survival' && monsterMusicSource && !beatDropTriggered && audioCtx) {
        const musicTime = audioCtx.currentTime - musicStartTime;
        if (musicTime >= 12.0) {
            // Mark beat drop occurred and play impact; don't force fog overrides
            beatDropTriggered = true;
            triggerImpactFrame({ color: '#ff1414', duration: 320, hitstop: 90 }); // beat-drop punch
            // Ensure fog is recalculated after the flat impact effect ends.
            // runScopedTimeout so this is dropped if the player quick-restarts
            // during the 360ms window (otherwise stale updateCurse could fight
            // the new run's curse state).
            trackTimeout(runScopedTimeout(() => {
                try { updateCurse(); } catch (e) { /* ignore */ }
            }, 360));
        }
    }

    // (No forced red fog tint here — curse-driven fog now applies consistently.)

    // Update debug path if enabled
    if (window.debug._pathEnabled) {
        if (!window.debug._pathPoints) window.debug._pathPoints = [];
        window.debug._pathPoints.push(player.position.clone());
        if (window.debug._pathPoints.length > 500) window.debug._pathPoints.shift();
        
        if (window.debug._pathLine) scene.remove(window.debug._pathLine);
        const geo = new THREE.BufferGeometry().setFromPoints(window.debug._pathPoints);
        const mat = new THREE.LineBasicMaterial({ color: 0x00ff00 });
        window.debug._pathLine = new THREE.Line(geo, mat);
        scene.add(window.debug._pathLine);
    }

    const moveStatus = isSliding ? 'SLIDING' : (isWallRunning ? 'WALL-RUN' : (isSprinting ? '⚡ SPRINT' : (isGrounded ? 'GROUNDED' : 'AIRBORNE')));
    const flashStatus = flashlightEnabled ? ' 🔦' : '';
    let uiContent = gameMode === 'survival' ? `[ ${moveStatus} ]${flashStatus}` : `Cubes: ${cubesCollected} / 20${flashStatus}<br>[ ${moveStatus} ]`;
    if (curseFactor > 0.7 && Math.random() < 0.005 && gameMode !== 'survival') {
        uiContent = `̷C̷u̷b̷e̷s̷: ${cubesCollected} / 20<br>[ ${moveStatus} ]`;
    }

    if (uiContent !== lastUIContent) {
        ui.innerHTML = uiContent;
        lastUIContent = uiContent;
    }

    // Update progress bar (hide in survival mode)
    const progressBar = document.getElementById('progress-bar-fill');
    if (progressBar) {
        if (gameMode === 'survival') {
            progressBar.style.width = '0%';
        } else {
            const progress = (cubesCollected / 20) * 100;
            progressBar.style.width = progress + '%';
            // Change color based on curse factor
            const r = Math.floor(THREE.MathUtils.lerp(0, 255, curseFactor));
            const g = Math.floor(THREE.MathUtils.lerp(255, 0, curseFactor));
            progressBar.style.background = `rgb(${r}, ${g}, 0)`;
        }
    }

    if (cubesCollected >= 5) {
        ui.style.color = `rgb(${Math.floor(THREE.MathUtils.lerp(0x35,0xff,curseFactor*2))},${Math.floor(THREE.MathUtils.lerp(0xfc,0x00,(curseFactor)*2))},${Math.floor(THREE.MathUtils.lerp(0x0d,0x00,curseFactor*2))})`;
    } //

    if (flashlightEnabled && flashlight) {
        const flickerBase = 3.5 - curseFactor * 1.2;
        if (curseFactor > 0.7 && Math.random() < 0.04) flashlight.intensity = 0.1;
        else flashlight.intensity = flickerBase * 0.6; // Reduced flashlight intensity
    }

    // Update sonic booms
    for (let i = sonicBooms.length - 1; i >= 0; i--) {
        const b = sonicBooms[i];
        b.userData.life += dt;
        const progress = b.userData.life / 0.5; // 0.5 second duration
        if (progress >= 1) {
            scene.remove(b);
            sonicBooms.splice(i, 1);
        } else {
            b.scale.setScalar(1 + progress * 15);
            b.material.opacity = 1 - progress;
        }
    }

    // Update dive-impact lightning bursts — expand outward then fade.
    for (let i = diveImpacts.length - 1; i >= 0; i--) {
        const g = diveImpacts[i];
        g.userData.life += dt;
        const progress = g.userData.life / 0.45; // 0.45 second duration
        if (progress >= 1) {
            scene.remove(g);
            g.children.forEach(c => { c.geometry.dispose(); c.material.dispose(); });
            diveImpacts.splice(i, 1);
        } else {
            const scale = 1 + progress * 2.2;
            g.scale.set(scale, 1, scale);
            const op = 1 - progress;
            g.children.forEach(c => { c.material.opacity = op; });
        }
    }

    skyDome.position.copy(player.position);

    renderer.render(scene, camera);
}

async function handleScoreSubmit() {
    const nameInput = document.getElementById('submit-name-input');
    const submitBtn = document.getElementById('submit-score-btn');
    const status = document.getElementById('submit-score-status');

    let name = (nameInput.value || '').trim();
    if (!name) name = 'PLAYER';
    name = name.replace(/[<>&]/g, '').slice(0, 16);
    nameInput.value = name;
    playerName = name;
    localStorage.setItem('redCubeName', playerName);

    submitBtn.disabled = true;
    submitBtn.textContent = 'SUBMITTING...';
    status.textContent = 'submitting...';

    const result = await submitScore(currentRunTime);

    if (result === 'tainted') {
        status.textContent = 'debug commands were used — not eligible for the leaderboard.';
        submitBtn.textContent = 'SUBMIT SCORE';
        submitBtn.disabled = false;
    } else if (result === 'implausible') {
        status.textContent = 'time flagged as implausible — not eligible for the leaderboard.';
        submitBtn.textContent = 'SUBMIT SCORE';
        submitBtn.disabled = false;
    } else if (Array.isArray(result)) {
        const rank = result.findIndex(e => e.name === playerName && e.time === currentRunTime) + 1;
        status.textContent = rank > 0
            ? `submitted — rank #${rank} on the ${gameMode}/${difficulty} board.`
            : `submitted to the ${gameMode}/${difficulty} board.`;
        submitBtn.textContent = 'SUBMITTED';
    } else {
        status.textContent = 'submission failed — backend unreachable, try again.';
        submitBtn.textContent = 'SUBMIT SCORE';
        submitBtn.disabled = false;
    }
}
window.handleScoreSubmit = handleScoreSubmit;

function endGame(outcome) {
    gameEnded = true;
    // v2.1: hide sandbox hint + close panel on game end
    try {
        updateSandboxHintVisibility();
        const panel = document.getElementById('sandbox-panel');
        if (panel) panel.style.display = 'none';
        sandboxPanelOpen = false;
    } catch (e) {}
    if (monsterMusicSource) {
        monsterMusicSource.stop();
        monsterMusicSource = null;
    }
    musicStartTime = 0;
    beatDropTriggered = false;
    document.getElementById('run-timer').style.display = 'none';
    winScreen.style.display = 'flex';
    document.exitPointerLock();
    const heading = document.querySelector('#win-screen h1');
    const sub = document.getElementById('win-sub');
    const endings = [
        "you were warned.",
        "they followed you home.",
        "none of this was real.",
        "the cubes remember you.",
        "close the tab. please.",
    ];
    const flavor = endings[Math.floor(Math.random()*endings.length)];
    currentRunTime = gameTime;

    if (outcome === 'caught') {
        heading.textContent = 'THEY GOT YOU';
        sub.textContent = `survived ${formatTime(currentRunTime)} — ${flavor}`;
    } else if (gameMode === 'timeattack' || gameMode === 'rush') {
        heading.textContent = 'CUBES COLLECTED';
        sub.textContent = `time: ${formatTime(currentRunTime)} — ${flavor}`;
        // v2.0: Pure run achievement (win without being caught)
        unlockAchievement('no_damage');
    } else if (gameMode === 'zen') {
        heading.textContent = 'PEACEFUL';
        sub.textContent = `${formatTime(currentRunTime)} of zen — ${flavor}`;
        unlockAchievement('no_damage');
    } else if (gameMode === 'sandbox') {
        heading.textContent = 'SANDBOX SESSION ENDED';
        sub.textContent = `${formatTime(currentRunTime)} of free play — ${flavor}`;
    } else {
        heading.textContent = 'YOU COLLECTED THEM ALL';
        sub.textContent = flavor;
        unlockAchievement('no_damage');
    }

    const nameInput = document.getElementById('submit-name-input');
    const submitBtn = document.getElementById('submit-score-btn');
    const status = document.getElementById('submit-score-status');
    nameInput.value = playerName || '';
    submitBtn.disabled = false;
    submitBtn.textContent = 'SUBMIT SCORE';

    if (gameMode === 'sandbox') {
        status.textContent = 'sandbox mode — no leaderboard. open SETTINGS → TUNING to edit any game parameter, or press P for the control panel.';
        document.getElementById('submit-score-row').style.display = 'none';
    } else if (runTainted) {
        status.textContent = 'debug commands were used — this run is not eligible for the leaderboard.';
        document.getElementById('submit-score-row').style.display = 'none';
    } else if (!isTimePlausible(currentRunTime)) {
        status.textContent = 'time flagged as implausible — not eligible for the leaderboard.';
        document.getElementById('submit-score-row').style.display = 'none';
    } else {
        document.getElementById('submit-score-row').style.display = 'flex';
        status.textContent = `enter a name and submit to the ${gameMode}/${difficulty} board (${gameMode === 'survival' ? 'higher is better' : 'lower is better'})`;
    }

    if (audioCtx) {
        const o = audioCtx.createOscillator();
        const g = audioCtx.createGain();
        o.type = 'sawtooth';
        o.frequency.setValueAtTime(40, audioCtx.currentTime);
        o.frequency.linearRampToValueAtTime(15, audioCtx.currentTime + 4);
        g.gain.setValueAtTime(0.3, audioCtx.currentTime);
        g.gain.linearRampToValueAtTime(0.0, audioCtx.currentTime + 5);
        o.connect(g); g.connect(audioCtx.destination);
        o.start(); o.stop(audioCtx.currentTime + 5);
    }
}

window.addEventListener('resize', () => {
    camera.aspect = innerWidth / innerHeight;
    camera.updateProjectionMatrix();
    renderer.setSize(innerWidth, innerHeight);
    // Re-apply the performance preset's pixel ratio (in case devicePixelRatio
    // changed, e.g. window dragged between monitors).
