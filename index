// ===================== DIVE IMPACT: RADIAL LIGHTNING =====================
// Fired when the player slams into a platform/ground from a dive (regular
// or power dive). Spawns a burst of jagged red+black "lightning" lines
// radiating outward from the impact point, flat against the ground, that
// quickly expand and fade — replaces the old on-screen "POWER DIVE!" text
// with a grounded, physical-feeling impact effect.
const diveImpacts = [];
function _buildBoltRibbon(pts, widthFn, color, opts = {}) {
    // Builds a flat triangle-strip "ribbon" mesh that follows pts, with a
    // width at each point given by widthFn(t). This is how we fake a THICK
    // lightning bolt — THREE.Line ignores linewidth in WebGL, but a ribbon
    // mesh can be as thick as we want and tapers naturally toward the tip.
    const positions = [];
    const indices = [];
    const n = pts.length;
    for (let i = 0; i < n; i++) {
        const t = i / (n - 1);
        // Perpendicular direction (in the XZ plane) to the bolt's local travel dir.
        const prev = pts[Math.max(0, i - 1)];
        const next = pts[Math.min(n - 1, i + 1)];
        let dx = next.x - prev.x, dz = next.z - prev.z;
        const len = Math.hypot(dx, dz) || 1;
        dx /= len; dz /= len;
        const px = -dz, pz = dx; // perpendicular
        const w = widthFn(t);
        positions.push(pts[i].x + px * w, 0, pts[i].z + pz * w);
        positions.push(pts[i].x - px * w, 0, pts[i].z - pz * w);
    }
    for (let i = 0; i < n - 1; i++) {
        const a = i * 2, b = i * 2 + 1, c = i * 2 + 2, d = i * 2 + 3;
        indices.push(a, b, c, b, d, c);
    }
    const geo = new THREE.BufferGeometry();
    geo.setAttribute('position', new THREE.Float32BufferAttribute(positions, 3));
    geo.setIndex(indices);
    const mat = new THREE.MeshBasicMaterial({
        color,
        transparent: true,
        opacity: 1,
        side: THREE.DoubleSide,
        depthWrite: false,
        blending: opts.additive ? THREE.AdditiveBlending : THREE.NormalBlending
    });
    return new THREE.Mesh(geo, mat);
}

function triggerDiveImpact(pos, intensity = 1) {
    if (particleEffectsLevel === 'off') return;

    const group = new THREE.Group();
    group.position.copy(pos);
    group.position.y += 0.05; // sit just above the ground to avoid z-fighting

    const boltCount = particleEffectsLevel === 'low' ? 6 : 10;
    for (let i = 0; i < boltCount; i++) {
        const angle = (i / boltCount) * Math.PI * 2 + Math.random() * 0.3;

        // Build a jagged lightning-bolt path radiating outward from center.
        const segCount = 5 + Math.floor(Math.random() * 3);
        const len = (1.5 + Math.random() * 1.3) * intensity;
        const dirX = Math.cos(angle), dirZ = Math.sin(angle);
        const pts = [];
        for (let s = 0; s <= segCount; s++) {
            const t = s / segCount;
            const jitter = (Math.random() - 0.5) * 0.4 * (1 - t * 0.5);
            const px = dirX * len * t + (-dirZ * jitter);
            const pz = dirZ * len * t + (dirX * jitter);
            pts.push(new THREE.Vector3(px, 0, pz));
        }

        // One Piece "red lightning" look: a wide, glowing red outer bolt
        // with a thin black core burned through the middle — taper both
        // toward the tip so it reads as a jagged crack rather than a blob.
        const baseW = (0.16 + Math.random() * 0.08) * intensity;
        const redRibbon = _buildBoltRibbon(pts, t => baseW * (1 - t * 0.65), 0xff1100, { additive: true });
        const blackRibbon = _buildBoltRibbon(pts, t => baseW * 0.4 * (1 - t * 0.7), 0x000000, { additive: false });
        redRibbon.renderOrder = 1;
        blackRibbon.renderOrder = 2; // draw the black core on top of the red glow
        group.add(redRibbon);
        group.add(blackRibbon);
    }

    group.userData.life = 0;
    scene.add(group);
    diveImpacts.push(group);
}

function createStalker() {
    // === THE STALKER ===
    // A tall, gaunt, multi-limbed horror: elongated torso, skull-like head,
    // hollow glowing eyes, jagged teeth, four reaching arms with claws,
    // backward-bent animal legs, and a pulsing dark aura.
    // AI: state-machine (wander → stalk → hunt → lunge) with rage meter.
    const group = new THREE.Group();
    const S = TUNING.stalkerScaleMin + Math.random() * TUNING.stalkerScaleRange;

    // ----- materials (cached per-monster so we can modulate them at runtime) -----
    const fleshMat = new THREE.MeshPhongMaterial({
        color: 0x0a0306, emissive: 0x180004, emissiveIntensity: 0.5, shininess: 4
    });
    const boneMat = new THREE.MeshPhongMaterial({
        color: 0xb8a08a, emissive: 0x1a0e00, emissiveIntensity: 0.35, shininess: 90
    });
    const eyeMat = new THREE.MeshBasicMaterial({ color: 0xff0000 });
    const socketMat = new THREE.MeshBasicMaterial({ color: 0x000000 });
    const veinMat = new THREE.MeshBasicMaterial({ color: 0x550000 });

    // ----- TORSO: elongated tapered cone, hunched forward -----
    const torso = new THREE.Mesh(new THREE.CylinderGeometry(S * 0.32, S * 0.62, S * 2.4, 8), fleshMat);
    torso.position.y = S * 2.5;
    torso.rotation.x = 0.15; // slight hunch
    group.add(torso);

    // ----- ribcage: three thin torus rings, exposed bone -----
    const ribs = [];
    for (let i = 0; i < 3; i++) {
        const rib = new THREE.Mesh(new THREE.TorusGeometry(S * (0.45 - i * 0.05), S * 0.035, 4, 10), veinMat);
        rib.position.y = S * (2.0 + i * 0.45);
        rib.rotation.x = Math.PI / 2;
        group.add(rib);
        ribs.push(rib);
    }

    // ----- spine bumps down the back -----
    for (let i = 0; i < 5; i++) {
        const spike = new THREE.Mesh(new THREE.ConeGeometry(S * 0.06, S * 0.25, 4), boneMat);
        spike.position.set(0, S * (3.4 - i * 0.4), -S * 0.3);
        spike.rotation.x = -0.6;
        group.add(spike);
    }

    // ----- HEAD: elongated skull, pointed forward -----
    const headGroup = new THREE.Group();
    headGroup.position.y = S * 4.1;
    group.add(headGroup);

    const skull = new THREE.Mesh(new THREE.ConeGeometry(S * 0.42, S * 1.1, 6), fleshMat);
    skull.rotation.x = Math.PI / 2; // point forward
    skull.position.z = S * 0.2;
    headGroup.add(skull);

    // jaw (smaller cone below)
    const jaw = new THREE.Mesh(new THREE.ConeGeometry(S * 0.32, S * 0.55, 6), fleshMat);
    jaw.rotation.x = -Math.PI / 2;
    jaw.position.set(0, -S * 0.15, S * 0.15);
    headGroup.add(jaw);

    // ----- EYE SOCKETS: deep black holes -----
    const socketL = new THREE.Mesh(new THREE.SphereGeometry(S * 0.17, 10, 10), socketMat);
    socketL.position.set(-S * 0.2, S * 0.05, S * 0.42);
    headGroup.add(socketL);
    const socketR = socketL.clone(); socketR.position.x = S * 0.2; headGroup.add(socketR);

    // ----- GLOWING EYES: bright red, sit just inside the sockets -----
    const eyeL = new THREE.Mesh(new THREE.SphereGeometry(S * 0.09, 10, 10), eyeMat);
    eyeL.position.set(-S * 0.2, S * 0.05, S * 0.5);
    headGroup.add(eyeL);
    const eyeR = eyeL.clone(); eyeR.position.x = S * 0.2; headGroup.add(eyeR);

    // eye-glow halos (transparent red spheres around eyes)
    const haloMatL = new THREE.MeshBasicMaterial({ color: 0xff0000, transparent: true, opacity: 0.35, depthWrite: false });
    const haloL = new THREE.Mesh(new THREE.SphereGeometry(S * 0.16, 10, 10), haloMatL);
    haloL.position.copy(eyeL.position);
    headGroup.add(haloL);
    const haloR = new THREE.Mesh(new THREE.SphereGeometry(S * 0.16, 10, 10), haloMatL.clone());
    haloR.position.copy(eyeR.position);
    headGroup.add(haloR);

    // ----- TEETH: jagged cones lining the jaw -----
    const teethGroup = new THREE.Group();
    const numTeeth = 9;
    for (let i = 0; i < numTeeth; i++) {
        const tooth = new THREE.Mesh(new THREE.ConeGeometry(S * 0.045, S * 0.22, 4), boneMat);
        tooth.position.set((i - (numTeeth - 1) / 2) * S * 0.075, -S * 0.05, S * 0.55);
        tooth.rotation.x = Math.PI; // point down
        teethGroup.add(tooth);
    }
    headGroup.add(teethGroup);

    // ----- ARMS: four long, thin, multi-jointed reaching arms -----
    const armConfigs = [
        { side: -1, height:  S * 3.1, length: S * 2.1, fwd: -0.25 },
        { side:  1, height:  S * 3.1, length: S * 2.1, fwd:  0.25 },
        { side: -1, height:  S * 2.4, length: S * 1.9, fwd: -0.45 },
        { side:  1, height:  S * 2.4, length: S * 1.9, fwd:  0.45 }
    ];
    const arms = [];
    armConfigs.forEach((cfg, i) => {
        const pivot = new THREE.Group();
        pivot.position.set(cfg.side * S * 0.4, cfg.height, 0);
        group.add(pivot);

        // upper arm
        const upper = new THREE.Mesh(new THREE.CylinderGeometry(S * 0.055, S * 0.04, cfg.length, 5), fleshMat);
        upper.position.y = -cfg.length / 2;
        pivot.add(upper);

        // elbow joint
        const elbow = new THREE.Mesh(new THREE.SphereGeometry(S * 0.06, 6, 6), boneMat);
        elbow.position.y = -cfg.length;
        pivot.add(elbow);

        // forearm (bent forward)
        const forearmPivot = new THREE.Group();
        forearmPivot.position.y = -cfg.length;
        pivot.add(forearmPivot);
        const forearm = new THREE.Mesh(new THREE.CylinderGeometry(S * 0.04, S * 0.025, S * 1.2, 5), fleshMat);
        forearm.position.set(0, -S * 0.6, S * 0.3);
        forearm.rotation.x = -0.7;
        forearmPivot.add(forearm);

        // claw fingers (3 long sharp claws)
        const clawGroup = new THREE.Group();
        clawGroup.position.set(0, -S * 1.1, S * 0.6);
        forearmPivot.add(clawGroup);
        for (let c = 0; c < 3; c++) {
            const claw = new THREE.Mesh(new THREE.ConeGeometry(S * 0.035, S * 0.5, 4), boneMat);
            claw.position.set((c - 1) * S * 0.07, -S * 0.25, 0);
            claw.rotation.x = Math.PI - 0.3;
            clawGroup.add(claw);
        }

        arms.push({ pivot, forearmPivot, baseFwd: cfg.fwd, phase: i * Math.PI * 0.5 });
    });

    // ----- LEGS: backward-bent, animal-like (digitigrade) -----
    const legs = [];
    const legConfigs = [{ side: -1 }, { side: 1 }];
    legConfigs.forEach((cfg, i) => {
        const pivot = new THREE.Group();
        pivot.position.set(cfg.side * S * 0.28, S * 1.3, 0);
        group.add(pivot);

        const thigh = new THREE.Mesh(new THREE.CylinderGeometry(S * 0.09, S * 0.06, S * 1.3, 6), fleshMat);
        thigh.position.set(0, -S * 0.65, 0);
        thigh.rotation.z = cfg.side * 0.25;
        pivot.add(thigh);

        const knee = new THREE.Mesh(new THREE.SphereGeometry(S * 0.07, 6, 6), boneMat);
        knee.position.set(cfg.side * S * 0.2, -S * 1.3, 0);
        pivot.add(knee);

        const shinPivot = new THREE.Group();
        shinPivot.position.set(cfg.side * S * 0.2, -S * 1.3, 0);
        pivot.add(shinPivot);
        const shin = new THREE.Mesh(new THREE.CylinderGeometry(S * 0.05, S * 0.025, S * 1.2, 6), fleshMat);
        shin.position.set(0, -S * 0.6, -S * 0.1);
        shin.rotation.x = 0.3;
        shinPivot.add(shin);

        // foot claw
        const foot = new THREE.Mesh(new THREE.ConeGeometry(S * 0.06, S * 0.4, 4), boneMat);
        foot.position.set(0, -S * 1.2, S * 0.1);
        foot.rotation.x = Math.PI / 2;
        shinPivot.add(foot);

        legs.push({ pivot, shinPivot, phase: i * Math.PI });
    });

    // ----- DARK AURA: pulsing transparent sphere around the torso -----
    const auraMat = new THREE.MeshBasicMaterial({
        color: 0x660005, transparent: true, opacity: 0.18,
        side: THREE.BackSide, depthWrite: false
    });
    const aura = new THREE.Mesh(new THREE.SphereGeometry(S * 2.6, 12, 12), auraMat);
    aura.position.y = S * 2.6;
    group.add(aura);

    // ----- spawn position (far from player) -----
    const angle = Math.random() * Math.PI * 2;
    const dist = TUNING.monsterSpawnDistMin + Math.random() * TUNING.monsterSpawnDistRange;
    group.position.set(Math.cos(angle) * dist, 0, Math.sin(angle) * dist);

    group.userData = {
        kind: 'stalker',
        scale: S,
        limbPhase: Math.random() * Math.PI * 2,
        groanTimer: Math.random() * 4,
        stunTimer: 0,
        // ---- AI state ----
        aiState: 'wander',
        stateTimer: 0,
        wanderTarget: new THREE.Vector3(
            group.position.x + (Math.random() - 0.5) * 100,
            0,
            group.position.z + (Math.random() - 0.5) * 100
        ),
        nextWanderUpdate: 3 + Math.random() * 4,
        stalkDir: Math.random() < 0.5 ? 1 : -1,
        rage: 0,                 // 0..1, builds while seeing the player
        lungeTimer: 0,
        lungeCooldown: 0,
        twitchTimer: 0,
        twitchOffset: new THREE.Vector3(),
        // ---- refs for animation ----
        refs: { aura, arms, legs, eyeL, eyeR, haloL, haloR, headGroup, teethGroup, ribs }
    };

    group.visible = false;
    scene.add(group);
    monsters.push(group);
    createMonsterBeacon(); // red tracking beacon for this Stalker
    return group;
}

function createHound() {
    // === THE HOUND ===
    // A pale quadrupedal beast that ALWAYS knows where the player is.
    // Momentum-based AI: accelerates while running in a straight line,
    // decelerates hard when forced to turn. Visually distinct from the
    // Stalker — low-slung quadruped, single cyclops eye, lolling tongue,
    // bony ribs and spine, pale hide vs. the Stalker's dark red flesh.
    const group = new THREE.Group();
    const S = TUNING.houndScaleMin + Math.random() * TUNING.houndScaleRange;

    // ----- materials -----
    const hideMat = new THREE.MeshPhongMaterial({
        color: 0x9a8c78, emissive: 0x140c08, emissiveIntensity: 0.4, shininess: 8
    });
    const boneMat = new THREE.MeshPhongMaterial({
        color: 0xe0d4b8, emissive: 0x1a0e00, emissiveIntensity: 0.35, shininess: 90
    });
    const eyeMat  = new THREE.MeshBasicMaterial({ color: 0xff2200 });
    const eyeHaloMat = new THREE.MeshBasicMaterial({
        color: 0xff3300, transparent: true, opacity: 0.45, depthWrite: false
    });
    const tongueMat = new THREE.MeshPhongMaterial({
        color: 0x4a0008, emissive: 0x300000, emissiveIntensity: 0.7
    });

    // ----- BODY: low, horizontal, elongated -----
    const body = new THREE.Mesh(new THREE.BoxGeometry(S * 2.2, S * 1.0, S * 1.0), hideMat);
    body.position.y = S * 1.4;
    group.add(body);

    // ----- exposed ribcage (top of body) -----
    for (let i = 0; i < 4; i++) {
        const rib = new THREE.Mesh(new THREE.TorusGeometry(S * (0.5 - i * 0.05), S * 0.04, 4, 8), boneMat);
        rib.position.set(S * (0.6 - i * 0.4), S * 1.7, 0);
        rib.rotation.y = Math.PI / 2;
        group.add(rib);
    }

    // ----- spine spikes -----
    for (let i = 0; i < 5; i++) {
        const spike = new THREE.Mesh(new THREE.ConeGeometry(S * 0.08, S * 0.4, 4), boneMat);
        spike.position.set(S * (0.8 - i * 0.4), S * 2.0, 0);
        spike.rotation.x = -0.2;
        group.add(spike);
    }

    // ----- HEAD: forward wedge with a single huge eye -----
    const headGroup = new THREE.Group();
    headGroup.position.set(S * 1.3, S * 1.5, 0);
    group.add(headGroup);

    const skull = new THREE.Mesh(new THREE.ConeGeometry(S * 0.55, S * 1.4, 6), hideMat);
    skull.rotation.z = -Math.PI / 2; // point forward (+x)
    headGroup.add(skull);

    // cyclops eye
    const eye = new THREE.Mesh(new THREE.SphereGeometry(S * 0.22, 14, 14), eyeMat);
    eye.position.set(S * 0.55, 0, 0);
    headGroup.add(eye);
    const eyeHalo = new THREE.Mesh(new THREE.SphereGeometry(S * 0.36, 14, 14), eyeHaloMat);
    eyeHalo.position.copy(eye.position);
    headGroup.add(eyeHalo);
    // bony eye socket ring
    const socket = new THREE.Mesh(new THREE.TorusGeometry(S * 0.28, S * 0.06, 6, 12), boneMat);
    socket.position.copy(eye.position);
    socket.rotation.y = Math.PI / 2;
    headGroup.add(socket);

    // ----- jaws: top + bottom fangs -----
    for (let side = -1; side <= 1; side += 2) {
        for (let i = 0; i < 3; i++) {
            const fang = new THREE.Mesh(new THREE.ConeGeometry(S * 0.06, S * 0.3, 4), boneMat);
            fang.position.set(S * 1.1, side * S * 0.12, (i - 1) * S * 0.18);
            fang.rotation.z = side > 0 ? Math.PI : 0;
            headGroup.add(fang);
        }
    }

    // ----- lolling tongue -----
    const tongue = new THREE.Mesh(new THREE.BoxGeometry(S * 0.6, S * 0.08, S * 0.25), tongueMat);
    tongue.position.set(S * 1.4, -S * 0.05, 0);
    headGroup.add(tongue);

    // ----- LEGS: 4 short thick legs -----
    const legs = [];
    const legConfigs = [
        { x:  S * 0.7, z: -S * 0.5, phase: 0 },
        { x:  S * 0.7, z:  S * 0.5, phase: Math.PI },
        { x: -S * 0.7, z: -S * 0.5, phase: Math.PI * 0.5 },
        { x: -S * 0.7, z:  S * 0.5, phase: Math.PI * 1.5 }
    ];
    legConfigs.forEach((cfg) => {
        const pivot = new THREE.Group();
        pivot.position.set(cfg.x, S * 1.2, cfg.z);
        group.add(pivot);
        const upper = new THREE.Mesh(new THREE.CylinderGeometry(S * 0.1, S * 0.07, S * 1.2, 6), hideMat);
        upper.position.y = -S * 0.6;
        pivot.add(upper);
        const paw = new THREE.Mesh(new THREE.SphereGeometry(S * 0.12, 6, 6), boneMat);
        paw.position.y = -S * 1.2;
        pivot.add(paw);
        legs.push({ pivot, phase: cfg.phase });
    });

    // ----- TAIL: tapered cone trailing behind -----
    const tailPivot = new THREE.Group();
    tailPivot.position.set(-S * 1.1, S * 1.5, 0);
    group.add(tailPivot);
    const tail = new THREE.Mesh(new THREE.ConeGeometry(S * 0.18, S * 1.8, 6), hideMat);
    tail.position.set(-S * 0.9, 0, 0);
    tail.rotation.z = Math.PI / 2;
    tailPivot.add(tail);

    // ----- AURA: pale grey, pulses with current speed -----
    const auraMat = new THREE.MeshBasicMaterial({
        color: 0x886644, transparent: true, opacity: 0.12,
        side: THREE.BackSide, depthWrite: false
    });
    const aura = new THREE.Mesh(new THREE.SphereGeometry(S * 2.0, 12, 12), auraMat);
    aura.position.y = S * 1.4;
    group.add(aura);

    // ----- spawn far from player -----
    const angle = Math.random() * Math.PI * 2;
    const dist = TUNING.monsterSpawnDistMin + Math.random() * TUNING.monsterSpawnDistRange;
    group.position.set(Math.cos(angle) * dist, 0, Math.sin(angle) * dist);

    group.userData = {
        kind: 'hound',
        scale: S,
        limbPhase: Math.random() * Math.PI * 2,
        groanTimer: Math.random() * 4,
        stunTimer: 0,
        // ---- Hound AI: always hunts, momentum-based ----
        // heading  = current travel direction (unit vector)
        // currentSpeed = scalar speed along heading
        // The hound always knows where the player is. It accelerates while
        // its heading aligns with the direction to the player, and loses
        // speed proportional to how much it has to turn.
        heading: new THREE.Vector3(Math.cos(angle), 0, Math.sin(angle)),
        currentSpeed: TUNING.houndSpeedMin,
        topSpeed: 12.0, // updated each frame from difficulty
        // ---- refs for animation ----
        refs: { aura, eye, eyeHalo, legs, tailPivot, headGroup, tongue }
    };

    group.visible = false;
    scene.add(group);
    monsters.push(group);
    createMonsterBeacon(); // red tracking beacon for this Hound
    return group;
}

