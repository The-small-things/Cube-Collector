   WIN SCREEN
   ============================================================ */
#win-screen {
    flex-direction: column;
    gap: 14px;
    text-align: center;
}
#win-screen > * { width: 100%; max-width: 520px; }
#win-screen h1 {
    font-family: var(--font-display);
    font-size: 42px;
    color: #efe0e0;
    letter-spacing: .06em;
    line-height: 1.05;
    text-shadow: 0 0 16px rgba(209,17,36,.5);
    animation: title-flicker 6s linear infinite;
}
#win-screen h1 .red {
    color: var(--red-bright);
    text-shadow: 0 0 14px rgba(255,42,60,.9), 0 0 32px rgba(209,17,36,.7);
}
#win-screen #win-sub {
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--text-dim);
    letter-spacing: .04em;
    line-height: 1.6;
}
#win-screen #submit-score-row {
    display: flex;
    gap: 5px;
    justify-content: center;
}
#win-screen #submit-name-input {
    flex: 1;
    max-width: 220px;
    background: rgba(8,4,6,.8);
    border: 1px solid var(--line-strong);
    padding: 7px 10px;
    color: #f0d8d8;
    font-family: var(--font-mono);
    font-size: 16px;
    letter-spacing: .08em;
    transition: border-color .15s var(--ease), box-shadow .15s var(--ease);
}
#win-screen #submit-name-input::placeholder { color: var(--text-faint); letter-spacing: .14em; }
#win-screen #submit-name-input:focus {
    outline: none;
    border-color: var(--red);
    box-shadow: 0 0 10px rgba(209,17,36,.4);
}
#win-screen #submit-score-status {
    font-family: var(--font-mono);
    font-size: 14px;
    color: var(--text-muted);
    min-height: 18px;
    letter-spacing: .06em;
}
#win-screen .win-actions {
    display: flex;
    gap: 6px;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: 6px;
}

/* ============================================================
   JUMPSCARE OVERLAY
   ============================================================ */
#jumpscare-overlay {
    position: fixed;
    inset: 0;
    background: #000;
    z-index: 1000;
    display: none;
    align-items: center;
    justify-content: center;
}
#jumpscare-overlay[style]:not([style*="display: none"]):not([style*="display:none"]) {
    display: flex !important;
}
#jumpscare-overlay::before {
    content: "CAUGHT";
    font-family: var(--font-display);
    font-size: 120px;
    font-weight: 700;
    color: var(--red-bright);
    text-transform: uppercase;
    letter-spacing: .1em;
    text-shadow: 0 0 24px rgba(255,42,60,1), 0 0 60px rgba(209,17,36,.9);
    animation: jumpscare-shake .12s steps(2) infinite;
}
@keyframes jumpscare-shake {
    0%   { transform: translate(-3px,2px) scale(1.02); }
    100% { transform: translate(3px,-2px) scale(1); }
}

/* ============================================================
   CUSTOM RANGE INPUTS (blood-red track + glowing thumb)
   ============================================================ */
input[type="range"] {
    -webkit-appearance: none;
    appearance: none;
    width: 100%;
    height: 6px;
    background: rgba(209,17,36,.15);
    border: 1px solid var(--line-strong);
    outline: none;
    cursor: pointer;
}
input[type="range"]::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 14px; height: 14px;
    background: linear-gradient(180deg, var(--red-bright), var(--red-deep));
    border: 1px solid #fff;
    box-shadow: 0 0 10px rgba(255,42,60,.8);
    cursor: pointer;
    transition: box-shadow .15s var(--ease), transform .12s var(--ease);
}
input[type="range"]::-webkit-slider-thumb:hover { transform: scale(1.2); box-shadow: 0 0 16px rgba(255,42,60,1); }
input[type="range"]::-moz-range-thumb {
    width: 14px; height: 14px;
    background: linear-gradient(180deg, var(--red-bright), var(--red-deep));
    border: 1px solid #fff;
    box-shadow: 0 0 10px rgba(255,42,60,.8);
    cursor: pointer;
}
input[type="range"]::-moz-range-track {
    height: 6px;
    background: rgba(209,17,36,.15);
    border: 1px solid var(--line-strong);
}

/* Text inputs fallback */
input[type="text"], input[type="number"] {
    font-family: var(--font-mono);
}

/* ============================================================
   ANIMATIONS / KEYFRAMES (names preserved for JS references)
   ============================================================ */
@keyframes rc-impact-flash {
    0%   { opacity: 0; }
    20%  { opacity: 0.85; }
    100% { opacity: 0; }
}
@keyframes rc-impact-lines {
    0%   { opacity: 0; }
    25%  { opacity: 0.7; }
    100% { opacity: 0; }
}
@keyframes rc-canvas-shake {
    0%, 100% { transform: translate(0, 0); }
    25%  { transform: translate(-4px, 2px); }
    50%  { transform: translate(3px, -3px); }
    75%  { transform: translate(-2px, 4px); }
}
@keyframes pulse-screen {
    0%, 100% { background: #0a0608; }
    50%      { background: #14080c; }
}
@keyframes pulse-bar {
    0%, 100% { filter: none; }
    50%      { filter: none; }
}

/* ============================================================
   RESPONSIVE
   ============================================================ */
@media (max-width: 880px) {
    #instructions {
        grid-template-columns: 1fr;
        gap: 12px;
        padding: 14px;
    }
    #instructions .brand-col h2 { font-size: 40px; }
    #instructions .mode-grid { grid-template-columns: repeat(2, 1fr); }
    #instructions .diff-grid { grid-template-columns: repeat(3, 1fr); }
    #instructions .controls-grid { grid-template-columns: 1fr; }

    #settings-menu .settings-shell {
        grid-template-columns: 1fr;
        max-height: 90vh;
        gap: 10px;
        padding: 12px;
    }
    #settings-menu .settings-sidebar {
        flex-direction: row;
        align-items: center;
        border-right: none;
        border-bottom: 1px solid var(--line-strong);
        padding-right: 0;
        padding-bottom: 8px;
        gap: 6px;
    }
    #settings-menu .settings-tabs {
        flex-direction: row;
        flex-wrap: wrap;
    }
    #settings-menu .settings-tab-btn {
        padding: 8px 10px;
        min-height: 36px;
        font-size: 10px;
    }
    #settings-menu .settings-topbar {
        flex-wrap: wrap;
        gap: 8px;
    }
    #settings-menu .settings-topbar h2 { font-size: 18px; }
    #settings-menu .settings-back-btn {
        font-size: 11px;
        padding: 9px 14px;
        min-height: 36px;
    }

    #sandbox-panel {
        width: calc(100% - 20px);
        max-height: 70vh;
        right: 10px;
        left: 10px;
        top: 64px;
    }

    #powerup-indicator { width: 160px; top: 64px; left: 10px; }
    #run-timer { padding: 3px 8px; }
    #run-timer #run-timer-value { font-size: 18px; }
    #achievement-toast { width: calc(100% - 20px); max-width: 270px; right: 10px; }

    .ability-card { width: 150px; right: 10px; }
    #speed-container { width: 158px; left: 10px; bottom: 10px; }
    #minimap-container { top: 64px; right: 10px; }
    #minimap-canvas { width: 120px; height: 120px; }

    #ui { top: 64px; }
    #progress-bar-container { width: 160px; }
    #combo-meter { top: 54px; }
    #curse-msg { font-size: 24px; }
    #jumpscare-overlay::before { font-size: 72px; }
}

@media (max-width: 480px) {
    #instructions .menu-actions { flex-direction: column; }
    #instructions .mode-grid { grid-template-columns: 1fr 1fr; }
    #instructions .diff-grid { grid-template-columns: 1fr 1fr; }
    .ability-card { width: 128px; padding: 4px 7px; }
    #speed-container { width: 128px; }
    #win-screen .win-actions { flex-direction: column; }
    #win-screen #submit-score-row { flex-direction: column; align-items: stretch; }
    #win-screen h1 { font-size: 32px; }
    #jumpscare-overlay::before { font-size: 54px; }
}

/* Short / landscape viewports — shrink and tuck the minimap so it can't
   collide with the ability-card stack anchored to the bottom-right. */
@media (max-height: 480px) {
    #minimap-container { top: 50px; }
    #minimap-canvas { width: 90px; height: 90px; }
    .ability-card { width: 140px; padding: 4px 8px; }
    #timeslow-ui   { bottom: 6px; }
    #power-dive-ui { bottom: 42px; }
    #ability-ui    { bottom: 78px; }
}
