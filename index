// Switch between the KEYBINDINGS and ADVANCED panels in the settings menu.
// Also restyles the active tab button so the user can see which panel is shown.
function showSettingsTab(tab) {
    const tabs = ['keybinds', 'advanced', 'tuning'];
    if (!tabs.includes(tab)) tab = 'keybinds';
    for (const t of tabs) {
        const panel = document.getElementById('tab-' + t);
        if (panel) panel.style.display = (t === tab) ? 'block' : 'none';
        const btn = document.querySelector(`.settings-tab-btn[data-tab="${t}"]`);
        if (btn) {
            btn.classList.toggle('active', t === tab);
        }
    }
}

document.addEventListener('mousemove', e => {
    if (!isLocked || isJumpscareActive) return;
    let sens = (TUNING.baseMouseSens * mouseSensitivity) + curseFactor * TUNING.curseMouseSensAdd;
    // --- SPEED-AWARE LOOK SENSITIVITY ---
    // The feel problem: at high horizontal speed, the same mouse movement
    // barely rotates your view relative to how fast the world is flying
    // past, so turning feels sluggish and you can't redirect in time.
    // Fix: scale look sensitivity with horizontal speed so the player
    // always has roughly the same "degrees of view per unit of ground
    // covered" feeling. At hSpeed=0 → 1.0x; at hSpeed=35 (~Mach 1) → 1.7x;
    // at hSpeed=70+ (Mach 4) → 1.0+speedLookMultMax. This is what lets
    // you actually navigate obstacles while sprinting without cranking
    // your base sensitivity through the roof.
    const hSpeedNow = Math.hypot(velocity.x, velocity.z);
    const speedLookMult = 1.0 + Math.min(hSpeedNow / TUNING.speedLookMultDivisor, TUNING.speedLookMultMax);
    sens *= speedLookMult;
    yaw -= e.movementX * sens;
    // v2.0: invert Y axis option
    const pitchSens = sens + (curseFactor > 0.7 ? Math.sin(gameTime*3)*0.002 : 0);
    pitch -= e.movementY * pitchSens * (settingInvertY ? -1 : 1);
    pitch = Math.max(-Math.PI/2.2, Math.min(Math.PI/2.2, pitch));
    player.rotation.y = yaw + (curseFactor > 0.8 ? Math.sin(gameTime*1.5)*0.04 : 0);
    camera.rotation.x = pitch;
});

document.addEventListener('contextmenu', e => e.preventDefault());

function handleMouse(button, isDown) {
    const code = `Mouse${button}`;
    if(code === keyMapping.forward) keys.w = isDown;
    if(code === keyMapping.left) keys.a = isDown;
    if(code === keyMapping.backward) keys.s = isDown;
    if(code === keyMapping.right) keys.d = isDown;
    if(code === keyMapping.jump) { keys.space = isDown; if (isDown) jumpBufferTimer = JUMP_BUFFER_TIME; }
    if(code === keyMapping.sprint) keys.shift = isDown;
    if(code === keyMapping.slide) keys.control = isDown;
}

document.addEventListener('mousedown', e => {
    if (rebindingAction) {
        if (e.target.classList.contains('menu-btn')) return;
        keyMapping[rebindingAction] = `Mouse${e.button}`;
        saveKeybinds();
        updateKeybindUI();
        rebindingAction = null;
        return;
    }
    handleMouse(e.button, true);
});
document.addEventListener('mouseup', e => {
    handleMouse(e.button, false);
});

document.addEventListener('keydown', e => {
    if (rebindingAction) {
        e.preventDefault();
        keyMapping[rebindingAction] = e.code;
        saveKeybinds();
        updateKeybindUI();
        rebindingAction = null;
        return;
    }

    // ESC while pause menu is open → resume
    if (e.code === 'Escape' && pauseMenu && pauseMenu.style.display === 'block'
        && gameStarted && !gameEnded && !isJumpscareActive) {
        e.preventDefault();
        resumeGame();
        return;
    }

    if(e.code === keyMapping.forward) keys.w=true;
    if(e.code === keyMapping.left) keys.a=true;
    if(e.code === keyMapping.backward) keys.s=true;
    if(e.code === keyMapping.right) keys.d=true;
    if(e.code === keyMapping.jump) { e.preventDefault(); keys.space=true; if (!e.repeat) jumpBufferTimer = JUMP_BUFFER_TIME; }
    if(e.code === keyMapping.ability) useAbility();
    if(e.code === keyMapping.powerDive && !e.repeat) usePowerDive();
    // v2.0: Time Slow ability on E (default), Minimap toggle on M
    if(e.code === 'KeyE' && !e.repeat) useTimeSlow();
    if(e.code === 'KeyM' && !e.repeat) { toggleMinimap(); }
    
    // Special handling for modifiers to allow both Left/Right versions if not explicitly rebound
    if(e.code === keyMapping.sprint || (keyMapping.sprint === 'ShiftLeft' && e.code === 'ShiftRight')) keys.shift=true;
    if(e.code === keyMapping.slide || (keyMapping.slide === 'ControlLeft' && e.code === 'ControlRight')) keys.control=true;
});
document.addEventListener('keyup', e => {
    if(e.code === keyMapping.forward) keys.w=false;
    if(e.code === keyMapping.left) keys.a=false;
    if(e.code === keyMapping.backward) keys.s=false;
    if(e.code === keyMapping.right) keys.d=false;
    if(e.code === keyMapping.jump) keys.space=false;
    
    if(e.code === keyMapping.sprint || (keyMapping.sprint === 'ShiftLeft' && e.code === 'ShiftRight')) keys.shift=false;
    if(e.code === keyMapping.slide || (keyMapping.slide === 'ControlLeft' && e.code === 'ControlRight')) keys.control=false;
});

