// Place cubes on top of randomly selected platforms
function generateCubePositionsOnPlatforms(platforms, cubeCount = 20) {
    // Find exactly one tagged host platform from each of the 20 structures
    const hosts = platforms.filter(p => p[7] === 'CUBE_PLATFORM');
    
    return hosts.slice(0, cubeCount).map(p => {
        // Place cube directly above the center of its unique obstacle
        return [p[3], p[4] + p[1] + 1.2, p[5]];
    });
}

const CUBE_POSITIONS = generateCubePositionsOnPlatforms(platformData, 20);

