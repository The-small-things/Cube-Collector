// ===================== PICKUP TOAST =====================
function showPickupToast(text) {
    if (!v2UI.pickupToast) return;
    v2UI.pickupToast.textContent = text;
    const col = activePowerup ? '#' + POWERUP_COLORS[activePowerup.type].toString(16).padStart(6, '0') : '#ffdd00';
    v2UI.pickupToast.style.color = col;
    v2UI.pickupToast.classList.add('show');
    setTimeout(() => { if (v2UI.pickupToast) v2UI.pickupToast.classList.remove('show'); }, 1200);
}

// ===================== ACHIEVEMENTS =====================
function unlockAchievement(id) {
    if (achievementsUnlocked.has(id)) return;
    achievementsUnlocked.add(id);
    const ach = ACHIEVEMENTS.find(a => a.id === id);
    if (!ach) return;
    if (v2UI.achName) v2UI.achName.textContent = ach.name;
    if (v2UI.achDesc) v2UI.achDesc.textContent = ach.desc;
    if (v2UI.achievementToast) {
        // Avoid overlapping the minimap when it's on screen.
        const mapVisible = settingMinimap && minimapVisible && v2UI.minimap && v2UI.minimap.style.display !== 'none';
        v2UI.achievementToast.style.top = mapVisible ? '270px' : '80px';
        v2UI.achievementToast.classList.add('show');
        setTimeout(() => { if (v2UI.achievementToast) v2UI.achievementToast.classList.remove('show'); }, 3500);
    }
    // Save to localStorage for persistence
    try {
        const saved = new Set(JSON.parse(localStorage.getItem('redCubeAchievements') || '[]'));
        saved.add(id);
        localStorage.setItem('redCubeAchievements', JSON.stringify([...saved]));
    } catch (e) {}
}

function loadAchievements() {
    try {
        const saved = JSON.parse(localStorage.getItem('redCubeAchievements') || '[]');
        achievementsUnlocked = new Set(saved);
    } catch (e) { achievementsUnlocked = new Set(); }
}

// ===================== RUN STATS PANEL =====================
function showRunStats() {
    const panel = document.getElementById('stats-panel');
    const rows = document.getElementById('stats-rows');
    if (!panel || !rows) return;
    const rowsHtml = [
        ['Mode', gameMode.toUpperCase()],
        ['Difficulty', difficulty.toUpperCase()],
        ['Outcome', (gameEnded === 'win' ? 'WIN' : (gameEnded === 'caught' ? 'CAUGHT' : '—'))],
        ['Time', formatTime(currentRunTime || gameTime)],
        ['Cubes Collected', `${runStats.cubesCollected} / 20`],
        ['Top Speed', runStats.topSpeed.toFixed(1) + ' u/s', 'gold'],
        ['Top Mach Tier', 'MACH ' + runStats.topMach, 'gold'],
        ['Max Combo', '×' + runStats.maxCombo, 'gold'],
        ['Distance Traveled', runStats.distanceTraveled.toFixed(0) + ' u'],
        ['Power-ups Collected', runStats.powerupsCollected, 'purple'],
        ['Time Slow Uses', runStats.timeSlowUses, 'purple'],
        ['Flare Uses', runStats.flareUses, 'purple'],
        ['Power Dive Uses', runStats.powerDiveUses, 'purple'],
        ['Total Jumps', runStats.jumps],
        ['Wall Jumps', runStats.wallJumps],
        ['Slides', runStats.slides],
    ];
    rows.innerHTML = rowsHtml.map(r => `<div class="stat-row${r[2] ? ' ' + r[2] : ''}"><span class="stat-label">${r[0]}</span><span class="stat-value">${r[1]}</span></div>`).join('');
    panel.style.display = 'block';
}

function closeStatsPanel() {
    const panel = document.getElementById('stats-panel');
    if (panel) panel.style.display = 'none';
}

function updateRunStats(dt, hSpeed) {
    if (hSpeed > runStats.topSpeed) runStats.topSpeed = hSpeed;
    if (hSpeed > TUNING.mach3Speed && runStats.topMach < 3) { runStats.topMach = 3; }
    if (hSpeed > TUNING.mach4Speed && runStats.topMach < 4) { runStats.topMach = 4; }
    if (hSpeed > TUNING.mach5Speed && runStats.topMach < 5) { runStats.topMach = 5; unlockAchievement('mach_5'); }
    if (hSpeed > TUNING.mach3Speed && !achievementsUnlocked.has('mach_3')) unlockAchievement('mach_3');

    // Distance traveled
    if (lastPlayerXZ) {
        const dx = player.position.x - lastPlayerXZ.x;
        const dz = player.position.z - lastPlayerXZ.z;
        runStats.distanceTraveled += Math.hypot(dx, dz);
    }
    lastPlayerXZ = { x: player.position.x, z: player.position.z };
}

// ===================== PHANTOM AI UPDATE =====================
function updatePhantom(phantom, dt, diffSettings) {
    const ud = phantom.userData;
    const dx = player.position.x - phantom.position.x;
    const dz = player.position.z - phantom.position.z;
    const distToPlayer = Math.hypot(dx, dz);

    // Rage builds when in detection range
    if (distToPlayer < TUNING.phantomRageBuildDist) {
        ud.rage = Math.min(1, ud.rage + TUNING.phantomRageBuildRate * dt);
    } else {
        ud.rage = Math.max(0, ud.rage - TUNING.phantomRageDecayRate * dt);
    }

    // Slow drift toward player (telegraph between teleports)
    const driftSpeed = TUNING.phantomBaseSpeed * (1 + ud.rage * TUNING.phantomRageSpeedBonus) * diffSettings.speedMult;
    if (distToPlayer > 0.1) {
        phantom.position.x += (dx / distToPlayer) * driftSpeed * dt;
        phantom.position.z += (dz / distToPlayer) * driftSpeed * dt;
    }
    // Float bob
    ud.bobPhase += dt * 1.5;
    phantom.position.y = Math.sin(ud.bobPhase) * 0.6;
    // Face player
    phantom.lookAt(player.position.x, phantom.position.y, player.position.z);

    // Telegraph handling
    if (ud.telegraphTimer > 0) {
        ud.telegraphTimer -= dt;
        if (ud.telegraphTimer <= 0) {
            // Execute teleport
            const tx = player.position.x + (Math.random() - 0.5) * 30;
            const tz = player.position.z + (Math.random() - 0.5) * 30;
            // Clamp to map
            const lim = MAP_SIZE * 0.48;
            phantom.position.x = Math.max(-lim, Math.min(lim, tx));
            phantom.position.z = Math.max(-lim, Math.min(lim, tz));
            if (ud.telegraphMesh) {
                scene.remove(ud.telegraphMesh);
                ud.telegraphMesh = null;
            }
            // Teleport FX: brief purple flash + impact frame
            triggerImpactFrame({ color: '#aa55ff', duration: 180, hitstop: 0, flat: true });
            showSubtitle('* PHANTOM TELEPORTED *', 1.0);
            // Reset teleport timer
            ud.teleportTimer = (ud.rage > 0.5 ? TUNING.phantomTeleportIntervalRage : TUNING.phantomTeleportInterval) * (0.8 + Math.random() * 0.4);
        }
    } else {
        ud.teleportTimer -= dt;
        if (ud.teleportTimer <= 0 && distToPlayer > 12) {
            // Start teleport telegraph — spawn a ghost at target location
            ud.telegraphTimer = TUNING.phantomTelegraphTime;
            // Spawn telegraph mesh
            const tgMat = new THREE.MeshBasicMaterial({
                color: 0xff00ff, transparent: true, opacity: 0.4, wireframe: true
            });
            ud.telegraphMesh = new THREE.Mesh(new THREE.SphereGeometry(ud.scale * 1.5, 8, 8), tgMat);
            // Target = somewhere near player
            const tx = player.position.x + (Math.random() - 0.5) * 30;
            const tz = player.position.z + (Math.random() - 0.5) * 30;
            ud.telegraphMesh.position.set(tx, 1, tz);
            scene.add(ud.telegraphMesh);
        }
    }

    // Catch radius check
    const catchRadius = TUNING.phantomCatchRadius * ud.scale * 0.4 * diffSettings.catchMult;
    if (distToPlayer < catchRadius) {
        // Return catch signal
        return true;
    }

    // Animation: pulse eye + aura with rage
    if (ud.refs.eyeHaloMat) ud.refs.eyeHaloMat.opacity = 0.3 + ud.rage * 0.5 + Math.sin(gameTime * 4) * 0.1;
    if (ud.refs.auraMat) {
        ud.refs.auraMat.opacity = 0.15 + ud.rage * 0.25;
        const auraScale = 1 + ud.rage * 0.3 + Math.sin(gameTime * 3) * 0.05;
        ud.refs.aura.scale.set(auraScale, auraScale, auraScale);
    }
    if (ud.refs.coreMat) ud.refs.coreMat.opacity = 0.4 + ud.rage * 0.4 + Math.sin(gameTime * 5) * 0.1;

    return false;
}

function resetPhantomState(phantom) {
    const ud = phantom.userData;
    ud.rage = 0;
    ud.teleportTimer = 2 + Math.random() * 2;
    ud.telegraphTimer = 0;
    if (ud.telegraphMesh) {
        scene.remove(ud.telegraphMesh);
        ud.telegraphMesh = null;
    }
    // Teleport away from player
    const angle = Math.random() * Math.PI * 2;
    const dist = TUNING.monsterCatchRespawnDist + Math.random() * 80;
    phantom.position.set(player.position.x + Math.cos(angle) * dist, 0, player.position.z + Math.sin(angle) * dist);
}

// ===================== v2.0 RESET ON QUICK RESTART =====================
function resetV2State() {
    comboCount = 0;
    comboMultiplier = 1;
    comboTimer = 0;
    maxComboReached = 0;
    // (stamina removed)
    timeSlowActive = false;
    timeSlowTimer = 0;
    timeSlowCooldownTimer = 0;
    activePowerup = null;
    lastPlayerXZ = null;
    runStats = {
        topSpeed: 0, topMach: 0, maxCombo: 0,
        cubesCollected: 0, distanceTraveled: 0,
        powerupsCollected: 0, abilitiesUsed: 0,
        timeSlowUses: 0, flareUses: 0, powerDiveUses: 0,
        jumps: 0, wallJumps: 0, slides: 0,
    };
    if (v2UI.combo) v2UI.combo.classList.remove('active');
    if (v2UI.timeslowOverlay) v2UI.timeslowOverlay.classList.remove('active');
    if (v2UI.shieldRing) v2UI.shieldRing.classList.remove('active');
    if (v2UI.powerup) v2UI.powerup.style.display = 'none';
    // Clear telegraph meshes
    monsters.forEach(m => {
        if (m.userData.kind === 'phantom' && m.userData.telegraphMesh) {
            scene.remove(m.userData.telegraphMesh);
            m.userData.telegraphMesh = null;
        }
    });
    // Respawn powerups
    spawnPowerups();
    // Hide stats panel
    const sp = document.getElementById('stats-panel');
    if (sp) sp.style.display = 'none';
    // Reset per-run achievements (achievements persist across runs in localStorage, but we reset the in-memory set)
    // Actually we keep them — achievements are persistent.
    // Show version badge
    if (v2UI.versionBadge) v2UI.versionBadge.classList.add('show');
    // Show minimap if enabled
    minimapVisible = settingMinimap;
}

// ===================== ZEN MODE — PEACEFUL OVERRIDES =====================
function applyZenModeVisuals() {
    if (gameMode !== 'zen') return;
    // Brighter lighting
    if (ambientLight) ambientLight.intensity = TUNING.ambientLightStart + TUNING.zenAmbientBoost;
    if (sunLight) sunLight.intensity = TUNING.sunLightStart * 1.3;
    if (skyDome && skyDome.material) {
        skyDome.material.color.setHex(TUNING.zenSkyColor);
    }
    if (scene.fog) {
        scene.fog.density = TUNING.zenFogDensity;
    }
    // Hide curse vignette
    const v = document.getElementById('vignette');
    if (v) v.style.background = 'radial-gradient(ellipse at center, transparent 55%, rgba(50,0,0,0) 100%)';
}

