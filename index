<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>RED CUBE COLLECTOR — v2.0</title>
    <link rel="icon" href="data:,">
<style>
/* ============================================================
   RED CUBE COLLECTOR — "CRIMSON FOLD" UI
   ------------------------------------------------------------
   Creepypasta / daunting. Dark + blood red.
   Custom gothic + typewriter fonts. Heavy atmosphere.
   All element IDs/classes preserved for JS compatibility.
   Display-toggle patterns preserved exactly.
   ============================================================ */

* { margin: 0; padding: 0; box-sizing: border-box; }

:root {
    /* Legacy aliases — JS inline-styles reference these. Keep names. */
    --red:            #d11124;
    --red-bright:     #ff2a3c;
    --red-deep:       #7a0a16;
    --accent-red:     #d11124;
    --accent-gold:    #b8956a;
    --accent-purple:  #7a2c5a;
    --accent-cyan:    #2a6b6b;
    --accent-green:   #4d6b39;

    --bg:           #0a0608;
    --bg-soft:      #120a0d;
    --bg-card:      #15090c;
    --bg-card-2:    #1c0b10;
    --text:         #c8c0ba;
    --text-dim:     #9c9089;
    --text-muted:   #6c5f59;
    --text-faint:   #473b37;
    --text-on-red:  #f6eaea;
    --line:         #3a1a20;
    --line-strong:  #6c1019;
    --line-red:     #d11124;

    --font-display: 'Cinzel Decorative', 'Times New Roman', serif;
    --font-title:   'Cinzel', 'Times New Roman', serif;
    --font-body:    'Special Elite', 'Courier New', monospace;
    --font-mono:    'VT323', 'Courier New', monospace;

    --ease:       cubic-bezier(.2,.7,.2,1);
    --ease-fast:  cubic-bezier(.3,.8,.3,1);
    --ease-bounce:cubic-bezier(.34,1.56,.64,1);

    --glow-red: 0 0 6px rgba(209,17,36,.55), 0 0 18px rgba(209,17,36,.25);
}

html, body {
    height: 100%;
    overflow: hidden;
    background: #070406;
    color: var(--text);
    font-family: var(--font-body);
    font-size: 14px;
    cursor: default;
    user-select: none;
    -webkit-user-select: none;
}

body {
    background:
        radial-gradient(ellipse 80% 60% at 50% 38%, rgba(122,10,22,.22) 0%, rgba(10,6,8,0) 60%),
        radial-gradient(ellipse 120% 100% at 50% 120%, rgba(80,4,14,.30) 0%, rgba(7,4,6,0) 55%),
        #070406;
}

/* ---- Persistent atmosphere: film grain ---- */
body::before {
    content: "";
    position: fixed;
    inset: -50%;
    pointer-events: none;
    z-index: 9990;
    opacity: .045;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='160' height='160'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='2' stitchTiles='stitch'/></filter><rect width='100%25' height='100%25' filter='url(%23n)'/></svg>");
    animation: grain 1.1s steps(4) infinite;
    mix-blend-mode: screen;
}

/* ---- Persistent atmosphere: scanlines ---- */
body::after {
    content: "";
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 9991;
    background: repeating-linear-gradient(
        to bottom,
        rgba(0,0,0,0) 0px,
        rgba(0,0,0,0) 2px,
        rgba(0,0,0,.18) 3px,
        rgba(0,0,0,0) 4px);
    opacity: .35;
    mix-blend-mode: multiply;
}

@keyframes grain {
    0%   { transform: translate(0,0); }
    25%  { transform: translate(-3%,2%); }
    50%  { transform: translate(2%,-2%); }
    75%  { transform: translate(-2%,-3%); }
    100% { transform: translate(2%,3%); }
}

canvas { display: block; position: fixed; inset: 0; z-index: 0; }

/* ---- Custom scrollbars — aged bone on black ---- */
*::-webkit-scrollbar { width: 9px; height: 9px; }
*::-webkit-scrollbar-track { background: #0c0608; }
*::-webkit-scrollbar-thumb {
    background: linear-gradient(#5a0c14,#2c0508);
    border: 1px solid #1c0508;
}
*::-webkit-scrollbar-thumb:hover { background: linear-gradient(#7a0c16,#3c0508); }
* { scrollbar-color: #5a0c14 #0c0608; scrollbar-width: thin; }

/* ============================================================
   TYPOGRAPHY
   ============================================================ */
h1, h2, h3, h4 {
    font-family: var(--font-title);
    font-weight: 700;
    color: var(--text);
    margin-bottom: 10px;
    letter-spacing: .04em;
}
h1 { font-size: 34px; }
h2 { font-size: 24px; }
h3 { font-size: 18px; }
p  { font-size: 14px; color: var(--text); }
strong { font-weight: 700; color: #e7d9d9; }
em { font-style: italic; color: var(--text-dim); }

::selection { background: var(--red-deep); color: #fff; }

/* Global keyboard-focus safety net — every clickable element gets a visible ring. */
button:focus-visible,
[role="button"]:focus-visible,
input:focus-visible {
    outline: 2px solid var(--red-bright);
    outline-offset: 2px;
}

/* ============================================================
   BASE BUTTON — .menu-btn (ghost outline, blood fill)
   ============================================================ */
.menu-btn {
    font-family: var(--font-body);
    font-size: 13px;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--text);
    background: rgba(20,8,11,.6);
    border: 1px solid var(--line-strong);
    padding: 12px 16px;
    min-height: 42px;
    cursor: pointer;
    border-radius: 0;
    position: relative;
    transition: color .18s var(--ease), background .18s var(--ease),
                border-color .18s var(--ease), box-shadow .18s var(--ease),
                text-shadow .18s var(--ease), transform .12s var(--ease);
    overflow: hidden;
}
.menu-btn::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(120deg, transparent 0%, rgba(209,17,36,.16) 50%, transparent 100%);
    transform: translateX(-120%);
    transition: transform .5s var(--ease);
    pointer-events: none;
}
.menu-btn:hover {
    color: #fff;
    background: rgba(122,10,22,.55);
    border-color: var(--red);
    box-shadow: 0 0 10px rgba(209,17,36,.4), inset 0 0 12px rgba(209,17,36,.18);
    text-shadow: 0 0 8px rgba(255,42,60,.7);
    transform: translateY(-1px);
}
.menu-btn:hover::before { transform: translateX(120%); }
.menu-btn:active {
    background: rgba(209,17,36,.7);
    color: #fff;
    box-shadow: inset 0 0 14px rgba(0,0,0,.6);
    transform: translateY(0) scale(.98);
}
.menu-btn:focus-visible {
    outline: 2px solid var(--red-bright);
    outline-offset: 2px;
}
.menu-btn.secondary {
    color: var(--text-dim);
    border-color: var(--line);
    background: rgba(12,6,8,.5);
}
.menu-btn.secondary:hover {
    color: #f0d8d8;
    border-color: var(--red-deep);
    background: rgba(60,6,14,.5);
}
.menu-btn.purple {
    color: #d8b8d0;
    border-color: #4a1d3a;
    background: rgba(40,12,30,.5);
}
.menu-btn.purple:hover {
    color: #fff;
    border-color: var(--accent-purple);
    box-shadow: 0 0 10px rgba(122,44,90,.5), inset 0 0 12px rgba(122,44,90,.2);
    text-shadow: 0 0 8px rgba(200,120,180,.6);
    background: rgba(80,20,60,.6);
}

/* ============================================================
   HUD OVERLAYS — full-screen FX
   ============================================================ */
#crosshair {
    position: fixed;
    top: 50%; left: 50%;
    width: 22px; height: 22px;
    transform: translate(-50%, -50%);
    pointer-events: none;
    z-index: 100;
    mix-blend-mode: screen;
}
#crosshair::before,
#crosshair::after {
    content: "";
    position: absolute;
    background: var(--red-bright);
    box-shadow: 0 0 6px rgba(255,42,60,.8);
}
#crosshair::before {
    top: 50%; left: 0;
    width: 100%; height: 2px;
    transform: translateY(-50%);
    clip-path: polygon(0 0, 35% 0, 35% 100%, 0 100%, 0 0, 65% 0, 65% 100%, 100% 100%, 100% 0, 65% 0);
}
#crosshair::after {
    top: 0; left: 50%;
    width: 2px; height: 100%;
    transform: translateX(-50%);
    clip-path: polygon(0 0, 100% 0, 100% 35%, 0 35%, 0 0, 100% 65%, 100% 100%, 0 100%, 0 65%);
}

#vignette {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 50;
    /* Made visible so the curse / proximity red glow (set via inline style by JS) renders. */
    display: block;
    background: radial-gradient(ellipse at center, transparent 58%, rgba(40,0,6,.55) 100%);
}

#timeslow-overlay {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 51;
    background: radial-gradient(ellipse at center, rgba(40,0,40,.10) 0%, rgba(60,0,80,.30) 100%);
    opacity: 0;
    transition: opacity .25s var(--ease);
}
#timeslow-overlay.active { opacity: 1; }

#shield-ring {
    position: fixed;
    inset: 30px;
    pointer-events: none;
    z-index: 52;
    border: 2px solid rgba(255,42,60,.0);
    border-radius: 2px;
    opacity: 0;
    transition: opacity .2s var(--ease), border-color .2s var(--ease);
    box-shadow: inset 0 0 30px rgba(255,42,60,0);
}
#shield-ring.active {
    opacity: 1;
    border-color: rgba(255,42,60,.75);
    box-shadow: inset 0 0 30px rgba(209,17,36,.4), 0 0 18px rgba(209,17,36,.35);
    animation: shield-pulse 1.6s ease-in-out infinite;
}
@keyframes shield-pulse {
    0%,100% { box-shadow: inset 0 0 24px rgba(209,17,36,.30), 0 0 14px rgba(209,17,36,.25); }
    50%     { box-shadow: inset 0 0 40px rgba(255,42,60,.55), 0 0 26px rgba(255,42,60,.45); }
}

#impact-frame {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 200;
    display: none;
}
#impact-frame.firing { display: block; }
#impact-frame .impact-flash {
    position: absolute;
    inset: 0;
    background: var(--impact-color, rgba(209,17,36,.85));
    opacity: 0;
}
#impact-frame .impact-lines {
    position: absolute;
    inset: 0;
    background:
        repeating-conic-gradient(from 0deg at 50% 50%,
            transparent 0deg, transparent 6deg,
            var(--impact-color, rgba(255,42,60,.35)) 6deg,
            var(--impact-color, rgba(255,42,60,.35)) 7deg);
    opacity: 0;
}
#impact-frame.firing .impact-flash {
    animation: rc-impact-flash var(--impact-duration, 320ms) ease-out forwards;
}
#impact-frame.firing .impact-lines {
    animation: rc-impact-lines var(--impact-duration, 320ms) ease-out forwards;
}

canvas.impact-shake {
    animation: rc-canvas-shake 0.34s ease both;
}
@keyframes mach-shake {
    0%, 100% { transform: translate(0, 0); }
    25%  { transform: translate(-1px, 1px); }
    50%  { transform: translate(1px, -1px); }
    75%  { transform: translate(-1px, -1px); }
}

#curse-msg {
    position: fixed;
    top: 22%;
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--font-display);
    font-size: 30px;
    font-weight: 700;
    color: var(--red-bright);
    text-transform: uppercase;
    pointer-events: none;
    z-index: 95;
    opacity: 0;
    text-align: center;
    white-space: nowrap;
    letter-spacing: .08em;
    text-shadow: 0 0 10px rgba(255,42,60,.8), 0 0 26px rgba(209,17,36,.6);
    /* fast fade-in, slow fade-out handled by JS toggling .visible */
    transition: opacity .25s ease-out, text-shadow .25s ease-out;
}
#curse-msg.visible {
    opacity: 1;
    text-shadow: 0 0 14px rgba(255,42,60,1), 0 0 34px rgba(209,17,36,.8);
    transition: opacity .18s ease-out, text-shadow .18s ease-out;
}
#curse-msg.fadeout {
    opacity: 0;
    text-shadow: 0 0 2px rgba(255,42,60,.1);
    transition: opacity 1.4s ease-in, text-shadow 1.4s ease-in;
}

#version-badge {
    position: fixed;
    top: 10px;
    right: 10px;
    font-family: var(--font-mono);
    font-size: 14px;
    letter-spacing: .14em;
    color: var(--text-muted);
    background: rgba(10,5,7,.7);
    border: 1px solid var(--line);
    padding: 3px 9px;
    z-index: 110;
    text-transform: uppercase;
    opacity: 0;
    transition: opacity .5s var(--ease);
}
#version-badge.show { opacity: 1; color: var(--red); border-color: var(--line-strong); }

/* ============================================================
   COMBO METER
   ============================================================ */
#combo-meter {
    position: fixed;
    top: 74px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 100;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3px;
    opacity: 0;
    transition: opacity .2s var(--ease);
}
#combo-meter.active { opacity: 1; }
#combo-meter .combo-x {
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: 700;
    color: var(--red-bright);
    line-height: 1;
    text-shadow: var(--glow-red);
}
#combo-meter .combo-label {
    font-family: var(--font-mono);
    font-size: 13px;
    letter-spacing: .22em;
    color: var(--text-muted);
    text-transform: uppercase;
}
#combo-meter .combo-bar-bg {
    width: 120px;
    height: 3px;
    background: rgba(209,17,36,.15);
    border: 1px solid var(--line);
    overflow: hidden;
    margin-top: 3px;
}
#combo-meter .combo-bar-fill {
    height: 100%;
    width: 100%;
    background: linear-gradient(90deg, var(--red-deep), var(--red-bright));
    box-shadow: 0 0 8px rgba(255,42,60,.6);
}

/* ============================================================
   PICKUP TOAST + SUBTITLES + ACHIEVEMENT TOAST
   ============================================================ */
#pickup-toast {
    position: fixed;
    top: 28%;
    left: 50%;
    transform: translate(-50%, -10px);
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 700;
    color: #ffe9ec;
    text-transform: uppercase;
    letter-spacing: .1em;
    pointer-events: none;
    z-index: 95;
    opacity: 0;
    text-shadow: 0 0 10px rgba(255,42,60,.8), 0 0 24px rgba(209,17,36,.6);
    transition: opacity .25s var(--ease), transform .25s var(--ease);
}
#pickup-toast.show {
    opacity: 1;
    transform: translate(-50%, 0);
}

#subtitles {
    position: fixed;
    bottom: 16%;
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--font-body);
    font-size: 14px;
    letter-spacing: .06em;
    color: var(--text);
    background: rgba(8,4,6,.82);
    border: 1px solid var(--line-strong);
    border-left: 2px solid var(--red);
    padding: 5px 14px;
    pointer-events: none;
    z-index: 95;
    opacity: 0;
    transition: opacity .2s var(--ease);
    box-shadow: 0 0 14px rgba(0,0,0,.7);
}
#subtitles.show { opacity: 1; }

#achievement-toast {
    position: fixed;
    top: 270px;
    right: 10px;
    width: 270px;
    background: linear-gradient(180deg, rgba(28,10,14,.95), rgba(14,6,9,.95));
    border: 1px solid var(--line-strong);
    border-left: 3px solid var(--red);
    padding: 9px 12px;
    z-index: 120;
    transform: translateX(130%);
    transition: transform .45s var(--ease-bounce);
    box-shadow: 0 0 18px rgba(0,0,0,.8), inset 0 0 18px rgba(209,17,36,.1);
}
#achievement-toast.show { transform: translateX(0); }
#achievement-toast .ach-title {
    font-family: var(--font-mono);
    font-size: 13px;
    letter-spacing: .2em;
    color: var(--red);
    text-transform: uppercase;
    margin-bottom: 3px;
}
#achievement-toast .ach-name {
    font-family: var(--font-title);
    font-size: 15px;
    font-weight: 700;
    color: #f0e0e0;
    margin-bottom: 3px;
}
#achievement-toast .ach-desc {
    font-size: 12px;
    color: var(--text-dim);
}

/* ============================================================
   POWER-UP INDICATOR (top-left)
   ============================================================ */
#powerup-indicator {
    position: fixed;
    top: 74px;
    left: 10px;
    width: 190px;
    background: linear-gradient(180deg, rgba(28,10,14,.92), rgba(14,6,9,.92));
    border: 1px solid var(--line-strong);
    border-left: 3px solid var(--red);
    padding: 6px 10px;
    z-index: 100;
    display: none;
    box-shadow: 0 0 14px rgba(0,0,0,.7), inset 0 0 14px rgba(209,17,36,.08);
}
#powerup-indicator[style]:not([style*="display: none"]):not([style*="display:none"]) {
    display: block !important;
}
#powerup-indicator .pu-name {
    font-family: var(--font-display);
    font-size: 14px;
    font-weight: 700;
    color: var(--red-bright);
    text-transform: uppercase;
    margin-bottom: 5px;
    letter-spacing: .08em;
    text-shadow: var(--glow-red);
}
#powerup-indicator .pu-bar-bg {
    width: 100%;
    height: 4px;
    background: rgba(209,17,36,.15);
    border: 1px solid var(--line);
    overflow: hidden;
}
#powerup-indicator .pu-bar-fill {
    height: 100%;
    width: 100%;
    background: linear-gradient(90deg, var(--red-deep), var(--red-bright));
    box-shadow: 0 0 8px rgba(255,42,60,.6);
}

/* ============================================================
   RUN TIMER (top-center, primary)
   ============================================================ */
#run-timer {
    position: fixed;
    top: 10px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 110;
    display: none;
    align-items: baseline;
    gap: 9px;
    background: linear-gradient(180deg, rgba(28,10,14,.92), rgba(12,5,8,.92));
    border: 1px solid var(--line-strong);
    border-top: 2px solid var(--red);
    padding: 4px 14px;
    font-family: var(--font-mono);
    box-shadow: 0 0 14px rgba(0,0,0,.7);
}
#run-timer[style]:not([style*="display: none"]):not([style*="display:none"]) {
    display: flex !important;
}
#run-timer #run-timer-label {
    font-size: 15px;
    letter-spacing: .2em;
    color: var(--text-muted);
    text-transform: uppercase;
}
#run-timer #run-timer-value {
    font-size: 22px;
    font-weight: 700;
    color: #f4e4e4;
    text-shadow: 0 0 8px rgba(255,42,60,.5);
}
#run-timer #run-timer-mult {
    font-size: 16px;
    color: var(--red);
    letter-spacing: .05em;
}

/* ============================================================
   FPS COUNTER
   ============================================================ */
#fps-counter {
    position: fixed;
    top: 52px;
    right: 10px;
    font-family: var(--font-mono);
    font-size: 15px;
    letter-spacing: .12em;
    color: var(--text-dim);
    background: rgba(10,5,7,.75);
    border: 1px solid var(--line);
    padding: 2px 8px;
    z-index: 110;
    display: none;
}
body.game-active #fps-counter { display: block; }
#fps-counter[style]:not([style*="display: none"]):not([style*="display:none"]) {
    display: block !important;
}

/* ============================================================
   TAINT BADGE
   ============================================================ */
#taint-badge {
    position: fixed;
    top: 10px;
    left: 10px;
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: .12em;
    color: #ffb8b8;
    background: rgba(60,4,10,.85);
    border: 1px solid var(--red);
    padding: 3px 8px;
    z-index: 110;
    display: none;
    text-transform: uppercase;
    box-shadow: 0 0 12px rgba(209,17,36,.5);
    animation: taint-pulse 2s ease-in-out infinite;
}
@keyframes taint-pulse {
    0%,100% { box-shadow: 0 0 10px rgba(209,17,36,.4); }
    50%     { box-shadow: 0 0 20px rgba(255,42,60,.7); }
}
#taint-badge[style]:not([style*="display: none"]):not([style*="display:none"]) {
    display: block !important;
}

/* ============================================================
   MODAL PANELS — shared style
   ============================================================ */
#stats-panel,
#leaderboard-menu,
#pause-menu,
#settings-menu,
#win-screen {
    position: fixed;
    inset: 0;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 24px;
    background:
        radial-gradient(ellipse at center, rgba(122,10,22,.20) 0%, rgba(7,4,6,.92) 70%),
        rgba(7,4,6,.94);
    z-index: 200;
    backdrop-filter: blur(2px);
}
#stats-panel[style]:not([style*="display: none"]):not([style*="display:none"]),
#leaderboard-menu[style]:not([style*="display: none"]):not([style*="display:none"]),
#pause-menu[style]:not([style*="display: none"]):not([style*="display:none"]),
#settings-menu[style]:not([style*="display: none"]):not([style*="display:none"]),
#win-screen[style]:not([style*="display: none"]):not([style*="display:none"]) {
    display: flex !important;
}

/* ============================================================
   STATS PANEL
   ============================================================ */
#stats-panel { align-items: center; justify-content: center; }
#stats-panel > *:not(.stats-close-btn) {
    width: 100%;
    max-width: 520px;
}
#stats-panel h3 {
    font-family: var(--font-display);
    font-size: 22px;
    color: var(--red-bright);
    margin-bottom: 14px;
    text-align: center;
    letter-spacing: .12em;
    text-shadow: var(--glow-red);
}
#stats-rows {
    background: linear-gradient(180deg, rgba(20,9,12,.9), rgba(12,5,8,.9));
    border: 1px solid var(--line-strong);
    border-left: 2px solid var(--red);
    padding: 12px 16px;
    margin-bottom: 14px;
    box-shadow: inset 0 0 18px rgba(0,0,0,.5);
}
#stats-rows .stat-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 5px 0;
    border-bottom: 1px solid var(--line);
    font-family: var(--font-mono);
    font-size: 15px;
    color: var(--text);
}
#stats-rows .stat-row:last-child { border-bottom: none; }
#stats-rows .stat-row .stat-label {
    color: var(--text-muted);
    text-transform: uppercase;
    font-size: 13px;
    letter-spacing: .14em;
}
#stats-rows .stat-row .stat-value {
    color: #f0e0e0;
    font-weight: 700;
    text-shadow: 0 0 6px rgba(255,42,60,.4);
}
#stats-rows .stat-row.gold .stat-value { color: var(--accent-gold); text-shadow: 0 0 6px rgba(184,149,106,.5); }
#stats-rows .stat-row.purple .stat-value { color: #c898c0; text-shadow: 0 0 6px rgba(122,44,90,.5); }
.stats-close-btn { margin: 0 auto; display: block; }

/* Keybind list */
#bind-list {
    display: flex;
    flex-direction: column;
    gap: 3px;
}
#bind-list .keybind-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 5px 8px;
    border: 1px solid var(--line);
    background: rgba(12,6,8,.5);
    transition: border-color .15s var(--ease), background .15s var(--ease);
}
#bind-list .keybind-row:hover { border-color: var(--line-strong); background: rgba(30,10,14,.5); }
#bind-list .kb-label {
    font-size: 13px;
    color: var(--text);
    letter-spacing: .04em;
}
#bind-list .kb-btn {
    font-family: var(--font-mono);
    font-size: 14px;
    letter-spacing: .08em;
    color: #f0d8d8;
    background: rgba(60,6,14,.6);
    border: 1px solid var(--line-strong);
    padding: 3px 8px;
    cursor: pointer;
    min-width: 66px;
    text-align: center;
    transition: background .15s var(--ease), border-color .15s var(--ease), box-shadow .15s var(--ease);
}
#bind-list .kb-btn:hover {
    background: rgba(122,10,22,.7);
    border-color: var(--red);
    box-shadow: 0 0 8px rgba(209,17,36,.4);
}

/* ============================================================
   LEADERBOARD
   ============================================================ */
#leaderboard-menu { flex-direction: column; gap: 0; }
#leaderboard-menu > * { width: 100%; max-width: 760px; }
#leaderboard-menu h2 {
    font-family: var(--font-display);
    font-size: 30px;
    color: var(--red-bright);
    text-align: center;
    margin-bottom: 20px;
    letter-spacing: .14em;
    text-shadow: var(--glow-red);
}

/* Tab row wrapper — mode tabs on top, diff tabs below with a divider */
#leaderboard-tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    justify-content: center;
    margin-bottom: 8px;
}
#leaderboard-diff-tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    justify-content: center;
    margin-bottom: 18px;
    padding-top: 8px;
    border-top: 1px solid var(--line);
}
#leaderboard-tabs .lb-tab,
#leaderboard-diff-tabs .lb-tab {
    font-family: var(--font-body);
    font-size: 13px;
    letter-spacing: .12em;
    color: var(--text-dim);
    background: rgba(14,7,9,.7);
    border: 1px solid var(--line);
    padding: 8px 20px;
    min-height: 38px;
    cursor: pointer;
    text-transform: uppercase;
    border-radius: 1px;
    transition: color .15s var(--ease), background .15s var(--ease), border-color .15s var(--ease);
}
#leaderboard-tabs .lb-tab:hover,
#leaderboard-diff-tabs .lb-tab:hover {
    background: rgba(40,10,16,.7);
    border-color: var(--line-strong);
    color: #f0d8d8;
}
#leaderboard-tabs .lb-tab.active,
#leaderboard-diff-tabs .lb-tab.active {
    color: #fff;
    background: rgba(122,10,22,.85);
    border-color: var(--red);
    box-shadow: 0 0 10px rgba(209,17,36,.45);
}

/* List container */
#leaderboard-list {
    background: linear-gradient(180deg, rgba(20,9,12,.9), rgba(12,5,8,.9));
    border: 1px solid var(--line-strong);
    border-left: 3px solid var(--red);
    padding: 0;
    max-height: 52vh;
    overflow-y: auto;
    font-family: var(--font-mono);
    font-size: 17px;
    color: var(--text);
    margin-bottom: 14px;
    box-shadow: inset 0 0 22px rgba(0,0,0,.6);
}

/* Column header bar */
#leaderboard-list .lb-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 8px 20px;
    background: rgba(30,8,12,.85);
    border-bottom: 1px solid var(--line-strong);
    font-family: var(--font-body);
    font-size: 12px;
    letter-spacing: .14em;
    color: var(--text-muted);
    text-transform: uppercase;
    position: sticky;
    top: 0;
}

/* Entry rows */
#leaderboard-list .lb-row {
    display: grid;
    grid-template-columns: 40px 1fr auto;
    align-items: center;
    gap: 14px;
    padding: 11px 20px;
    border-bottom: 1px solid var(--line);
    transition: background .12s var(--ease);
}
#leaderboard-list .lb-row:last-child { border-bottom: none; }
#leaderboard-list .lb-row:hover { background: rgba(40,10,16,.4); }

/* Rank number */
#leaderboard-list .lb-rank {
    color: var(--text-faint);
    font-size: 15px;
    text-align: right;
}
/* Gold / silver / bronze highlights */
#leaderboard-list .lb-row.rank-1 .lb-rank { color: #c8a84a; text-shadow: 0 0 8px rgba(200,168,74,.5); }
#leaderboard-list .lb-row.rank-2 .lb-rank { color: #9ba8b0; }
#leaderboard-list .lb-row.rank-3 .lb-rank { color: #a07850; }
#leaderboard-list .lb-row.rank-1 { background: rgba(200,168,74,.05); }

/* Player name */
#leaderboard-list .lb-name { color: var(--text); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
#leaderboard-list .lb-row.rank-1 .lb-name { color: #e8d8a0; }

/* Time value */
#leaderboard-list .lb-time {
    color: var(--red-bright);
    font-weight: 700;
    font-size: 18px;
    text-align: right;
    white-space: nowrap;
    text-shadow: 0 0 6px rgba(255,42,60,.35);
}

/* Status bar */
#leaderboard-status {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 7px;
    font-family: var(--font-body);
    font-size: 13px;
    color: var(--text-muted);
    margin-bottom: 14px;
    letter-spacing: .06em;
}
#leaderboard-status .lb-dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    flex-shrink: 0;
}
#leaderboard-status.online  { color: #7acc7a; }
#leaderboard-status.online  .lb-dot { background: #4f4; box-shadow: 0 0 5px #4f4; }
#leaderboard-status.offline { color: #cccc66; }
#leaderboard-status.offline .lb-dot { background: #ff0; box-shadow: 0 0 5px #cc0; }
#leaderboard-status.local   { color: var(--text-muted); }
#leaderboard-status.local   .lb-dot { background: var(--text-faint); }

/* ============================================================
   LOADING SCREEN
   ============================================================ */
#loading-screen {
    position: fixed;
    inset: 0;
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 18px;
    background:
        radial-gradient(ellipse at center, rgba(122,10,22,.25) 0%, rgba(7,4,6,1) 70%),
        #070406;
    z-index: 500;
}
#loading-screen[style]:not([style*="display: none"]):not([style*="display:none"]) {
    display: flex !important;
}
#loading-screen h2 {
    font-family: var(--font-display);
    font-size: 30px;
    color: var(--red-bright);
    text-transform: uppercase;
    letter-spacing: .18em;
    text-shadow: var(--glow-red);
    animation: title-flicker 3.5s linear infinite;
}
#loading-bar-outer {
    width: 320px;
    height: 8px;
    background: rgba(209,17,36,.1);
    border: 1px solid var(--line-strong);
    overflow: hidden;
    box-shadow: inset 0 0 8px rgba(0,0,0,.7);
}
#loading-bar-inner {
    height: 100%;
    width: 0%;
    background: linear-gradient(90deg, var(--red-deep), var(--red-bright));
    box-shadow: 0 0 10px rgba(255,42,60,.7);
    transition: width .25s var(--ease);
}
#loading-status {
    font-family: var(--font-mono);
    font-size: 15px;
    letter-spacing: .14em;
    color: var(--text-muted);
    text-transform: uppercase;
}

/* ============================================================
   MAIN MENU — #instructions  (NEW LAYOUT: ritual tome)
   ============================================================ */
#instructions {
    position: fixed;
    inset: 0;
    display: grid;
    grid-template-columns: 0.95fr 1.35fr;
    gap: 22px;
    padding: 26px;
    z-index: 150;
    overflow-y: auto;
    background:
        radial-gradient(ellipse 70% 55% at 30% 40%, rgba(122,10,22,.22) 0%, rgba(7,4,6,0) 60%),
        radial-gradient(ellipse 80% 60% at 80% 90%, rgba(60,4,12,.30) 0%, rgba(7,4,6,0) 55%),
        #070406;
}
#instructions[style*="display: none"],
#instructions[style*="display:none"] { display: none !important; }
#instructions[style]:not([style*="display: none"]):not([style*="display:none"]) {
    display: grid !important;
}
#instructions .brand-col,
#instructions .config-col > * {
    animation: menu-rise .5s var(--ease) both;
}
#instructions .config-col > *:nth-child(1) { animation-delay: .03s; }
#instructions .config-col > *:nth-child(2) { animation-delay: .08s; }
#instructions .config-col > *:nth-child(3) { animation-delay: .13s; }
#instructions .config-col > *:nth-child(4) { animation-delay: .18s; }
#instructions .config-col > *:nth-child(5) { animation-delay: .23s; }
@keyframes menu-rise {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
}
@media (prefers-reduced-motion: reduce) {
    #instructions .brand-col,
    #instructions .config-col > * { animation: none; }
    #instructions .mode-btn.active,
    #instructions .diff-btn.active { animation: none; }
}
/* keyboard accessibility — visible focus ring everywhere a default outline got stripped */
#instructions button:focus-visible,
#instructions .start:focus-visible {
    outline: 2px solid var(--red-bright);
    outline-offset: 2px;
}

#instructions .brand-col {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    align-items: flex-start;
    padding: 22px 22px 18px;
    background:
        linear-gradient(180deg, rgba(22,9,12,.78), rgba(10,5,7,.78));
    border: 1px solid var(--line-strong);
    box-shadow: inset 0 0 40px rgba(0,0,0,.6), 0 0 22px rgba(0,0,0,.6);
    overflow: hidden;
}
/* corner brackets */
#instructions .brand-col::before,
#instructions .brand-col::after {
    content: "";
    position: absolute;
    width: 26px; height: 26px;
    border: 2px solid var(--red);
    pointer-events: none;
}
#instructions .brand-col::before { top: 8px; left: 8px; border-right: none; border-bottom: none; }
#instructions .brand-col::after  { bottom: 8px; right: 8px; border-left: none; border-top: none; }

#instructions .brand-col .version-tag {
    font-family: var(--font-mono);
    font-size: 14px;
    letter-spacing: .22em;
    color: var(--red);
    text-transform: uppercase;
    margin-bottom: 14px;
    padding: 2px 8px;
    border: 1px solid var(--line-strong);
    background: rgba(40,6,12,.5);
}
#instructions .brand-col h2 {
    font-family: var(--font-display);
    font-size: 56px;
    font-weight: 700;
    line-height: .96;
    color: #efe0e0;
    margin-bottom: 10px;
    letter-spacing: .02em;
    text-shadow: 0 0 14px rgba(209,17,36,.4);
    animation: title-flicker 5.5s linear infinite;
}
#instructions .brand-col h2 .red {
    color: var(--red-bright);
    text-shadow: 0 0 12px rgba(255,42,60,.8), 0 0 28px rgba(209,17,36,.6);
}
#instructions .brand-col .start {
    appearance: none;
    -webkit-appearance: none;
    display: inline-block;
    font-family: var(--font-display);
    font-size: 18px;
    letter-spacing: .2em;
    color: #fff;
    text-transform: uppercase;
    cursor: pointer;
    padding: 10px 22px;
    border: 1px solid var(--red);
    background: linear-gradient(180deg, rgba(122,10,22,.6), rgba(60,4,10,.6));
    margin: 18px 0 10px;
    text-shadow: 0 0 10px rgba(255,42,60,.6);
    box-shadow: 0 0 14px rgba(209,17,36,.35), inset 0 0 14px rgba(209,17,36,.2);
    transition: background .2s var(--ease), box-shadow .2s var(--ease), transform .12s var(--ease);
    position: relative;
}
#instructions .brand-col .start::after {
    content: "_";
    margin-left: 4px;
    animation: caret 1s steps(1) infinite;
}
@keyframes caret { 0%,49%{opacity:1;} 50%,100%{opacity:0;} }
#instructions .brand-col .start:hover {
    background: linear-gradient(180deg, rgba(209,17,36,.8), rgba(122,10,22,.8));
    box-shadow: 0 0 24px rgba(255,42,60,.7), inset 0 0 18px rgba(255,42,60,.3);
    transform: translateY(-2px);
}
#instructions .brand-col .start:active { transform: translateY(1px); }
#instructions .brand-col .flavor-text {
    font-family: var(--font-body);
    font-size: 13px;
    color: var(--text-muted);
    font-style: italic;
    letter-spacing: .04em;
    max-width: 320px;
    line-height: 1.5;
}

#instructions .config-col {
    display: flex;
    flex-direction: column;
    gap: 12px;
    overflow-y: auto;
    padding-right: 6px;
}
#instructions .menu-actions {
    display: flex;
    gap: 7px;
}
#instructions .menu-actions .menu-btn { flex: 1; }

#instructions .config-block {
    position: relative;
    background: linear-gradient(180deg, rgba(18,8,11,.82), rgba(10,5,7,.82));
    border: 1px solid var(--line-strong);
    padding: 11px 15px 13px;
    box-shadow: inset 0 0 22px rgba(0,0,0,.45);
    transition: border-color .2s var(--ease), box-shadow .2s var(--ease);
}
#instructions .config-block:hover {
    border-color: var(--red-deep);
    box-shadow: inset 0 0 22px rgba(0,0,0,.45), 0 0 14px rgba(209,17,36,.12);
}
#instructions .config-block.config-objective {
    border-color: var(--red-deep);
    border-left: 2px solid var(--red);
    background: linear-gradient(180deg, rgba(30,8,14,.85), rgba(14,5,9,.85));
}
#instructions .section-label {
    font-family: var(--font-title);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: .26em;
    color: var(--red);
    text-transform: uppercase;
    margin-bottom: 10px;
    border-bottom: 1px solid var(--line-strong);
    padding-bottom: 4px;
    text-shadow: 0 0 8px rgba(209,17,36,.4);
}

#instructions .controls-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3px 14px;
}
#instructions .ctrl {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 4px 0;
    border-bottom: 1px solid var(--line);
    font-size: 13px;
    color: var(--text);
    letter-spacing: .03em;
}
#instructions .ctrl:hover { color: #f0d8d8; }
#instructions .ctrl > span:first-child { color: var(--text); }
#instructions .ctrl .key {
    font-family: var(--font-mono);
    font-size: 14px;
    letter-spacing: .08em;
    color: var(--red-bright);
    background: rgba(60,6,14,.55);
    border: 1px solid var(--line-strong);
    padding: 1px 7px;
    text-shadow: 0 0 6px rgba(255,42,60,.5);
}

#instructions .mode-grid,
#instructions .diff-grid {
    display: grid;
    gap: 6px;
}
#instructions .mode-grid { grid-template-columns: repeat(3, 1fr); }
#instructions .diff-grid { grid-template-columns: repeat(5, 1fr); }

#instructions .mode-btn,
#instructions .diff-btn {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 3px;
    font-family: var(--font-body);
    font-size: 11px;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--text-dim);
    background: rgba(12,6,8,.6);
    border: 1px solid var(--line);
    padding: 13px 4px;
    min-height: 44px;
    cursor: pointer;
    transition: color .16s var(--ease), background .16s var(--ease),
                border-color .16s var(--ease), box-shadow .16s var(--ease),
                transform .16s var(--ease);
    position: relative;
}
#instructions .mode-btn .sym,
#instructions .diff-btn .sym {
    width: 28px; height: 28px;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
    transition: filter .16s var(--ease), opacity .16s var(--ease);
    opacity: .55;
}
#instructions .mode-btn .sym svg,
#instructions .diff-btn .sym svg {
    width: 100%; height: 100%;
    fill: currentColor;
    transition: fill .16s var(--ease);
}
#instructions .mode-btn:hover .sym,
#instructions .diff-btn:hover .sym { opacity: .85; }
#instructions .mode-btn.active .sym,
#instructions .diff-btn.active .sym {
    opacity: 1;
    filter: drop-shadow(0 0 5px rgba(255,42,60,.85));
}
#instructions .mode-btn .lbl,
#instructions .diff-btn .lbl { line-height: 1.1; text-align: center; }
#instructions .mode-btn:hover,
#instructions .diff-btn:hover {
    color: #f0d8d8;
    border-color: var(--line-strong);
    background: rgba(30,10,14,.6);
    transform: translateY(-1px);
}
#instructions .mode-btn:active,
#instructions .diff-btn:active {
    transform: translateY(0) scale(.97);
}
#instructions .mode-btn.active,
#instructions .diff-btn.active {
    color: #fff;
    border-color: var(--red);
    background: linear-gradient(180deg, rgba(122,10,22,.7), rgba(60,4,10,.7));
    box-shadow: 0 0 12px rgba(209,17,36,.45), inset 0 0 12px rgba(209,17,36,.2);
    text-shadow: 0 0 8px rgba(255,42,60,.6);
    animation: active-pulse 2.2s ease-in-out infinite;
}
@keyframes active-pulse {
    0%,100% { box-shadow: 0 0 12px rgba(209,17,36,.45), inset 0 0 12px rgba(209,17,36,.2); }
    50%     { box-shadow: 0 0 18px rgba(209,17,36,.65), inset 0 0 14px rgba(209,17,36,.3); }
}


#instructions .objective {
    font-family: var(--font-body);
    font-size: 13px;
    line-height: 1.6;
    color: var(--text-dim);
    letter-spacing: .02em;
}
#instructions .objective strong { color: var(--red-bright); letter-spacing: .08em; }
#instructions .objective em { color: var(--accent-gold); font-style: italic; }

@keyframes title-flicker {
    0%,100% { opacity: 1; }
    41%,43% { opacity: 1; }
    42% { opacity: .55; }
    62%,64% { opacity: 1; }
    63% { opacity: .7; }
    77% { opacity: 1; }
    78% { opacity: .4; }
    79% { opacity: 1; }
}

/* ============================================================
   PAUSE MENU
   ============================================================ */
#pause-menu {
    flex-direction: column;
    gap: 7px;
}
#pause-menu > * { width: 100%; max-width: 320px; }
#pause-menu h2 {
    font-family: var(--font-display);
    font-size: 30px;
    color: var(--red-bright);
    text-align: center;
    margin-bottom: 10px;
    letter-spacing: .18em;
    text-shadow: var(--glow-red);
    animation: title-flicker 4s linear infinite;
}
#pause-menu #pause-stats {
    font-family: var(--font-mono);
    font-size: 16px;
    color: var(--text);
    text-align: center;
    background: linear-gradient(180deg, rgba(20,9,12,.9), rgba(12,5,8,.9));
    border: 1px solid var(--line-strong);
    border-left: 2px solid var(--red);
    padding: 10px;
    line-height: 1.7;
    box-shadow: inset 0 0 16px rgba(0,0,0,.5);
}
#pause-menu #pause-stats #pause-cubes,
#pause-menu #pause-stats #pause-time {
    color: var(--red-bright);
    font-weight: 700;
    text-shadow: 0 0 6px rgba(255,42,60,.5);
}

/* ============================================================
   SETTINGS MENU
   ============================================================ */
#settings-menu .settings-shell {
    display: grid;
    grid-template-columns: 200px 1fr;
    grid-template-rows: auto 1fr;
    gap: 18px;
    width: 100%;
    max-width: 920px;
    max-height: 86vh;
    background: linear-gradient(180deg, rgba(20,9,12,.96), rgba(10,5,7,.96));
    border: 1px solid var(--line-strong);
    padding: 18px;
    overflow: hidden;
    box-shadow: 0 0 30px rgba(0,0,0,.8), inset 0 0 30px rgba(0,0,0,.5);
}
#settings-menu .settings-topbar {
    grid-column: 1 / -1;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
    padding-bottom: 14px;
    border-bottom: 1px solid var(--line-strong);
}
#settings-menu .settings-topbar h2 {
    font-family: var(--font-display);
    font-size: 22px;
    color: var(--red-bright);
    letter-spacing: .12em;
    text-shadow: var(--glow-red);
    margin: 0;
}
#settings-menu .settings-back-btn {
    font-family: var(--font-body);
    font-size: 13px;
    letter-spacing: .16em;
    text-transform: uppercase;
    color: #fff;
    background: linear-gradient(180deg, rgba(122,10,22,.75), rgba(60,4,10,.75));
    border: 1px solid var(--red);
    padding: 10px 20px;
    min-height: 40px;
    display: flex;
    align-items: center;
    gap: 8px;
    cursor: pointer;
    box-shadow: 0 0 12px rgba(209,17,36,.35), inset 0 0 10px rgba(209,17,36,.18);
    text-shadow: 0 0 8px rgba(255,42,60,.6);
    transition: background .18s var(--ease), box-shadow .18s var(--ease), transform .12s var(--ease);
}
#settings-menu .settings-back-btn:hover {
    background: linear-gradient(180deg, rgba(209,17,36,.85), rgba(122,10,22,.85));
    box-shadow: 0 0 20px rgba(255,42,60,.6), inset 0 0 14px rgba(255,42,60,.3);
    transform: translateY(-1px);
}
