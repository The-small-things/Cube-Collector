// ===================== ANIME IMPACT FRAME (reusable FX) =====================
// Mode-agnostic "impact frame" punch: a hard color flash + a burst of radiating
// speed-lines, with an optional brief hitstop (freeze), screen shake, and a
// "flat" pass that strips the 3D scene down to a flat 2D-poster look for the
// duration of the hit — pitch-black platforms, white sky/ground, solid red
// cubes, solid yellow beacons — the classic anime way of selling a hit.
// Call it from ANY mode or event; it has no idea what triggered it, so it's
// safe to reuse for beat drops, monster hits, big collisions, ability pops, etc.
//
//   triggerImpactFrame();                                  // default white punch
//   triggerImpactFrame({ color: '#ff1414', hitstop: 90 });  // red, longer freeze
//   triggerImpactFrame({ shake: false });                   // no camera shake
//   triggerImpactFrame({ flat: false });                    // skip the flat 2D look
//
// Options:
//   color    - flash/line tint, any CSS color (default '#ffffff')
//   duration - total flash+lines lifespan in ms (default 260)
//   hitstop  - ms to freeze game motion for, 0 disables (default 80)
//   shake    - whether to punch the canvas with a screen shake (default true)
//   blend    - CSS mix-blend-mode for the flash layer (default 'screen')
//   flat     - whether to apply the flat 2D-poster scene look (default true)
const impactFrameEl = document.getElementById('impact-frame');
let impactFrameHitstopUntil = 0; // real-world ms timestamp; read each frame in animate()

// ---- Flat 2D-poster scene look -----------------------------------------
// Kills all lighting (so any lit surface — i.e. every platform, regardless
// of its normal color — falls to pitch black) and forces the few things
// that are meant to read as color (sky, ground, beacons) to flat solid
// values. Cubes and beacons already render via emissive, which ignores
// lighting entirely, so they stay a clean solid red/yellow once the lights
// are killed — no per-object color hunting needed.
let impactFlatModeActive = false;
let _flatModeSnapshot = null;
let _fovWasFrozen = false; // tracks whether camera.fov was frozen by an impact frame

function setFlatImpactStyle(active) {
    if (active === impactFlatModeActive) return;
    impactFlatModeActive = active;

    if (active) {
        _flatModeSnapshot = {
            bg: scene.background.clone(),
            skyDomeColor: skyDomeMat.color.clone(),
            fogDensity: scene.fog.density,
            groundColor: groundMat.color.clone(),
            groundEmissive: groundMat.emissive.clone(),
            ambientIntensity: ambientLight.intensity,
            sunIntensity: sunLight.intensity,
            flashlightIntensity: flashlight ? flashlight.intensity : null,
            beacons: beaconMats.map(({ core, glow }) => ({
                coreOpacity: core.opacity, glowOpacity: glow.opacity
            })),
            ringOpacity: ringInstanced ? ringInstanced.material.opacity : null
        };

        scene.background.setHex(0xffffff);   // sky -> white
        skyDomeMat.color.setHex(0xffffff);
        scene.fog.density = 0;                // no haze muddying the flat look
        groundMat.color.setHex(0xffffff);     // ground -> white
        groundMat.emissive.setHex(0xffffff);  // ...and unlit, so it stays white with lights off
        ambientLight.intensity = 0;           // lights off -> every lit surface (platforms) goes black
        sunLight.intensity = 0;
        if (flashlight) flashlight.intensity = 0;
        beaconMats.forEach(({ core, glow }) => { core.opacity = 1; glow.opacity = 1; }); // solid yellow beacons
        if (ringInstanced) ringInstanced.material.opacity = 1; // solid yellow floating rings
    } else {
        const s = _flatModeSnapshot;
        if (!s) return;
        scene.background.copy(s.bg);
        skyDomeMat.color.copy(s.skyDomeColor);
        // Recompute fog based on current curse state rather than restoring
        // the pre-impact snapshot. This ensures survival fog updates after
        // beat drops reflect the current cube count.
        try { updateCurse(); } catch (e) { scene.fog.density = s.fogDensity; }
        groundMat.color.copy(s.groundColor);
        groundMat.emissive.copy(s.groundEmissive);
        ambientLight.intensity = s.ambientIntensity;
        sunLight.intensity = s.sunIntensity;
        if (flashlight && s.flashlightIntensity !== null) flashlight.intensity = s.flashlightIntensity;
        beaconMats.forEach(({ core, glow }, i) => {
            core.opacity = s.beacons[i].coreOpacity;
            glow.opacity = s.beacons[i].glowOpacity;
        });
        if (ringInstanced && s.ringOpacity !== null) ringInstanced.material.opacity = s.ringOpacity;
        _flatModeSnapshot = null;
    }
}

function triggerImpactFrame(opts = {}) {
    const {
        color = '#ffffff',
        duration = 240,
        hitstop = 80,
        shake = false, //hgf
        blend = 'screen',
        flat = true
    } = opts;

    // Particle-effects setting gates the visual flash + speed-lines (the
    // hitstop freeze + camera shake still fire so the impact "punch" is
    // preserved even with particles fully off).
    if (particleEffectsLevel === 'off') {
        if (hitstop > 0) impactFrameHitstopUntil = performance.now() + hitstop;
        return;
    }
    // On 'low', halve the duration so the burst is briefer.
    const effectiveDuration = particleEffectsLevel === 'low' ? Math.round(duration * 0.5) : duration;

    impactFrameEl.style.setProperty('--impact-color', color);
    impactFrameEl.style.setProperty('--impact-duration', effectiveDuration + 'ms');
    impactFrameEl.style.setProperty('--impact-blend', blend);

    // Restart the CSS animations even if one is already mid-flight.
    impactFrameEl.classList.remove('firing');
    void impactFrameEl.offsetWidth; // force reflow so the class re-triggers
    impactFrameEl.classList.add('firing');
    clearTimeout(impactFrameEl._hideTimer);
    impactFrameEl._hideTimer = setTimeout(() => impactFrameEl.classList.remove('firing'), effectiveDuration + 30);

    if (hitstop > 0) {
        impactFrameHitstopUntil = performance.now() + hitstop;
    }

    if (shake && renderer && renderer.domElement) {
        const canvas = renderer.domElement;
        canvas.classList.remove('impact-shake');
        void canvas.offsetWidth;
        canvas.classList.add('impact-shake');
        clearTimeout(canvas._shakeTimer);
        canvas._shakeTimer = setTimeout(() => canvas.classList.remove('impact-shake'), 340);
    }

    if (flat) {
        setFlatImpactStyle(true);
        clearTimeout(window._impactFlatTimer);
        window._impactFlatTimer = setTimeout(() => setFlatImpactStyle(false), duration);
    }
}
window.triggerImpactFrame = triggerImpactFrame; // exposed so any mode/event can call it


